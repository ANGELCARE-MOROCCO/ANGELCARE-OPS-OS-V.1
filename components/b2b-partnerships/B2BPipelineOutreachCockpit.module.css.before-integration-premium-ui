.scriptComposer,
.formPanel,
.outreachForm,
.templateComposer {
  position: relative;
  overflow: hidden;
  border-radius: 30px !important;
  border: 1px solid rgba(226, 232, 240, 0.96) !important;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, .08), transparent 34%),
    #ffffff !important;
  box-shadow: 0 24px 62px rgba(15, 23, 42, .075) !important;
}

.composer textarea,
.messageComposer textarea,
.scriptComposer textarea,
.formPanel textarea,
.outreachForm textarea,
.templateComposer textarea,
.composer input,
.messageComposer input,
.scriptComposer input,
.formPanel input,
.outreachForm input,
.templateComposer input,
.composer select,
.messageComposer select,
.scriptComposer select,
.formPanel select,
.outreachForm select,
.templateComposer select {
  border-radius: 17px !important;
  border: 1px solid #e2e8f0 !important;
  background: linear-gradient(180deg, #ffffff, #fbfdff) !important;
  color: #0f172a !important;
  font-weight: 750;
}

.composer textarea:focus,
.messageComposer textarea:focus,
.scriptComposer textarea:focus,
.formPanel textarea:focus,
.outreachForm textarea:focus,
.templateComposer textarea:focus,
.composer input:focus,
.messageComposer input:focus,
.scriptComposer input:focus,
.formPanel input:focus,
.outreachForm input:focus,
.templateComposer input:focus,
.composer select:focus,
.messageComposer select:focus,
.scriptComposer select:focus,
.formPanel select:focus,
.outreachForm select:focus,
.templateComposer select:focus {
  outline: none !important;
  border-color: #93c5fd !important;
  box-shadow: 0 0 0 4px rgba(37, 99, 235, .10) !important;
}

/* Message preview / scripts */
.preview,
.messagePreview,
.scriptPreview,
.templatePreview {
  border-radius: 24px !important;
  border: 1px solid #e5e7eb !important;
  background:
    linear-gradient(135deg, #ffffff, #f8fbff) !important;
  box-shadow: 0 18px 42px rgba(15, 23, 42, .06);
}

.preview::before,
.messagePreview::before,
.scriptPreview::before,
.templatePreview::before {
  content: "✨ Ready-to-send script";
  display: inline-flex;
  width: fit-content;
  margin-bottom: 12px;
  padding: 7px 10px;
  border-radius: 999px;
  color: #1d4ed8;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .09em;
  text-transform: uppercase;
}

/* Timeline / history */
.timeline,
.history,
.activityFeed,
.outreachHistory {
  position: relative;
  border-radius: 30px !important;
  border: 1px solid rgba(226, 232, 240, .96) !important;
  background: #ffffff !important;
  box-shadow: 0 24px 62px rgba(15, 23, 42, .075);
}

.timelineItem,
.historyItem,
.activityItem,
.logItem {
  position: relative;
  border-radius: 22px !important;
  border: 1px solid #e5e7eb !important;
  background:
    linear-gradient(135deg, #ffffff, #f8fbff) !important;
  box-shadow: 0 14px 34px rgba(15, 23, 42, .055);
}

.timelineItem::before,
.historyItem::before,
.activityItem::before,
.logItem::before {
  content: "↗";
  display: grid;
  place-items: center;
  width: 32px;
  height: 32px;
  border-radius: 13px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  color: #1d4ed8;
  font-weight: 950;
  margin-bottom: 8px;
}

/* Toolbar / filters */
.filters,
.toolbar,
.outreachToolbar,
.commandToolbar,
.searchBar {
  position: relative;
  z-index: 1;
  padding: 14px !important;
  border-radius: 24px !important;
  border: 1px solid rgba(226, 232, 240, 0.96) !important;
  background:
    linear-gradient(135deg, rgba(255,255,255,.96), rgba(248,250,252,.88)) !important;
  box-shadow: 0 18px 46px rgba(15, 23, 42, 0.055);
  backdrop-filter: blur(18px);
}

.filters input,
.toolbar input,
.outreachToolbar input,
.commandToolbar input,
.searchBar input,
.filters select,
.toolbar select,
.outreachToolbar select,
.commandToolbar select,
.searchBar select {
  min-height: 48px !important;
  border-radius: 17px !important;
  background: #ffffff !important;
  border: 1px solid #e2e8f0 !important;
  color: #0f172a !important;
  font-weight: 800;
}

/* Tables if outreach has log tables */
.tableWrap,
.tableContainer,
.directoryTable {
  border-radius: 28px !important;
  overflow: hidden;
  border: 1px solid rgba(226, 232, 240, 0.98) !important;
  background: #ffffff !important;
  box-shadow: 0 24px 64px rgba(15, 23, 42, 0.075);
}

.tableWrap :global(thead),
.tableContainer :global(thead),
.directoryTable :global(thead) {
  background: linear-gradient(135deg, #f8fafc 0%, #eef6ff 52%, #fdf2f8 100%) !important;
}

.tableWrap :global(th),
.tableContainer :global(th),
.directoryTable :global(th) {
  height: 56px !important;
  padding: 0 18px !important;
  color: #64748b !important;
  font-size: 11px !important;
  letter-spacing: .13em !important;
  text-transform: uppercase !important;
  font-weight: 950 !important;
}

.tableWrap :global(td),
.tableContainer :global(td),
.directoryTable :global(td) {
  padding: 16px 18px !important;
  border-top: 1px solid rgba(226, 232, 240, 0.88) !important;
}

/* Buttons */
.primaryButton,
.secondaryButton,
.smallButton,
.actionButton,
.tableAction,
.card button,
.outreachCard button,
.actionCard button,
.scriptCard button,
.templateCard button {
  transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease !important;
}

.primaryButton,
.actionButton,
button.primaryButton {
  background: linear-gradient(135deg, #07111f 0%, #0f172a 48%, #1e3a8a 100%) !important;
  color: #ffffff !important;
  box-shadow: 0 16px 34px rgba(37, 99, 235, .20) !important;
}

.secondaryButton,
.smallButton,
button.secondaryButton,
button.smallButton {
  background: #ffffff !important;
  border: 1px solid #e5e7eb !important;
  color: #0f172a !important;
  box-shadow: 0 10px 24px rgba(15, 23, 42, .055);
}

.primaryButton:hover,
.secondaryButton:hover,
.smallButton:hover,
.actionButton:hover,
.tableAction:hover,
.card button:hover,
.outreachCard button:hover,
.actionCard button:hover,
.scriptCard button:hover,
.templateCard button:hover {
  transform: translateY(-2px);
}

/* Empty states */
.emptyState,
.empty,
.noData,
.emptyPanel {
  border: 1px dashed #cbd5e1 !important;
  border-radius: 24px !important;
  background:
    radial-gradient(circle at center, rgba(37, 99, 235, .08), transparent 55%),
    #ffffff !important;
  color: #64748b !important;
  min-height: 130px;
}

/* Modal visual polish */
.modalBackdrop {
  background:
    radial-gradient(circle at 50% 0%, rgba(37, 99, 235, .18), transparent 34%),
    rgba(15, 23, 42, .58) !important;
  backdrop-filter: blur(12px);
  z-index: 2147483000 !important;
}

.modal,
.megaModal,
.detailModal,
.drawer,
.sidePanel {
  position: relative;
  z-index: 2147483001 !important;
  border: 1px solid rgba(226, 232, 240, 0.98) !important;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, .10), transparent 28%),
    linear-gradient(180deg, #ffffff, #f8fafc) !important;
  box-shadow: 0 40px 110px rgba(15, 23, 42, .30) !important;
}

/* Responsive */
@media (max-width: 1200px) {
  .outreachHero::after,
  .cockpitHero::after,
  .commandHero::after,
  .hero::after,
  .header::after {
    display: none;
  }
}

@media (max-width: 760px) {
  .outreachCard,
  .actionCard,
  .scriptCard,
  .templateCard,
  .messageCard,
  .panel,
  .outreachPanel,
  .communicationPanel {
    border-radius: 24px !important;
  }
}

