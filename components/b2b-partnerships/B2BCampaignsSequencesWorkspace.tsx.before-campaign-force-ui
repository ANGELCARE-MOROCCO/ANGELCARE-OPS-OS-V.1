'use client'

import { useEffect, useMemo, useState } from 'react'
import styles from './B2BCampaignsSequencesWorkspace.module.css'

type Campaign = { id:string; name:string; objective?:string|null; segment:string; status:string; target_count?:number; contacted_count?:number; positive_reply_count?:number; meeting_booked_count?:number; signed_partner_count?:number; start_at?:string|null; end_at?:string|null }
type Sequence = { id:string; name:string; segment:string; objective?:string|null; steps?: Array<{ id:string; step_order:number; channel:string; delay_days:number; task_title?:string|null; instructions?:string|null }> }

async function readJson<T>(url:string):Promise<T[]> { const r = await fetch(url,{cache:'no-store'}); const j = await r.json(); if(!r.ok||!j.ok) throw new Error(j.error||`Request failed: ${url}`); return j.data || [] }

export default function B2BCampaignsSequencesWorkspace(){
  const [campaigns,setCampaigns]=useState<Campaign[]>([])
  const [sequences,setSequences]=useState<Sequence[]>([])
  const [error,setError]=useState<string|null>(null)
  const [modal,setModal]=useState<'campaign'|'sequence'|null>(null)
  const [busy,setBusy]=useState(false)
  const [campaignForm,setCampaignForm]=useState({name:'',segment:'hospitality',objective:'',status:'Draft',target_count:'80',start_at:'',end_at:'',notes:''})
  const [sequenceForm,setSequenceForm]=useState({name:'',segment:'hospitality',objective:'',steps:'Email J0\nCall J+1\nWhatsApp J+3\nFollow-up email J+5'})
  async function load(){ try{ setError(null); const [c,s]=await Promise.all([readJson<Campaign>('/api/b2b-partnerships/campaigns'),readJson<Sequence>('/api/b2b-partnerships/sequences')]); setCampaigns(c); setSequences(s)} catch(e){setError(e instanceof Error?e.message:'Unable to load campaigns')} }
  useEffect(()=>{load(); const id=setInterval(load,30000); return()=>clearInterval(id)},[])
  const metrics=useMemo(()=>({total:campaigns.length,running:campaigns.filter(c=>c.status==='Running').length,target:campaigns.reduce((a,c)=>a+Number(c.target_count||0),0),meetings:campaigns.reduce((a,c)=>a+Number(c.meeting_booked_count||0),0)}),[campaigns])
  async function createCampaign(){ setBusy(true); try{ const r=await fetch('/api/b2b-partnerships/campaigns',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(campaignForm)}); const j=await r.json(); if(!r.ok||!j.ok) throw new Error(j.error||'Unable to create campaign'); setModal(null); setCampaignForm({name:'',segment:'hospitality',objective:'',status:'Draft',target_count:'80',start_at:'',end_at:'',notes:''}); await load()}catch(e){setError(e instanceof Error?e.message:'Unable to create campaign')}finally{setBusy(false)} }
  async function createSequence(){ setBusy(true); try{ const steps=sequenceForm.steps.split('\n').filter(Boolean).map((line,index)=>({step_order:index+1,channel:line.toLowerCase().includes('call')?'Phone':line.toLowerCase().includes('whatsapp')?'WhatsApp':'Email',delay_days:index*2,task_title:line,instructions:line})); const r=await fetch('/api/b2b-partnerships/sequences',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({...sequenceForm,steps})}); const j=await r.json(); if(!r.ok||!j.ok) throw new Error(j.error||'Unable to create sequence'); setModal(null); await load()}catch(e){setError(e instanceof Error?e.message:'Unable to create sequence')}finally{setBusy(false)} }
  return <main className={`${styles.workspace} ${styles.campaignPremiumSurface}`}>
    <section className={styles.hero}><div><span className={styles.eyebrow}>Campaign orchestration</span><h2>Campaigns & Sequences Engine</h2><p>Planifiez des campagnes multi-touch pour hôtels, resorts, cliniques pédiatriques et centres de développement enfant avec séquences, relances, scoring et discipline commerciale.</p><div className={styles.actions}><button className={styles.primary} onClick={()=>setModal('campaign')}>Créer campagne</button><button className={styles.secondary} onClick={()=>setModal('sequence')}>Créer séquence</button><button className={styles.ghost} onClick={load}>Synchroniser</button></div></div><aside className={styles.sideCard}><span className={styles.eyebrow}>Live orchestration</span><strong>{error?'Vérification requise':'Ready'}</strong><p>{error||'Campagnes, séquences et prospects synchronisés.'}</p></aside></section>
    <section className={styles.grid}><Metric label="Campagnes" value={metrics.total}/><Metric label="Running" value={metrics.running}/><Metric label="Cibles cumulées" value={metrics.target}/><Metric label="Meetings générés" value={metrics.meetings}/></section>
    <section className={styles.board}><Panel title="Campaign Control Room" subtitle="Campagnes actives, segments et conversion">{campaigns.length? <div className={styles.list}>{campaigns.map(c=><article className={styles.row} key={c.id}><div><strong>{c.name}</strong><small>{c.objective || 'Aucun objectif renseigné.'}</small><div className={styles.badges}><span>{c.segment}</span><span>{Number(c.target_count||0)} cibles</span><span>{Number(c.meeting_booked_count||0)} meetings</span></div></div><span className={styles.status}>{c.status}</span></article>)}</div>:<div className={styles.empty}>Aucune campagne. Créez une campagne hôtels ou clinique pour lancer une séquence multi-touch.</div>}</Panel><Panel title="Sequences Library" subtitle="Cadence commerciale prête à être appliquée aux prospects">{sequences.length? <div className={styles.list}>{sequences.map(seq=><article className={styles.sequence} key={seq.id}><strong>{seq.name}</strong><small>{seq.objective || seq.segment}</small><div className={styles.steps}>{(seq.steps||[]).slice(0,5).map(step=><div className={styles.step} key={step.id}><b>{step.step_order}</b><span>{step.task_title || step.channel}</span><small>J+{step.delay_days}</small></div>)}</div></article>)}</div>:<div className={styles.empty}>Aucune séquence active. Créez une cadence email + call + WhatsApp + follow-up.</div>}</Panel></section>
    {modal==='campaign'&&<Modal title="Créer une campagne B2B" onClose={()=>setModal(null)} onSubmit={createCampaign} busy={busy}><div className={styles.formGrid}><label>Nom campagne<input className={styles.input} value={campaignForm.name} onChange={e=>setCampaignForm({...campaignForm,name:e.target.value})}/></label><label>Segment<select className={styles.select} value={campaignForm.segment} onChange={e=>setCampaignForm({...campaignForm,segment:e.target.value})}><option value="hospitality">Hôtels & Resorts</option><option value="pediatric_health">Cliniques pédiatriques</option><option value="education_childcare">Éducation & enfance</option><option value="all">Tous</option></select></label><label>Statut<select className={styles.select} value={campaignForm.status} onChange={e=>setCampaignForm({...campaignForm,status:e.target.value})}><option>Draft</option><option>Scheduled</option><option>Running</option><option>Paused</option></select></label><label>Nombre cible<input className={styles.input} value={campaignForm.target_count} onChange={e=>setCampaignForm({...campaignForm,target_count:e.target.value})}/></label><label>Date début<input type="datetime-local" className={styles.input} value={campaignForm.start_at} onChange={e=>setCampaignForm({...campaignForm,start_at:e.target.value})}/></label><label>Date fin<input type="datetime-local" className={styles.input} value={campaignForm.end_at} onChange={e=>setCampaignForm({...campaignForm,end_at:e.target.value})}/></label><label className={styles.full}>Objectif stratégique<textarea className={styles.textarea} value={campaignForm.objective} onChange={e=>setCampaignForm({...campaignForm,objective:e.target.value})}/></label><label className={styles.full}>Notes internes<textarea className={styles.textarea} value={campaignForm.notes} onChange={e=>setCampaignForm({...campaignForm,notes:e.target.value})}/></label></div></Modal>}
    {modal==='sequence'&&<Modal title="Créer une séquence de prospection" onClose={()=>setModal(null)} onSubmit={createSequence} busy={busy}><div className={styles.formGrid}><label>Nom séquence<input className={styles.input} value={sequenceForm.name} onChange={e=>setSequenceForm({...sequenceForm,name:e.target.value})}/></label><label>Segment<select className={styles.select} value={sequenceForm.segment} onChange={e=>setSequenceForm({...sequenceForm,segment:e.target.value})}><option value="hospitality">Hôtels & Resorts</option><option value="pediatric_health">Cliniques pédiatriques</option><option value="all">Tous</option></select></label><label className={styles.full}>Objectif<textarea className={styles.textarea} value={sequenceForm.objective} onChange={e=>setSequenceForm({...sequenceForm,objective:e.target.value})}/></label><label className={styles.full}>Étapes, une par ligne<textarea className={styles.textarea} value={sequenceForm.steps} onChange={e=>setSequenceForm({...sequenceForm,steps:e.target.value})}/></label></div></Modal>}
  </main>
}
function Metric({label,value}:{label:string;value:number}){return <article className={styles.metric}><span>{label}</span><strong>{value}</strong></article>}
function Panel({title,subtitle,children}:{title:string;subtitle:string;children:React.ReactNode}){return <section className={styles.panel}><div className={styles.panelHead}><div><h3>{title}</h3><p>{subtitle}</p></div></div>{children}</section>}
function Modal({title,onClose,onSubmit,busy,children}:{title:string;onClose:()=>void;onSubmit:()=>void;busy:boolean;children:React.ReactNode}){return <div className={styles.modalBackdrop}><section className={styles.modal}><header className={styles.modalHeader}><div><span className={styles.eyebrow}>Large corporate modal</span><h2>{title}</h2></div><button className={styles.close} onClick={onClose}>×</button></header><div className={styles.modalBody}>{children}</div><footer className={styles.modalFooter}><button className={styles.secondary} onClick={onClose}>Annuler</button><button className={styles.primary} onClick={onSubmit} disabled={busy}>{busy?'Enregistrement...':'Enregistrer'}</button></footer></section></div>}
