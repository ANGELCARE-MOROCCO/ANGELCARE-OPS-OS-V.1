        .filter((item) => item.status === 'rejected')
        .map((item: any) => item.reason?.message)
        .filter(Boolean)

      if (failures.length) setError(failures.join(' · '))
    } catch (e) {
      setError(e instanceof Error ? e.message : 'Unable to sync proposals workspace.')
    } finally {
      setLoading(false)
    }
