                      Status
                      <select value={form.status || 'draft'} onChange={(e) => setForm({ ...form, status: e.target.value })}>
                        <option value="draft">Draft</option>
                        <option value="sent">Sent</option>
                        <option value="pending_review">Pending review</option>
                        <option value="negotiation">Negotiation</option>
                        <option value="accepted">Accepted</option>
                        <option value="signed">Signed</option>
                        <option value="lost">Lost</option>
                      </select>
                    </label>

                    <label>
                      Estimated value
                      <input value={form.estimated_value || ''} onChange={(e) => setForm({ ...form, estimated_value: e.target.value })} placeholder="MAD / monthly / annual potential" />
                    </label>

                    <label>
                      Commercial owner
                      <input value={form.commercial_owner || ''} onChange={(e) => setForm({ ...form, commercial_owner: e.target.value })} />
                    </label>

                    <label>
                      Validity date
                      <input type="date" value={form.validity_date || ''} onChange={(e) => setForm({ ...form, validity_date: e.target.value })} />
                    </label>

                    <label className={styles.fullField}>
                      Objective
                      <textarea value={form.objective || ''} onChange={(e) => setForm({ ...form, objective: e.target.value })} />
                    </label>

                    <label className={styles.fullField}>
                      Commercial terms
                      <textarea value={form.commercial_terms || ''} onChange={(e) => setForm({ ...form, commercial_terms: e.target.value })} />
                    </label>

                    <label className={styles.fullField}>
                      Next action
                      <textarea value={form.next_action || ''} onChange={(e) => setForm({ ...form, next_action: e.target.value })} />
                    </label>

                    <label className={styles.fullField}>
                      Internal notes
                      <textarea value={form.notes || ''} onChange={(e) => setForm({ ...form, notes: e.target.value })} />
                    </label>
                  </div>
                )}

                <div className={styles.servicePicker}>
                  <h3>Service scope by sector</h3>
                  <p>{currentSector.label}</p>
                  <div>
                    {currentSector.services.map((service) => (
                      <button key={service} type="button" className={selectedServices.includes(service) ? styles.serviceSelected : ''} onClick={() => toggleService(service)}>
                        {service}
                      </button>
                    ))}
                  </div>
                </div>

                <div className={styles.modalActions}>
                  <button type="button" className={styles.secondaryButton} onClick={() => { setModalMode(null); setSelectedProposal(null) }}>Close</button>
                  {modalMode === 'view' && <button type="button" onClick={openEdit}>Edit proposal</button>}
                  {modalMode !== 'view' && <button type="button" disabled={loading} onClick={saveProposal}>{loading ? 'Saving…' : modalMode === 'create' ? 'Create proposal' : 'Save changes'}</button>}
                  {modalMode !== 'create' && selectedProposal?.id && <button type="button" className={styles.deleteButton} onClick={deleteProposal}>Delete</button>}
                  <button type="button" className={styles.printButton} onClick={printProposal}>Print official A4</button>
                </div>
              </div>

              <aside className={styles.a4Preview}>
                <div className={styles.a4Document}>
                  <header className={styles.a4TopHeader}>
                    <div className={styles.a4BrandBlock}>
                      <strong>ANGELCARE</strong>
                      <span>Département Partenariats B2B & Comptes Stratégiques</span>
                      <small>Services premium d'accompagnement familial, child care et solutions partenaires</small>
                    </div>

                    <div className={styles.a4RefBlock}>
                      <span>Document de proposition</span>
                      <strong>{docReference}</strong>
                      <small>{formatDate(new Date())}</small>
                    </div>
                  </header>

                  <section className={styles.a4MetaGrid}>
                    <article>
                      <span>Émetteur</span>
                      <strong>ANGELCARE</strong>
                      <p>Département B2B Partnerships<br />Direction Développement Commercial<br />Rabat / Maroc</p>
                    </article>

                    <article>
                      <span>Destinataire</span>
                      <strong>{recipientName}</strong>
                      <p>{recipientContact}<br />{recipientRole}<br />{recipientEmail}<br />{recipientPhone}<br />{recipientAddress}</p>
                    </article>

                    <article>
                      <span>Secteur partenaire</span>
                      <strong>{currentSector.label}</strong>
                      <p>{currentSector.partnerTypes.join(' · ')}</p>
                    </article>
                  </section>

                  <section className={styles.a4Cover}>
                    <span>Proposition confidentielle de partenariat</span>
                    <h1>{form.title || `Proposition de partenariat — ${currentSector.label}`}</h1>
                    <p>
                      Proposition structurée pour {recipientName}, préparée par ANGELCARE afin de créer une collaboration B2B premium,
                      opérationnelle et mesurable autour des besoins familles, clients, collaborateurs ou invités selon le contexte du partenaire.
                    </p>
                  </section>

                  <section className={styles.a4ExecutiveBox}>
                    <h2>Résumé exécutif</h2>
                    <p>
                      ANGELCARE propose à {recipientName} un partenariat à forte valeur ajoutée, conçu pour améliorer l'expérience des familles,
                      renforcer la différenciation du partenaire et mettre à disposition une solution flexible sans charge opérationnelle lourde.
                      L'approche recommandée repose sur une sélection de services adaptés au secteur {currentSector.label}, un modèle gagnant-gagnant,
                      des standards d'exécution clairs et une capacité de déploiement progressive.
                    </p>
                  </section>

                  <section>
                    <h2>1. Contexte et enjeu partenaire</h2>
                    <p>
                      Les familles, parents actifs, clients premium, patients, collaborateurs ou invités attendent aujourd'hui des solutions fiables,
                      rassurantes et simples à activer. Pour un partenaire positionné sur l'excellence, l'absence d'une réponse structurée à ces besoins
                      peut créer une friction dans l'expérience client, limiter la fidélisation et réduire la perception de service premium.
                    </p>
                    <p>
                      Dans ce contexte, ANGELCARE intervient comme partenaire spécialisé, capable de fournir un cadre professionnel et une offre adaptée
                      aux attentes du secteur: {currentSector.label}.
                    </p>
                  </section>

                  <section>
                    <h2>2. Objectif de la collaboration</h2>
                    <p>
                      {form.objective || 'Mettre en place une offre premium, flexible et mesurable permettant au partenaire de mieux servir les familles tout en créant une collaboration gagnant-gagnant durable.'}
                    </p>
                  </section>

                  <section>
                    <h2>3. Périmètre de services proposé</h2>
                    <table className={styles.a4ServiceTable}>
                      <thead>
                        <tr>
                          <th>Service</th>
                          <th>Objectif opérationnel</th>
                          <th>Valeur partenaire</th>
                        </tr>
                      </thead>
                      <tbody>
                        {selectedServices.map((service: string) => (
                          <tr key={service}>
                            <td>{service}</td>
                            <td>Répondre à un besoin famille identifié avec un cadre clair, activable et professionnel.</td>
                            <td>Renforcer l'expérience client, la différenciation et la satisfaction.</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </section>

                  <section>
                    <h2>4. Création de valeur et logique gagnant-gagnant</h2>
                    <div className={styles.a4ValueGrid}>
                      <article>
                        <strong>Pour le partenaire</strong>
                        <ul>
                          {currentSector.advantages.slice(0, 4).map((advantage) => <li key={advantage}>{advantage}</li>)}
                        </ul>
                      </article>
                      <article>
                        <strong>Pour les familles</strong>
                        <ul>
                          <li>Accès à une solution rassurante, structurée et adaptée.</li>
                          <li>Réduction de la charge mentale liée à l'organisation familiale.</li>
                          <li>Meilleure expérience globale avec le partenaire.</li>
                        </ul>
                      </article>
                      <article>
                        <strong>Pour ANGELCARE</strong>
                        <ul>
                          <li>Déploiement B2B durable auprès d'acteurs premium.</li>
                          <li>Relation commerciale mesurable et évolutive.</li>
                          <li>Création d'un standard de service différenciant.</li>
                        </ul>
                      </article>
                    </div>
                  </section>

                  <section>
                    <h2>5. Modèle opérationnel proposé</h2>
                    <ol>
                      <li><strong>Cadrage:</strong> validation du besoin, du volume potentiel, des profils familles et des contraintes du partenaire.</li>
                      <li><strong>Offre pilote:</strong> lancement contrôlé sur un périmètre limité afin de mesurer adoption, satisfaction et faisabilité.</li>
                      <li><strong>Standardisation:</strong> mise en place des procédures, supports de communication, points de contact et indicateurs.</li>
                      <li><strong>Déploiement:</strong> extension progressive selon les résultats, la saisonnalité et les objectifs commerciaux.</li>
                    </ol>
                  </section>

                  <section>
                    <h2>6. Conditions commerciales indicatives</h2>
                    <p>
                      {form.commercial_terms || 'Les modalités commerciales seront définies selon le volume, la fréquence, le niveau de service, la saisonnalité, le modèle de collaboration retenu et les standards opérationnels attendus.'}
                    </p>
                    <p>
                      Valeur estimative / potentiel: <strong>{form.estimated_value || 'À qualifier après cadrage commercial'}</strong>.
                      Validité de la proposition: <strong>{form.validity_date ? formatDate(form.validity_date) : 'À définir'}</strong>.
                    </p>
                  </section>

                  <section>
                    <h2>7. Gouvernance, suivi et indicateurs</h2>
                    <p>
                      ANGELCARE recommande un pilotage simple autour d'indicateurs concrets: demandes reçues, taux d'activation, satisfaction familles,
                      incidents évités, récurrence, feedback partenaire, revenus générés ou valeur indirecte créée.
                    </p>
                  </section>

                  <section>
                    <h2>8. Prochaines étapes recommandées</h2>
                    <p>{form.next_action || 'Valider les services prioritaires, identifier le décideur, organiser une réunion de présentation et préparer une version finale adaptée au partenaire.'}</p>
                  </section>

                  <footer className={styles.a4Footer}>
                    <div>
                      <strong>ANGELCARE · B2B Partnerships</strong>
                      <span>Proposition confidentielle · Usage réservé au destinataire indiqué</span>
                    </div>
                    <div>
                      <span>{docReference}</span>
                      <span>Page 1 / 1</span>
                    </div>
                  </footer>
                </div>
              </aside>
            </div>
          </section>
        </div>
      )}
    </main>
  )
}
