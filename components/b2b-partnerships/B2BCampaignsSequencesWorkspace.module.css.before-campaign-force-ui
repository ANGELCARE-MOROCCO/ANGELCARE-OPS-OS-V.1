.workspace { display: grid; gap: 22px; color: #0f172a; }
.hero { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(320px, .6fr); gap: 18px; padding: 28px; border-radius: 32px; background: #fff; border: 1px solid #e5e7eb; box-shadow: 0 22px 64px rgba(15,23,42,.08); }
.eyebrow { color:#64748b; font-size:11px; font-weight:900; letter-spacing:.14em; text-transform:uppercase; }
.hero h2 { margin:8px 0; font-size:42px; letter-spacing:-.055em; line-height:.95; }
.hero p { margin:0; max-width:900px; color:#64748b; line-height:1.65; }
.actions { display:flex; flex-wrap:wrap; gap:10px; margin-top:18px; }
.primary,.secondary,.ghost { min-height:44px; border-radius:15px; padding:0 16px; font-weight:900; cursor:pointer; }
.primary { color:#fff; background:#2563eb; border:0; box-shadow: 0 14px 28px rgba(37,99,235,.24); }
.secondary { color:#0f172a; background:#fff; border:1px solid #e5e7eb; }
.ghost { color:#334155; background:#f8fafc; border:1px solid #e5e7eb; }
.sideCard { padding:20px; border-radius:24px; background:linear-gradient(135deg,#f8fafc,#fff); border:1px solid #e5e7eb; }
.sideCard strong { display:block; font-size:20px; margin:6px 0; }
.grid { display:grid; grid-template-columns: repeat(4,minmax(0,1fr)); gap:14px; }
.metric { padding:18px; border-radius:22px; background:#fff; border:1px solid #e5e7eb; box-shadow:0 16px 40px rgba(15,23,42,.06); }
.metric span { color:#64748b; font-size:12px; font-weight:800; }
.metric strong { display:block; margin-top:8px; font-size:30px; letter-spacing:-.04em; }
.board { display:grid; grid-template-columns: 1fr 1fr; gap:18px; }
.panel { padding:22px; border-radius:28px; background:#fff; border:1px solid #e5e7eb; box-shadow:0 18px 54px rgba(15,23,42,.07); }
.panelHead { display:flex; justify-content:space-between; gap:16px; align-items:center; margin-bottom:16px; }
.panelHead h3 { margin:0; font-size:20px; letter-spacing:-.03em; }
.panelHead p { margin:4px 0 0; color:#64748b; font-size:13px; }
.list { display:grid; gap:11px; }
.row { display:grid; grid-template-columns: minmax(0,1fr) auto; gap:12px; padding:15px; border:1px solid #e5e7eb; border-radius:18px; background:#fbfdff; }
.row strong { display:block; font-size:14px; }
.row small { display:block; margin-top:5px; color:#64748b; line-height:1.45; }
.badges { display:flex; flex-wrap:wrap; gap:7px; margin-top:10px; }
.badges span { padding:6px 8px; border-radius:999px; background:#eff6ff; color:#1d4ed8; font-size:11px; font-weight:900; }
.status { padding:8px 10px; border-radius:999px; background:#ecfdf5; color:#047857; font-size:11px; font-weight:900; height:fit-content; }
.sequence { padding:16px; border-radius:20px; border:1px solid #e5e7eb; background:#fff; }
.steps { display:grid; gap:8px; margin-top:12px; }
.step { display:grid; grid-template-columns: 34px minmax(0,1fr) auto; gap:10px; align-items:center; padding:10px; border-radius:14px; background:#f8fafc; border:1px solid #e5e7eb; }
.step b { width:34px; height:34px; display:grid; place-items:center; border-radius:12px; background:#2563eb; color:#fff; }
.modalBackdrop { position:fixed; inset:0; z-index:80; background:rgba(15,23,42,.58); display:grid; place-items:center; padding:30px; }
.modal { width:min(1180px,96vw); max-height:92vh; overflow:auto; border-radius:34px; background:#fff; box-shadow:0 35px 100px rgba(15,23,42,.32); }
.modalHeader { display:flex; justify-content:space-between; gap:20px; padding:26px; border-bottom:1px solid #e5e7eb; }
.modalHeader h2 { margin:5px 0 0; font-size:28px; }
.close { width:44px; height:44px; border-radius:15px; border:1px solid #e5e7eb; background:#fff; cursor:pointer; font-size:22px; }
.modalBody { display:grid; gap:18px; padding:26px; }
.formGrid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:14px; }
.formGrid label, .full { display:grid; gap:7px; color:#334155; font-size:12px; font-weight:900; }
.full { grid-column:1/-1; }
.input, .textarea, .select { width:100%; border:1px solid #dbe3ee; border-radius:15px; padding:13px 14px; font:inherit; background:#fff; color:#0f172a; }
.textarea { min-height:110px; resize:vertical; }
.modalFooter { display:flex; justify-content:flex-end; gap:10px; padding:20px 26px; border-top:1px solid #e5e7eb; }
.empty { padding:28px; border-radius:24px; border:1px dashed #cbd5e1; background:#f8fafc; color:#64748b; }
@media(max-width:1100px){.hero,.board{grid-template-columns:1fr}.grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:720px){.grid,.formGrid{grid-template-columns:1fr}.hero{padding:20px}.hero h2{font-size:32px}}

