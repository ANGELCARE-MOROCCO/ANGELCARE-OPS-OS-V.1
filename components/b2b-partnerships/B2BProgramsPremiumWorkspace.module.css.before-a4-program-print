.workspace {
  display: grid;
  gap: 22px;
  padding: 24px;
  min-height: 100%;
  background:
    radial-gradient(circle at 5% 0%, rgba(37, 99, 235, .13), transparent 30%),
    radial-gradient(circle at 95% 5%, rgba(16, 185, 129, .13), transparent 30%),
    radial-gradient(circle at 70% 100%, rgba(168, 85, 247, .10), transparent 34%),
    linear-gradient(180deg, #f8fafc 0%, #eef6ff 100%);
}

.hero {
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  gap: 28px;
  align-items: flex-end;
  border-radius: 42px;
  border: 1px solid rgba(226, 232, 240, .98);
  background:
    radial-gradient(circle at 7% 0%, rgba(37, 99, 235, .16), transparent 34%),
    radial-gradient(circle at 94% 8%, rgba(16, 185, 129, .17), transparent 34%),
    linear-gradient(135deg, #ffffff 0%, #f8fbff 54%, #ecfdf5 100%);
  box-shadow: 0 36px 100px rgba(15, 23, 42, .12);
  padding: 34px;
}

.hero::after {
  content: "🧭";
  position: absolute;
  right: 34px;
  top: 30px;
  display: grid;
  place-items: center;
  width: 92px;
  height: 92px;
  border-radius: 34px;
  background: rgba(255,255,255,.84);
  border: 1px solid #bfdbfe;
  box-shadow: 0 22px 54px rgba(37, 99, 235, .16);
  font-size: 42px;
}

.eyebrow {
  display: inline-flex;
  min-height: 31px;
  align-items: center;
  padding: 0 12px;
  border-radius: 999px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  color: #1d4ed8;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.hero h1 {
  max-width: 1040px;
  margin: 14px 0 10px;
  color: #07111f;
  font-size: clamp(38px, 5vw, 76px);
  line-height: .92;
  letter-spacing: -.075em;
  font-weight: 950;
}

.hero p {
  max-width: 870px;
  margin: 0;
  color: #64748b;
  line-height: 1.65;
  font-size: 17px;
}

.heroCommand {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 10px;
  min-width: 300px;
  border-radius: 30px;
  border: 1px solid #dbeafe;
  background: rgba(255,255,255,.86);
  box-shadow: 0 24px 60px rgba(37, 99, 235, .13);
  padding: 20px;
}

.heroCommand span,
.metrics span,
.panelHeader span {
  display: block;
  color: #64748b;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.heroCommand strong {
  color: #07111f;
  font-size: 20px;
  font-weight: 950;
}

.heroCommand button,
.sectorBanner button,
.programFooter button,
.modalActions button {
  min-height: 44px;
  border-radius: 16px;
  border: 1px solid #0f172a;
  padding: 0 14px;
  font-weight: 950;
  background: linear-gradient(135deg, #07111f, #2563eb);
  color: #fff;
  box-shadow: 0 16px 34px rgba(37, 99, 235, .18);
}

.metrics {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 14px;
}

.metrics article {
  position: relative;
  overflow: hidden;
  min-height: 126px;
  border-radius: 28px;
  border: 1px solid rgba(226, 232, 240, .98);
  background: linear-gradient(135deg, #ffffff, #f8fbff);
  box-shadow: 0 22px 56px rgba(15, 23, 42, .08);
  padding: 20px;
}

.metrics article::after {
  content: "";
  position: absolute;
  right: -34px;
  top: -38px;
  width: 116px;
  height: 116px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(16,185,129,.13), rgba(37,99,235,.09));
}

.metrics div {
  position: relative;
  z-index: 1;
  display: grid;
  place-items: center;
  width: 46px;
  height: 46px;
  border-radius: 18px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  margin-bottom: 12px;
  font-size: 20px;
}

.metrics strong {
  display: block;
  margin-top: 7px;
  color: #07111f;
  font-size: 34px;
  font-weight: 950;
  letter-spacing: -.055em;
}

.metrics p {
  margin: 6px 0 0;
  color: #64748b;
}

.sectorNav,
.viewNav {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  border-radius: 26px;
  border: 1px solid #e5e7eb;
  background: rgba(255,255,255,.86);
  box-shadow: 0 18px 44px rgba(15, 23, 42, .06);
  padding: 12px;
}

.sectorNav button,
.viewNav button {
  min-height: 46px;
  border-radius: 16px;
  border: 1px solid #e5e7eb;
  background: #fff;
  color: #0f172a;
  font-weight: 950;
  padding: 0 15px;
}

.sectorNav button {
  display: inline-flex;
  gap: 9px;
  align-items: center;
}

.sectorNav strong {
  font-size: 20px;
}

.activeSector,
.activeView {
  background: linear-gradient(135deg, #07111f, #2563eb) !important;
  color: #fff !important;
  border-color: #0f172a !important;
  box-shadow: 0 14px 30px rgba(37, 99, 235, .16);
}

.sectorBanner {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: flex-end;
  border-radius: 34px;
  border: 1px solid #dbeafe;
  background:
    radial-gradient(circle at 90% 0%, rgba(37,99,235,.13), transparent 34%),
    linear-gradient(135deg, #ffffff, #eff6ff);
  box-shadow: 0 26px 66px rgba(37, 99, 235, .10);
  padding: 26px;
}

.sectorBanner span {
  display: inline-flex;
  min-height: 30px;
  align-items: center;
  padding: 0 12px;
  border-radius: 999px;
  background: #ffffff;
  border: 1px solid #bfdbfe;
  color: #1d4ed8;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.sectorBanner h2 {
  margin: 12px 0 8px;
  color: #07111f;
  font-size: 46px;
  line-height: 1;
  letter-spacing: -.06em;
  font-weight: 950;
}

.sectorBanner p {
  margin: 0;
  color: #64748b;
  max-width: 780px;
  line-height: 1.55;
}

.layout {
  display: grid;
  grid-template-columns: minmax(0, 1.55fr) minmax(360px, .85fr);
  gap: 22px;
  align-items: start;
}

.programPanel,
.commandPanel {
  border-radius: 38px;
  border: 1px solid rgba(226, 232, 240, .98);
  background: linear-gradient(135deg, #ffffff, #f8fbff);
  box-shadow: 0 30px 78px rgba(15, 23, 42, .10);
  padding: 26px;
}

.commandPanel {
  position: sticky;
  top: 20px;
  background:
    radial-gradient(circle at 90% 0%, rgba(245, 158, 11, .13), transparent 34%),
    linear-gradient(135deg, #ffffff, #fffdf7);
}

.panelHeader h2 {
  margin: 13px 0 8px;
  color: #07111f;
  font-size: 34px;
  line-height: 1;
  letter-spacing: -.055em;
  font-weight: 950;
}

.panelHeader p {
  margin: 0 0 18px;
  color: #64748b;
  line-height: 1.55;
}

.programGrid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
  gap: 16px;
}

.programCard {
  cursor: pointer;
  position: relative;
  overflow: hidden;
  min-height: 330px;
  border-radius: 30px;
  border: 1px solid rgba(226, 232, 240, .98);
  background:
    radial-gradient(circle at 94% 0%, rgba(37, 99, 235, .13), transparent 36%),
    linear-gradient(135deg, #ffffff 0%, #f8fbff 100%);
  box-shadow: 0 24px 62px rgba(15, 23, 42, .085);
  padding: 22px;
  transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
}

.programCard:hover {
  transform: translateY(-5px);
  border-color: #93c5fd;
  box-shadow: 0 34px 82px rgba(37, 99, 235, .16);
}

.programCard::after {
  content: "";
  position: absolute;
  right: -42px;
  top: -44px;
  width: 150px;
  height: 150px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(16,185,129,.16), rgba(37,99,235,.10));
}

.programTop {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
  margin-bottom: 18px;
}

.programTop div {
  display: grid;
  place-items: center;
  width: 54px;
  height: 54px;
  border-radius: 21px;
  background: linear-gradient(135deg, #ecfdf5, #eff6ff);
  border: 1px solid #bbf7d0;
  font-size: 23px;
}

.programTop span {
  display: inline-flex;
  align-items: center;
  min-height: 30px;
  padding: 0 11px;
  border-radius: 999px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  color: #1d4ed8;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.programCard h3 {
  position: relative;
  z-index: 1;
  margin: 0;
  color: #07111f;
  font-size: 23px;
  font-weight: 950;
  letter-spacing: -.045em;
  line-height: 1.05;
}

.programCard p {
  position: relative;
  z-index: 1;
  margin: 8px 0 18px;
  color: #64748b;
  line-height: 1.55;
}

.chips {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 18px;
}

.chips span,
.dossierSection span {
  display: inline-flex;
  width: fit-content;
  min-height: 30px;
  align-items: center;
  padding: 0 11px;
  border-radius: 999px;
  background: #f8fafc;
  border: 1px solid #e5e7eb;
  color: #475569;
  font-size: 12px;
  font-weight: 850;
}

.programFooter {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
}

.programFooter strong {
  color: #64748b;
  font-size: 12px;
  max-width: 220px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.commandList {
  display: grid;
  gap: 12px;
}

.commandList article {
  display: grid;
  grid-template-columns: 48px 1fr;
  column-gap: 13px;
  align-items: center;
  border-radius: 23px;
  border: 1px solid #fde68a;
  background: rgba(255,255,255,.84);
  box-shadow: 0 14px 32px rgba(245, 158, 11, .07);
  padding: 14px;
}

.commandList div {
  grid-row: span 2;
  display: grid;
  place-items: center;
  width: 48px;
  height: 48px;
  border-radius: 18px;
  background: #fff7ed;
  border: 1px solid #fed7aa;
  font-size: 21px;
}

.commandList h3 {
  margin: 0;
  color: #07111f;
  font-size: 16px;
  font-weight: 950;
}

.commandList p {
  margin: 4px 0 0;
  color: #64748b;
  line-height: 1.45;
}

.modalBackdrop {
  position: fixed;
  inset: 0;
  z-index: 2147483000;
  display: grid;
  place-items: center;
  padding: 28px;
  background: radial-gradient(circle at 50% 0%, rgba(37, 99, 235, .18), transparent 34%), rgba(15, 23, 42, .58);
  backdrop-filter: blur(14px);
}

.programModal {
  width: min(1460px, 98vw);
  max-height: min(920px, 94vh);
  overflow: auto;
  border-radius: 36px;
  border: 1px solid rgba(226, 232, 240, .98);
  background:
    radial-gradient(circle at 92% 0%, rgba(37, 99, 235, .13), transparent 34%),
    radial-gradient(circle at 6% 100%, rgba(16, 185, 129, .10), transparent 34%),
    linear-gradient(180deg, #ffffff, #f8fafc);
  box-shadow: 0 46px 120px rgba(15, 23, 42, .34);
  padding: 28px;
}

.modalHeader {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  align-items: flex-start;
  padding-bottom: 22px;
  border-bottom: 1px solid #e5e7eb;
}

.modalHeader span {
  display: inline-flex;
  min-height: 30px;
  align-items: center;
  padding: 0 12px;
  border-radius: 999px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  color: #1d4ed8;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.modalHeader h2 {
  margin: 12px 0 8px;
  color: #07111f;
  font-size: clamp(32px, 4vw, 56px);
  line-height: .95;
  letter-spacing: -.06em;
  font-weight: 950;
}

.modalHeader p {
  margin: 0;
  color: #64748b;
}

.modalHeader button {
  width: 46px;
  height: 46px;
  border-radius: 18px;
  border: 1px solid #e5e7eb;
  background: #fff;
  color: #0f172a;
  font-size: 24px;
  font-weight: 900;
}

.dossierMetrics,
.dossierGrid,
.formGrid {
  display: grid;
  gap: 12px;
}

.dossierMetrics {
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-top: 18px;
}

.dossierGrid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 14px;
}

.dossierMetrics article,
.dossierGrid article,
.dossierSection {
  border-radius: 22px;
  border: 1px solid #e5e7eb;
  background: linear-gradient(135deg, #ffffff, #f8fbff);
  box-shadow: 0 14px 34px rgba(15, 23, 42, .055);
  padding: 16px;
}

.dossierMetrics span {
  color: #64748b;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.dossierMetrics strong {
  display: block;
  margin-top: 8px;
  color: #07111f;
  font-size: 18px;
  font-weight: 950;
}

.dossierGrid h3,
.dossierSection h3 {
  margin: 0 0 10px;
  color: #07111f;
  font-size: 18px;
  font-weight: 950;
}

.dossierGrid p {
  margin: 0;
  color: #64748b;
  line-height: 1.6;
}

.dossierSection {
  margin-top: 14px;
}

.dossierSection div {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.formGrid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18px;
}

.formGrid label {
  display: grid;
  gap: 8px;
  color: #334155;
  font-size: 12px;
  font-weight: 950;
}

.formGrid input,
.formGrid select,
.formGrid textarea {
  width: 100%;
  min-height: 48px;
  border-radius: 17px;
  border: 1px solid #e2e8f0;
  background: #ffffff;
  color: #0f172a;
  font-weight: 850;
  padding: 0 14px;
  outline: none;
}

.formGrid textarea {
  min-height: 112px;
  padding: 14px;
  resize: vertical;
  line-height: 1.55;
}

.fullField {
  grid-column: 1 / -1;
}

.modalActions {
  display: flex;
  justify-content: flex-end;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 22px;
  padding-top: 18px;
  border-top: 1px solid #e5e7eb;
}

.secondaryButton {
  background: #ffffff !important;
  color: #0f172a !important;
  border: 1px solid #e5e7eb !important;
  box-shadow: 0 10px 24px rgba(15, 23, 42, .06) !important;
}

.deleteButton {
  background: linear-gradient(135deg, #991b1b, #ef4444) !important;
  border-color: #991b1b !important;
}

@media (max-width: 1300px) {
  .metrics {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .layout {
    grid-template-columns: 1fr;
  }

  .commandPanel {
    position: relative;
    top: auto;
  }
}

@media (max-width: 900px) {
  .hero,
  .sectorBanner {
    display: grid;
  }

  .hero::after {
    display: none;
  }

  .metrics,
  .dossierMetrics,
  .dossierGrid,
  .formGrid {
    grid-template-columns: 1fr;
  }
}
