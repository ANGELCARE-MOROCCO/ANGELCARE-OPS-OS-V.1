.workspace {
  display: grid;
  gap: 22px;
  padding: 24px;
  min-height: 100%;
  background:
    radial-gradient(circle at 6% 0%, rgba(37, 99, 235, .13), transparent 30%),
    radial-gradient(circle at 96% 4%, rgba(16, 185, 129, .13), transparent 30%),
    radial-gradient(circle at 70% 100%, rgba(245, 158, 11, .08), transparent 34%),
    linear-gradient(180deg, #f8fafc 0%, #edf5f8 100%);
}

.hero {
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  gap: 28px;
  align-items: flex-end;
  border-radius: 42px;
  border: 1px solid rgba(226, 232, 240, .98);
  background:
    radial-gradient(circle at 7% 0%, rgba(37, 99, 235, .16), transparent 34%),
    radial-gradient(circle at 94% 8%, rgba(16, 185, 129, .17), transparent 34%),
    linear-gradient(135deg, #ffffff 0%, #f8fbff 54%, #ecfdf5 100%);
  box-shadow: 0 36px 100px rgba(15, 23, 42, .12);
  padding: 34px;
}

.hero::after {
  content: "📊";
  position: absolute;
  right: 34px;
  top: 30px;
  display: grid;
  place-items: center;
  width: 92px;
  height: 92px;
  border-radius: 34px;
  background: rgba(255,255,255,.84);
  border: 1px solid #bbf7d0;
  font-size: 42px;
}

.eyebrow {
  display: inline-flex;
  min-height: 31px;
  align-items: center;
  padding: 0 12px;
  border-radius: 999px;
  background: #ecfdf5;
  border: 1px solid #bbf7d0;
  color: #047857;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.hero h1 {
  max-width: 1100px;
  margin: 14px 0 10px;
  color: #07111f;
  font-size: clamp(38px, 5vw, 76px);
  line-height: .92;
  letter-spacing: -.075em;
  font-weight: 950;
}

.hero p {
  max-width: 900px;
  margin: 0;
  color: #64748b;
  line-height: 1.65;
  font-size: 17px;
}

.heroCommand {
  position: relative;
  z-index: 1;
  display: grid;
  gap: 10px;
  min-width: 300px;
  border-radius: 30px;
  border: 1px solid #bbf7d0;
  background: rgba(255,255,255,.86);
  box-shadow: 0 24px 60px rgba(16, 185, 129, .13);
  padding: 20px;
}

.heroCommand span,
.metrics span,
.panelHeader span {
  display: block;
  color: #64748b;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.heroCommand strong {
  color: #07111f;
  font-size: 20px;
  font-weight: 950;
}

.heroCommand button,
.builderBar button,
.reportFooter button,
.modalActions button,
.templateGrid button {
  min-height: 44px;
  border-radius: 16px;
  border: 1px solid #0f172a;
  padding: 0 14px;
  font-weight: 950;
  background: linear-gradient(135deg, #07111f, #059669);
  color: #fff;
  box-shadow: 0 16px 34px rgba(16, 185, 129, .18);
}

.createButton {
  background: linear-gradient(135deg, #2563eb, #059669) !important;
}

.warning {
  border-radius: 24px;
  border: 1px solid #fed7aa;
  background: #fff7ed;
  color: #9a3412;
  padding: 18px 20px;
}

.warning p { margin: 6px 0 0; }

.metrics {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 14px;
}

.metrics article {
  position: relative;
  overflow: hidden;
  min-height: 126px;
  border-radius: 28px;
  border: 1px solid rgba(226, 232, 240, .98);
  background: linear-gradient(135deg, #ffffff, #f8fbff);
  box-shadow: 0 22px 56px rgba(15, 23, 42, .08);
  padding: 20px;
}

.metrics article::after {
  content: "";
  position: absolute;
  right: -34px;
  top: -38px;
  width: 116px;
  height: 116px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(16,185,129,.13), rgba(37,99,235,.09));
}

.metrics div {
  position: relative;
  z-index: 1;
  display: grid;
  place-items: center;
  width: 46px;
  height: 46px;
  border-radius: 18px;
  background: #ecfdf5;
  border: 1px solid #bbf7d0;
  margin-bottom: 12px;
  font-size: 20px;
}

.metrics strong {
  display: block;
  margin-top: 7px;
  color: #07111f;
  font-size: 34px;
  font-weight: 950;
  letter-spacing: -.055em;
}

.metrics p {
  margin: 6px 0 0;
  color: #64748b;
}

.navbar,
.sectorNav {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  border-radius: 26px;
  border: 1px solid #e5e7eb;
  background: rgba(255,255,255,.86);
  box-shadow: 0 18px 44px rgba(15, 23, 42, .06);
  padding: 12px;
}

.navbar button,
.sectorNav button {
  min-height: 46px;
  border-radius: 16px;
  border: 1px solid #e5e7eb;
  background: #fff;
  color: #0f172a;
  font-weight: 950;
  padding: 0 15px;
}

.sectorNav button {
  display: inline-flex;
  gap: 9px;
  align-items: center;
}

.activeSector,
.activeView {
  background: linear-gradient(135deg, #07111f, #059669) !important;
  color: #fff !important;
  border-color: #0f172a !important;
}

.builderBar {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: flex-end;
  border-radius: 34px;
  border: 1px solid #bbf7d0;
  background: linear-gradient(135deg, #ffffff, #ecfdf5);
  box-shadow: 0 26px 66px rgba(16, 185, 129, .10);
  padding: 26px;
}

.builderBar span {
  display: inline-flex;
  min-height: 30px;
  align-items: center;
  padding: 0 12px;
  border-radius: 999px;
  background: #ffffff;
  border: 1px solid #bbf7d0;
  color: #047857;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.builderBar h2 {
  margin: 12px 0 8px;
  color: #07111f;
  font-size: 42px;
  line-height: 1;
  letter-spacing: -.06em;
  font-weight: 950;
}

.builderBar p {
  margin: 0;
  color: #64748b;
  max-width: 760px;
  line-height: 1.55;
}

.builderBar > div:last-child {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}

.builderBar select {
  min-height: 44px;
  border-radius: 16px;
  border: 1px solid #e5e7eb;
  background: #fff;
  color: #0f172a;
  font-weight: 900;
  padding: 0 12px;
}

.layout {
  display: grid;
  grid-template-columns: minmax(0, 1.55fr) minmax(360px, .85fr);
  gap: 22px;
  align-items: start;
}

.reportPanel,
.commandPanel,
.controllerPanel {
  border-radius: 38px;
  border: 1px solid rgba(226, 232, 240, .98);
  background: linear-gradient(135deg, #ffffff, #f8fbff);
  box-shadow: 0 30px 78px rgba(15, 23, 42, .10);
  padding: 26px;
}

.commandPanel {
  position: sticky;
  top: 20px;
  background: linear-gradient(135deg, #ffffff, #fffdf7);
}

.panelHeader h2 {
  margin: 13px 0 8px;
  color: #07111f;
  font-size: 34px;
  line-height: 1;
  letter-spacing: -.055em;
  font-weight: 950;
}

.panelHeader p {
  margin: 0 0 18px;
  color: #64748b;
  line-height: 1.55;
}

.reportGrid,
.templateGrid,
.controllerGrid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
  gap: 16px;
}

.reportCard,
.templateGrid article,
.controllerGrid article {
  cursor: pointer;
  position: relative;
  overflow: hidden;
  min-height: 315px;
  border-radius: 30px;
  border: 1px solid rgba(226, 232, 240, .98);
  background: linear-gradient(135deg, #ffffff, #f8fbff);
  box-shadow: 0 24px 62px rgba(15, 23, 42, .085);
  padding: 22px;
}

.reportCard::after,
.templateGrid article::after {
  content: "";
  position: absolute;
  right: -42px;
  top: -44px;
  width: 150px;
  height: 150px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(16,185,129,.16), rgba(37,99,235,.10));
}

.reportTop {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
  margin-bottom: 18px;
}

.reportTop div,
.templateGrid article > div {
  display: grid;
  place-items: center;
  width: 54px;
  height: 54px;
  border-radius: 21px;
  background: linear-gradient(135deg, #ecfdf5, #eff6ff);
  border: 1px solid #bbf7d0;
  font-size: 23px;
}

.reportTop span {
  display: inline-flex;
  align-items: center;
  min-height: 30px;
  padding: 0 11px;
  border-radius: 999px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  color: #1d4ed8;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .08em;
  text-transform: uppercase;
}

.reportCard h3,
.templateGrid h3,
.controllerGrid h3 {
  position: relative;
  z-index: 1;
  margin: 0;
  color: #07111f;
  font-size: 23px;
  font-weight: 950;
  letter-spacing: -.045em;
  line-height: 1.05;
}

.reportCard p,
.templateGrid p,
.controllerGrid p {
  position: relative;
  z-index: 1;
  margin: 8px 0 18px;
  color: #64748b;
  line-height: 1.55;
}

.chips {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 18px;
}

.chips span,
.templateGrid span {
  display: inline-flex;
  width: fit-content;
  min-height: 30px;
  align-items: center;
  padding: 0 11px;
  border-radius: 999px;
  background: #f8fafc;
  border: 1px solid #e5e7eb;
  color: #475569;
  font-size: 12px;
  font-weight: 850;
}

.reportFooter {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: space-between;
  gap: 12px;
  align-items: center;
}

.reportFooter strong {
  color: #64748b;
  font-size: 12px;
}

.commandList {
  display: grid;
  gap: 12px;
}

.commandList article {
  display: grid;
  grid-template-columns: 48px 1fr;
  column-gap: 13px;
  align-items: center;
  border-radius: 23px;
  border: 1px solid #fde68a;
  background: rgba(255,255,255,.84);
  padding: 14px;
}

.commandList div {
  grid-row: span 2;
  display: grid;
  place-items: center;
  width: 48px;
  height: 48px;
  border-radius: 18px;
  background: #fff7ed;
  border: 1px solid #fed7aa;
}

.commandList h3 {
  margin: 0;
  color: #07111f;
  font-size: 16px;
  font-weight: 950;
}

.commandList p {
  margin: 4px 0 0;
  color: #64748b;
  line-height: 1.45;
}

.emptyState {
  border-radius: 30px;
  border: 1px dashed #cbd5e1;
  background: #ffffff;
  padding: 28px;
  min-height: 230px;
}

.emptyState div {
  display: grid;
  place-items: center;
  width: 54px;
  height: 54px;
  border-radius: 22px;
  background: #ecfdf5;
  border: 1px solid #bbf7d0;
  font-size: 24px;
  margin-bottom: 14px;
}

.emptyState h3 { margin: 0 0 8px; color: #07111f; font-size: 22px; font-weight: 950; }
.emptyState p { margin: 0; color: #64748b; line-height: 1.6; }

.modalBackdrop {
  position: fixed;
  inset: 0;
  z-index: 2147483000;
  display: grid;
  place-items: center;
  padding: 28px;
  background: radial-gradient(circle at 50% 0%, rgba(16, 185, 129, .18), transparent 34%), rgba(15, 23, 42, .58);
  backdrop-filter: blur(14px);
}

.reportModal {
  width: min(1480px, 98vw);
  max-height: min(930px, 94vh);
  overflow: auto;
  border-radius: 36px;
  border: 1px solid rgba(226, 232, 240, .98);
  background: linear-gradient(180deg, #ffffff, #f8fafc);
  box-shadow: 0 46px 120px rgba(15, 23, 42, .34);
  padding: 28px;
}

.modalHeader {
  display: flex;
  justify-content: space-between;
  gap: 24px;
  align-items: flex-start;
  padding-bottom: 22px;
  border-bottom: 1px solid #e5e7eb;
}

.modalHeader span {
  display: inline-flex;
  min-height: 30px;
  align-items: center;
  padding: 0 12px;
  border-radius: 999px;
  background: #ecfdf5;
  border: 1px solid #bbf7d0;
  color: #047857;
  font-size: 10px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}

.modalHeader h2 {
  margin: 12px 0 8px;
  color: #07111f;
  font-size: clamp(32px, 4vw, 56px);
  line-height: .95;
  letter-spacing: -.06em;
  font-weight: 950;
}

.modalHeader p { margin: 0; color: #64748b; }

.modalHeader button {
  width: 46px;
  height: 46px;
  border-radius: 18px;
  border: 1px solid #e5e7eb;
  background: #fff;
  font-size: 24px;
  font-weight: 900;
}

.reportDetailGrid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12px;
  margin-top: 18px;
}

.dossier {
  border-radius: 22px;
  border: 1px solid #e5e7eb;
  background: linear-gradient(135deg, #ffffff, #f8fbff);
  padding: 16px;
}

.dossier h3 {
  margin: 0 0 10px;
  color: #07111f;
  font-size: 18px;
  font-weight: 950;
}

.dossier ul {
  margin: 0;
  padding-left: 18px;
}

.dossier li {
  color: #475569;
  margin-bottom: 7px;
  line-height: 1.45;
}

.alert { border-color: #fed7aa; background: #fff7ed; }
.win { border-color: #bbf7d0; background: #ecfdf5; }
.coach { border-color: #bfdbfe; background: #eff6ff; }
.revenue { border-color: #ddd6fe; background: #f5f3ff; }

.reportA4Preview {
  margin-top: 18px;
  border-radius: 28px;
  border: 1px solid #e5e7eb;
  background: #f8fafc;
  box-shadow: 0 18px 44px rgba(15, 23, 42, .08);
  padding: 18px;
  overflow: auto;
}

.reportA4Document {
  width: 100%;
  max-width: 794px;
  min-height: 1123px;
  margin: 0 auto;
  background: #ffffff;
  color: #111827;
  box-shadow: 0 28px 72px rgba(15, 23, 42, .16);
  border: 1px solid #d1d5db;
  padding: 42px 46px;
  font-family: Calibri, Arial, Helvetica, sans-serif;
}

.a4Header {
  display: grid;
  grid-template-columns: 1fr 230px;
  gap: 24px;
  border-bottom: 3px solid #111827;
  padding-bottom: 18px;
  margin-bottom: 18px;
}

.a4Brand strong {
  display: block;
  color: #111827;
  font-size: 30px;
  line-height: 1;
  letter-spacing: .16em;
  font-weight: 900;
}

.a4Brand span { display: block; margin-top: 8px; color: #1f2937; font-size: 13px; font-weight: 800; }
.a4Brand small, .a4Ref small { display: block; margin-top: 4px; color: #6b7280; font-size: 11px; line-height: 1.4; }

.a4Ref {
  border-left: 4px solid #111827;
  padding-left: 14px;
}

.a4Ref span,
.a4MetaGrid span {
  display: block;
  color: #6b7280;
  font-size: 9.5px;
  font-weight: 900;
  letter-spacing: .12em;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.a4Ref strong { display: block; margin-top: 6px; color: #111827; font-size: 13px; line-height: 1.25; }

.a4TitleBlock {
  padding: 14px 0 18px;
  border-bottom: 1px solid #d1d5db;
  margin-bottom: 16px;
}

.a4TitleBlock span {
  display: inline-flex;
  align-items: center;
  min-height: 24px;
  padding: 0 9px;
  background: #111827;
  color: #ffffff;
  font-size: 9.5px;
  font-weight: 900;
  letter-spacing: .12em;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.a4TitleBlock h1 {
  color: #111827;
  font-size: 32px;
  line-height: 1.02;
  letter-spacing: -.035em;
  font-weight: 900;
  margin: 0 0 10px;
}

.a4TitleBlock p {
  color: #374151;
  font-size: 13px;
  line-height: 1.58;
  margin: 0;
}

.a4MetaGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin: 12px 0 14px;
}

.a4MetaGrid article {
  border: 1px solid #d1d5db;
  background: #f9fafb;
  padding: 10px;
  min-height: 74px;
}

.a4MetaGrid strong { display: block; color: #111827; font-size: 13px; font-weight: 900; }

.a4Executive {
  border-left: 5px solid #111827;
  background: #f3f4f6;
  padding: 12px 14px;
  margin: 12px 0;
}

.a4Executive h2,
.a4Section h2 {
  margin: 0 0 6px;
  color: #111827;
  font-size: 14px;
  font-weight: 900;
}

.a4Executive p,
.a4Section li {
  color: #374151;
  font-size: 11.2px;
  line-height: 1.45;
}

.a4Executive p { margin: 0; }

.a4TwoCol {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 9px;
  margin-top: 9px;
}

.a4ThreeCol {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 9px;
  margin-top: 9px;
}

.a4Section {
  border: 1px solid #d1d5db;
  background: #ffffff;
  padding: 10px;
  break-inside: avoid;
}

.a4Section ul,
.a4Section ol {
  margin: 5px 0 0;
  padding-left: 17px;
}

.a4Section li { margin-bottom: 3px; }

.a4Footer {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: flex-end;
  border-top: 3px solid #111827;
  padding-top: 12px;
  margin-top: 14px;
}

.a4Footer strong { display: block; color: #111827; font-size: 12px; font-weight: 900; }
.a4Footer span { display: block; color: #6b7280; font-size: 9.5px; line-height: 1.35; }
.a4Footer > div:last-child { text-align: right; }

.modalActions {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  flex-wrap: wrap;
  margin-top: 22px;
  padding-top: 18px;
  border-top: 1px solid #e5e7eb;
}

.secondaryButton {
  background: #ffffff !important;
  color: #0f172a !important;
  border: 1px solid #e5e7eb !important;
}

.printButton {
  background: linear-gradient(135deg, #0f172a, #047857) !important;
}

.deleteButton {
  background: linear-gradient(135deg, #991b1b, #ef4444) !important;
  border-color: #991b1b !important;
}

@media (max-width: 1300px) {
  .metrics { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  .layout { grid-template-columns: 1fr; }
  .commandPanel { position: relative; top: auto; }
}

@media (max-width: 900px) {
  .hero, .builderBar { display: grid; }
  .hero::after { display: none; }
  .metrics, .reportDetailGrid, .a4MetaGrid, .a4TwoCol, .a4ThreeCol { grid-template-columns: 1fr; }
}
