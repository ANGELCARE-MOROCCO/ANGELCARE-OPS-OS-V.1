/* ============================================================
   ANGELCARE B2B — PROSPECT DIRECTORY UI UPGRADE V1
   UI-only visual enhancement. No backend / logic changes.
   ============================================================ */

.workspace,
.page,
.crmWorkspace,
.prospectWorkspace {
  background:
    radial-gradient(circle at 8% 6%, rgba(37, 99, 235, 0.10), transparent 28%),
    radial-gradient(circle at 94% 10%, rgba(16, 185, 129, 0.10), transparent 26%),
    linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);
}

.hero,
.header,
.commandHero,
.crmHero,
.directoryHero {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(226, 232, 240, 0.95) !important;
  background:
    radial-gradient(circle at 86% 16%, rgba(37, 99, 235, 0.16), transparent 28%),
    radial-gradient(circle at 16% 84%, rgba(245, 158, 11, 0.12), transparent 30%),
    linear-gradient(135deg, #ffffff 0%, #f8fbff 55%, #f5f9ff 100%) !important;
  box-shadow: 0 28px 80px rgba(15, 23, 42, 0.10) !important;
}

.hero::before,
.header::before,
.commandHero::before,
.crmHero::before,
.directoryHero::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(15, 23, 42, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(15, 23, 42, 0.035) 1px, transparent 1px);
  background-size: 28px 28px;
  mask-image: linear-gradient(90deg, rgba(0,0,0,.7), transparent 70%);
}

.hero::after,
.header::after,
.commandHero::after,
.crmHero::after,
.directoryHero::after {
  content: "🏢";
  position: absolute;
  right: 34px;
  bottom: 24px;
  display: grid;
  place-items: center;
  width: 92px;
  height: 92px;
  border-radius: 30px;
  background:
    linear-gradient(135deg, rgba(37, 99, 235, 0.12), rgba(16, 185, 129, 0.12)),
    #ffffff;
  border: 1px solid rgba(226, 232, 240, 0.9);
  box-shadow: 0 24px 54px rgba(37, 99, 235, 0.16);
  font-size: 42px;
}

.eyebrow,
.kicker,
.badge,
.heroBadge {
  background: linear-gradient(135deg, #eff6ff, #ecfeff) !important;
  color: #2563eb !important;
  border: 1px solid #bfdbfe !important;
  box-shadow: 0 10px 24px rgba(37, 99, 235, 0.08);
}

.hero h1,
.header h1,
.commandHero h1,
.crmHero h1,
.directoryHero h1 {
  max-width: 920px;
  color: #07111f !important;
  letter-spacing: -0.065em !important;
  text-shadow: 0 1px 0 rgba(255, 255, 255, 0.7);
}

.hero p,
.header p,
.commandHero p,
.crmHero p,
.directoryHero p {
  max-width: 840px;
  color: #64748b !important;
  font-size: 15px;
  line-height: 1.7;
}

/* KPI cards / metric cards */
.metricCard,
.statCard,
.kpiCard,
.summaryCard,
.scoreCard {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(226, 232, 240, 0.95) !important;
  background: rgba(255, 255, 255, 0.92) !important;
  box-shadow: 0 18px 46px rgba(15, 23, 42, 0.07) !important;
  transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
}

.metricCard:hover,
.statCard:hover,
.kpiCard:hover,
.summaryCard:hover,
.scoreCard:hover {
  transform: translateY(-3px);
  border-color: rgba(147, 197, 253, 0.95) !important;
  box-shadow: 0 26px 58px rgba(37, 99, 235, 0.12) !important;
}

.metricCard::after,
.statCard::after,
.kpiCard::after,
.summaryCard::after,
.scoreCard::after {
  content: "";
  position: absolute;
  top: -38px;
  right: -34px;
  width: 112px;
  height: 112px;
  border-radius: 999px;
  background: linear-gradient(135deg, rgba(37, 99, 235, 0.12), rgba(16, 185, 129, 0.10));
}

.metricCard:nth-of-type(2n)::after,
.statCard:nth-of-type(2n)::after,
.kpiCard:nth-of-type(2n)::after,
.summaryCard:nth-of-type(2n)::after {
  background: linear-gradient(135deg, rgba(245, 158, 11, 0.14), rgba(251, 191, 36, 0.08));
}

.metricCard:nth-of-type(3n)::after,
.statCard:nth-of-type(3n)::after,
.kpiCard:nth-of-type(3n)::after,
.summaryCard:nth-of-type(3n)::after {
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.13), rgba(59, 130, 246, 0.08));
}

/* Tabs / category cards */
.tab,
.segmentCard,
.filterCard,
.categoryCard,
.pipelineCard {
  border: 1px solid rgba(226, 232, 240, 0.95) !important;
  background:
    linear-gradient(135deg, rgba(255,255,255,.96), rgba(248,250,252,.92)) !important;
  box-shadow: 0 14px 34px rgba(15, 23, 42, 0.055) !important;
  transition: 0.18s ease;
}

.tab:hover,
.segmentCard:hover,
.filterCard:hover,
.categoryCard:hover,
.pipelineCard:hover {
  transform: translateY(-2px);
  border-color: #bfdbfe !important;
  box-shadow: 0 20px 44px rgba(37, 99, 235, 0.10) !important;
}

/* Main directory panel */
.panel,
.tablePanel,
.directoryPanel,
.crmPanel,
.sectionCard {
  border: 1px solid rgba(226, 232, 240, 0.95) !important;
  background:
    linear-gradient(180deg, rgba(255,255,255,.98), rgba(248,250,252,.92)) !important;
  box-shadow: 0 24px 60px rgba(15, 23, 42, 0.075) !important;
}

/* Search/filter bar */
.filters,
.toolbar,
.searchBar,
.directoryToolbar {
  border: 1px solid rgba(226, 232, 240, 0.95) !important;
  background: rgba(255,255,255,.86) !important;
  backdrop-filter: blur(18px);
  box-shadow: 0 16px 38px rgba(15, 23, 42, 0.05);
}

.filters input,
.toolbar input,
.searchBar input,
.directoryToolbar input,
.filters select,
.toolbar select,
.searchBar select,
.directoryToolbar select {
  background: #ffffff !important;
  border: 1px solid #e2e8f0 !important;
  box-shadow: inset 0 1px 0 rgba(15, 23, 42, 0.02);
}

.filters input:focus,
.toolbar input:focus,
.searchBar input:focus,
.directoryToolbar input:focus,
.filters select:focus,
.toolbar select:focus,
.searchBar select:focus,
.directoryToolbar select:focus {
  outline: none !important;
  border-color: #93c5fd !important;
  box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.10) !important;
}

/* Tables */
.tableWrap,
.tableContainer,
.directoryTable {
  border-radius: 24px !important;
  overflow: hidden;
  border: 1px solid #e5e7eb !important;
  background: #ffffff !important;
  box-shadow: 0 18px 48px rgba(15, 23, 42, 0.055);
}

.tableWrap :global(table),
.tableContainer :global(table),
.directoryTable :global(table) {
  border-collapse: separate !important;
  border-spacing: 0 !important;
}

.tableWrap :global(thead),
.tableContainer :global(thead),
.directoryTable :global(thead) {
  background:
    linear-gradient(135deg, #f8fafc 0%, #eef6ff 100%) !important;
}

.tableWrap :global(th),
.tableContainer :global(th),
.directoryTable :global(th) {
  color: #64748b !important;
  font-size: 11px !important;
  letter-spacing: .11em !important;
  text-transform: uppercase !important;
  font-weight: 950 !important;
}

.tableWrap :global(td),
.tableContainer :global(td),
.directoryTable :global(td) {
  border-top: 1px solid #eef2f7 !important;
}

.tableWrap :global(tbody tr),
.tableContainer :global(tbody tr),
.directoryTable :global(tbody tr) {
  transition: background 0.16s ease, transform 0.16s ease;
}

.tableWrap :global(tbody tr:hover),
.tableContainer :global(tbody tr:hover),
.directoryTable :global(tbody tr:hover) {
  background: linear-gradient(90deg, rgba(37, 99, 235, 0.045), rgba(16, 185, 129, 0.035)) !important;
}

/* Pills / tags */
.status,
.priority,
.tag,
.pill,
.badgeSoft,
.statusPill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  min-height: 26px;
  padding: 0 10px;
  border-radius: 999px;
  border: 1px solid #e5e7eb;
  background: #f8fafc;
  color: #334155;
  font-size: 11px;
  font-weight: 900;
}

.status::before,
.priority::before,
.tag::before,
.pill::before,
.badgeSoft::before,
.statusPill::before {
  content: "";
  width: 7px;
  height: 7px;
  border-radius: 999px;
  background: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, .12);
}

/* Buttons */
.primaryButton,
.secondaryButton,
.smallButton,
.tableAction,
.actionButton,
button.smallButton,
button.tableAction {
  transition: transform .16s ease, box-shadow .16s ease, border-color .16s ease, background .16s ease !important;
}

.primaryButton,
.actionButton,
button.primaryButton {
  background: linear-gradient(135deg, #0f172a, #1e40af) !important;
  box-shadow: 0 16px 32px rgba(37, 99, 235, .20) !important;
}

.primaryButton:hover,
.actionButton:hover,
button.primaryButton:hover,
.tableAction:hover,
.smallButton:hover {
  transform: translateY(-2px);
}

.tableAction,
button.tableAction {
  background: #0f172a !important;
  color: #ffffff !important;
  border-radius: 14px !important;
  box-shadow: 0 12px 28px rgba(15, 23, 42, .16);
}

.secondaryButton,
.smallButton,
button.secondaryButton,
button.smallButton {
  background: #ffffff !important;
  border: 1px solid #e5e7eb !important;
  color: #0f172a !important;
  box-shadow: 0 10px 24px rgba(15, 23, 42, .055);
}

/* Detail drawer / modal */
.modalBackdrop {
  background:
    radial-gradient(circle at 50% 0%, rgba(37, 99, 235, .18), transparent 34%),
    rgba(15, 23, 42, .58) !important;
  backdrop-filter: blur(12px);
}

.megaModal,
.contactModal,
.detailModal {
  border: 1px solid rgba(226, 232, 240, 0.98) !important;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, .10), transparent 26%),
    linear-gradient(180deg, #ffffff, #f8fafc) !important;
  box-shadow: 0 40px 110px rgba(15, 23, 42, .30) !important;
}

.detailSection,
.formSection {
  border: 1px solid #e5e7eb !important;
  background: rgba(255,255,255,.88) !important;
  box-shadow: 0 16px 36px rgba(15, 23, 42, .055);
}

.sectionTitle h3,
.detailSection h3,
.formSection h3 {
  letter-spacing: -0.025em;
  color: #0f172a !important;
}

/* Contact cards */
.contactCard {
  position: relative;
  overflow: hidden;
  border: 1px solid #e5e7eb !important;
  background:
    linear-gradient(135deg, #ffffff, #f8fbff) !important;
  box-shadow: 0 14px 32px rgba(15, 23, 42, .055);
}

.contactCard::before {
  content: "👤";
  display: grid;
  place-items: center;
  width: 34px;
  height: 34px;
  border-radius: 13px;
  background: #eff6ff;
  border: 1px solid #bfdbfe;
  margin-bottom: 8px;
}

/* Empty states */
.emptyState,
.empty,
.noData {
  border: 1px dashed #cbd5e1 !important;
  background:
    radial-gradient(circle at center, rgba(37, 99, 235, .08), transparent 55%),
    #ffffff !important;
  color: #64748b !important;
}

/* Import/add prospect buttons at top of directory */
.toolbarActions,
.headerActions,
.heroActions {
  gap: 10px !important;
}

@media (max-width: 1100px) {
  .hero::after,
  .header::after,
  .commandHero::after,
  .crmHero::after,
  .directoryHero::after {
    display: none;
  }
}

