.workspace {
  min-height: 100vh;
  padding: 26px;
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 42%, #f5f7fb 100%);
  color: #0f172a;
}
.hero {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24px;
  padding: 32px;
  border-radius: 32px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  box-shadow: 0 24px 70px rgba(15, 23, 42, .08);
  position: relative;
  overflow: hidden;
}
.hero::after {
  content: '';
  position: absolute;
  right: -80px;
  top: -120px;
  width: 320px;
  height: 320px;
  background: radial-gradient(circle, rgba(37,99,235,.12), transparent 70%);
  border-radius: 999px;
}
.eyebrow {
  margin: 0 0 10px;
  color: #2563eb;
  font-weight: 950;
  font-size: 12px;
  letter-spacing: .12em;
  text-transform: uppercase;
}
.hero h1 {
  margin: 0;
  font-size: clamp(34px, 4vw, 56px);
  letter-spacing: -2.5px;
  line-height: .95;
  max-width: 820px;
}
.heroText {
  max-width: 820px;
  color: #64748b;
  font-size: 15px;
  line-height: 1.75;
  margin: 16px 0 0;
}
.heroActions,
.headerActions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: flex-end;
  position: relative;
  z-index: 2;
}
.primaryButton,
.secondaryButton,
.ghostButton,
.smallButton,
.tableAction {
  border: 0;
  cursor: pointer;
  border-radius: 14px;
  font-weight: 900;
  transition: .18s ease;
  white-space: nowrap;
}
.primaryButton {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: white;
  padding: 12px 16px;
  box-shadow: 0 14px 26px rgba(37,99,235,.22);
}
.primaryButton:hover,
.secondaryButton:hover,
.ghostButton:hover,
.smallButton:hover,
.tableAction:hover { transform: translateY(-1px); }
.secondaryButton {
  background: #ffffff;
  color: #0f172a;
  padding: 12px 16px;
  border: 1px solid #dbe3ef;
}
.ghostButton {
  background: #eff6ff;
  color: #1d4ed8;
  padding: 12px 16px;
  border: 1px solid #bfdbfe;
}
.smallButton {
  background: #f8fafc;
  color: #1e293b;
  padding: 9px 12px;
  border: 1px solid #e2e8f0;
  font-size: 12px;
}
.tableAction {
  background: #0f172a;
  color: white;
  padding: 9px 12px;
  font-size: 12px;
}
.errorPanel {
  display: flex;
  gap: 14px;
  align-items: center;
  justify-content: space-between;
  margin-top: 16px;
  padding: 16px 18px;
  background: #fff7ed;
  border: 1px solid #fed7aa;
  border-radius: 20px;
  color: #9a3412;
}
.errorPanel span { flex: 1; }
.errorPanel button {
  border: 0;
  border-radius: 12px;
  padding: 9px 12px;
  background: #9a3412;
  color: white;
  cursor: pointer;
}
.statsGrid {
  display: grid;
  grid-template-columns: repeat(6, minmax(0, 1fr));
  gap: 14px;
  margin-top: 18px;
}
.statCard {
  padding: 18px;
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 24px;
  box-shadow: 0 14px 34px rgba(15,23,42,.06);
}
.statCard span,
.statCard small {
  display: block;
  color: #64748b;
  font-size: 12px;
  font-weight: 800;
}
.statCard strong {
  display: block;
  margin: 8px 0 6px;
  font-size: 27px;
  letter-spacing: -1px;
}
.segmentBar {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 12px;
  margin-top: 18px;
}
.segment,
.segmentActive {
  text-align: left;
  padding: 16px;
  border-radius: 20px;
  border: 1px solid #e5e7eb;
  background: #ffffff;
  color: #0f172a;
  cursor: pointer;
  box-shadow: 0 12px 32px rgba(15,23,42,.04);
}
.segmentActive {
  border-color: #93c5fd;
  background: linear-gradient(135deg, #eff6ff, #ffffff);
  box-shadow: 0 16px 40px rgba(37,99,235,.12);
}
.segment strong,
.segmentActive strong,
.segment small,
.segmentActive small { display: block; }
.segment small,
.segmentActive small { margin-top: 5px; color: #64748b; }
.crmLayout {
  display: grid;
  grid-template-columns: minmax(0, 1.52fr) minmax(360px, .78fr);
  gap: 18px;
  margin-top: 18px;
  align-items: start;
}
.directoryPanel,
.detailPanel {
  background: #ffffff;
  border: 1px solid #e5e7eb;
  border-radius: 30px;
  box-shadow: 0 18px 50px rgba(15,23,42,.07);
  overflow: hidden;
}
.directoryPanel { padding: 20px; }
.detailPanel {
  position: sticky;
  top: 18px;
  min-height: 620px;
}
.panelHeader,
.sectionTitle,
.detailTop {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16px;
}
.panelHeader h2,
.detailTop h2 {
  margin: 0;
  font-size: 24px;
  letter-spacing: -.8px;
}
.panelHeader p,
.detailTop p {
  margin: 6px 0 0;
  color: #64748b;
  font-size: 13px;
  line-height: 1.5;
}
.filters {
  display: grid;
  grid-template-columns: 1.8fr repeat(3, .7fr);
  gap: 10px;
  padding: 14px;
  background: #f8fafc;
  border: 1px solid #e5e7eb;
  border-radius: 22px;
  margin: 18px 0;
}
.filters input,
.filters select,
.megaModal input,
.megaModal textarea,
.megaModal select,
.contactModal input,
.contactModal textarea,
.contactModal select {
  width: 100%;
  border: 1px solid #dbe3ef;
  border-radius: 14px;
  padding: 11px 12px;
  background: #ffffff;
  color: #0f172a;
  outline: none;
  font-size: 13px;
}
.megaModal textarea,
.contactModal textarea { min-height: 88px; resize: vertical; }
.tableShell {
  overflow-x: auto;
  border: 1px solid #e5e7eb;
  border-radius: 22px;
}
.table {
  width: 100%;
  border-collapse: collapse;
  min-width: 1100px;
}
.table th {
  text-align: left;
  padding: 13px 14px;
  color: #64748b;
  font-size: 11px;
  letter-spacing: .05em;
  text-transform: uppercase;
  background: #f8fafc;
  border-bottom: 1px solid #e5e7eb;
}
.table td {
  padding: 15px 14px;
  border-bottom: 1px solid #eef2f7;
  vertical-align: top;
  font-size: 13px;
}
.table tr { cursor: pointer; }
.table tr:hover { background: #f8fbff; }
.table td strong,
.table td small { display: block; }
.table td small { margin-top: 4px; color: #64748b; }
.softBadge,
.statusBadge,
.priority,
.priorityA {
  display: inline-flex;
  align-items: center;
  border-radius: 999px;
  padding: 7px 10px;
  font-size: 11px;
  font-weight: 900;
  border: 1px solid #e2e8f0;
  background: #f8fafc;
  color: #334155;
}
.statusBadge { background: #eff6ff; color: #1d4ed8; border-color: #bfdbfe; }
.priority { background: #f8fafc; }
.priorityA { background: #fef3c7; color: #92400e; border-color: #fde68a; }
.overdue { color: #dc2626; }
.emptyState,
.detailEmpty {
  padding: 50px 30px;
  text-align: center;
  border-radius: 26px;
  border: 1px dashed #cbd5e1;
  background: linear-gradient(180deg, #ffffff, #f8fafc);
}
.emptyState h3,
.detailEmpty h3 { margin: 0 0 8px; font-size: 24px; letter-spacing: -.7px; }
.emptyState p,
.detailEmpty p { color: #64748b; max-width: 640px; margin: 0 auto 18px; line-height: 1.65; }
.detailEmpty { border: 0; background: transparent; padding-top: 150px; }
.detailContent { padding: 22px; }
.scoreGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin: 18px 0;
}
.scoreGrid div {
  padding: 13px;
  border-radius: 18px;
  background: #f8fafc;
  border: 1px solid #e5e7eb;
}
.scoreGrid span,
.scoreGrid strong { display: block; }
.scoreGrid span { color: #64748b; font-size: 11px; font-weight: 850; }
.scoreGrid strong { margin-top: 5px; font-size: 18px; }
.detailSection {
  padding: 18px;
  border-radius: 22px;
  border: 1px solid #e5e7eb;
  background: #ffffff;
  margin-top: 12px;
}
.detailSection h3,
.detailSection h4 { margin: 0 0 8px; }
.detailSection h4 { margin-top: 14px; color: #334155; }
.detailSection p { color: #64748b; line-height: 1.6; margin: 0; }
.contactCard,
.timelineItem {
  display: grid;
  gap: 4px;
  padding: 12px;
  border-radius: 16px;
  background: #f8fafc;
  border: 1px solid #e5e7eb;
  margin-top: 8px;
}
.contactCard span,
.timelineItem span,
.timelineItem small { color: #64748b; font-size: 12px; }
.contactCard em {
  width: fit-content;
  border-radius: 999px;
  padding: 5px 8px;
  background: #dcfce7;
  color: #166534;
  font-style: normal;
  font-size: 11px;
  font-weight: 900;
}
.modalBackdrop {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22px;
  background: rgba(15, 23, 42, .56);
  backdrop-filter: blur(8px);
}
.megaModal,
.contactModal {
  width: min(1450px, 96vw);
  max-height: 92vh;
  overflow: auto;
  background: #ffffff;
  border-radius: 32px;
  box-shadow: 0 40px 120px rgba(0,0,0,.28);
}
.contactModal { width: min(980px, 94vw); }
.modalHeader {
  position: sticky;
  top: 0;
  z-index: 2;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  padding: 24px 28px;
  border-bottom: 1px solid #e5e7eb;
  background: rgba(255,255,255,.96);
  backdrop-filter: blur(18px);
}
.modalHeader h2 { margin: 0; font-size: 30px; letter-spacing: -1px; }
.modalHeader span { display: block; margin-top: 6px; color: #64748b; }
.modalHeader button {
  width: 42px;
  height: 42px;
  border-radius: 14px;
  border: 1px solid #e5e7eb;
  background: #f8fafc;
  cursor: pointer;
  font-size: 22px;
}
.modalGrid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14px;
  padding: 22px;
}
.modalGrid section,
.contactGrid {
  padding: 18px;
  border: 1px solid #e5e7eb;
  border-radius: 24px;
  background: #fbfdff;
}
.modalGrid h3 { margin: 0 0 14px; letter-spacing: -.4px; }
.modalGrid label,
.contactGrid label {
  display: grid;
  gap: 7px;
  margin-bottom: 12px;
  font-size: 12px;
  color: #334155;
  font-weight: 900;
}
.wide { grid-column: span 2; }
.contactGrid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12px;
  margin: 22px;
}
.checkbox {
  display: flex !important;
  align-items: center;
  gap: 10px !important;
  grid-column: 1 / -1;
}
.checkbox input { width: auto !important; }
.modalFooter {
  display: flex;
  justify-content: flex-end;
  gap: 10px;
  padding: 20px 28px 28px;
}
@media (max-width: 1200px) {
  .statsGrid { grid-template-columns: repeat(3, 1fr); }
  .crmLayout { grid-template-columns: 1fr; }
  .detailPanel { position: static; }
  .modalGrid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 760px) {
  .workspace { padding: 14px; }
  .hero,
  .panelHeader,
  .detailTop { flex-direction: column; }
  .statsGrid,
  .segmentBar,
  .filters,
  .modalGrid,
  .contactGrid { grid-template-columns: 1fr; }
  .wide { grid-column: auto; }
}

/* B2B modal must sit above ANGELCARE overhead panel / terminal / connect widgets */
.modalBackdrop {
  z-index: 2147483000 !important;
  align-items: flex-start !important;
  padding-top: 92px !important;
}

.megaModal,
.contactModal {
  position: relative;
  z-index: 2147483001 !important;
}

.contactsWide {
  grid-column: 1 / -1;
  padding: 18px;
  border: 1px solid #e5e7eb;
  border-radius: 24px;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, .08), transparent 34%),
    #fbfdff;
}

.contactsHeader {
  display: flex;
  justify-content: space-between;
  gap: 18px;
  align-items: flex-start;
  margin-bottom: 14px;
}

.contactsHeader h3 {
  margin: 0 0 5px;
}

.contactsHeader p {
  margin: 0;
  color: #64748b;
  font-size: 13px;
  line-height: 1.5;
}

.contactsManager {
  display: grid;
  gap: 14px;
}

.contactDraftCard {
  border: 1px solid #e5e7eb;
  background: #ffffff;
  border-radius: 22px;
  padding: 16px;
  box-shadow: 0 16px 34px rgba(15, 23, 42, .05);
}

.contactDraftTop {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-bottom: 14px;
}

.contactDraftTop strong {
  font-size: 14px;
  color: #0f172a;
}

.contactDraftTop div {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}

.contactDraftGrid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12px;
}

.contactDraftGrid label {
  display: grid;
  gap: 7px;
  margin: 0;
  font-size: 12px;
  color: #334155;
  font-weight: 900;
}

.contactNote {
  grid-column: span 2;
}

.miniButton,
.primaryMini,
.dangerMini {
  border: 1px solid #e5e7eb;
  border-radius: 999px;
  padding: 7px 10px;
  font-size: 11px;
  font-weight: 900;
  cursor: pointer;
  background: #ffffff;
  color: #334155;
}

.primaryMini {
  color: #1d4ed8;
  background: #eff6ff;
  border-color: #bfdbfe;
}

.dangerMini {
  color: #b91c1c;
  background: #fff1f2;
  border-color: #fecdd3;
}

@media (max-width: 1100px) {
  .contactDraftGrid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .contactNote {
    grid-column: 1 / -1;
  }
}

@media (max-width: 720px) {
  .modalBackdrop {
    padding-top: 72px !important;
  }

  .contactDraftGrid {
    grid-template-columns: 1fr;
  }

  .contactsHeader {
    flex-direction: column;
  }
}
