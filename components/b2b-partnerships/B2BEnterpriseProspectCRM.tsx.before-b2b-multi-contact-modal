'use client'

import { FormEvent, useEffect, useMemo, useState } from 'react'
import styles from './B2BEnterpriseProspectCRM.module.css'

type Prospect = {
  id: string
  name: string
  sector: string
  sub_sector?: string | null
  city?: string | null
  address?: string | null
  website?: string | null
  instagram?: string | null
  linkedin?: string | null
  google_maps_url?: string | null
  phone?: string | null
  email?: string | null
  main_contact_name?: string | null
  main_contact_role?: string | null
  decision_maker_name?: string | null
  decision_maker_role?: string | null
  decision_maker_phone?: string | null
  decision_maker_email?: string | null
  status: string
  priority_score: string
  fit_score?: number | null
  urgency_score?: number | null
  decision_power_score?: number | null
  revenue_potential_score?: number | null
  relationship_warmth?: string | null
  potential_service_fit?: string | null
  current_family_services?: string | null
  pain_points?: string | null
  opportunity_description?: string | null
  estimated_monthly_value?: number | null
  estimated_annual_value?: number | null
  assigned_owner_id?: string | null
  last_contact_at?: string | null
  next_follow_up_at?: string | null
  next_action?: string | null
  created_at?: string | null
}

type Contact = {
  id: string
  prospect_id: string
  name: string
  role?: string | null
  phone?: string | null
  email?: string | null
  linkedin?: string | null
  is_decision_maker?: boolean | null
  influence_level?: string | null
  preferred_channel?: string | null
  notes?: string | null
}

type Activity = {
  id: string
  activity_type: string
  title: string
  description?: string | null
  created_at?: string | null
}

type ProspectDetail = {
  prospect: Prospect
  contacts: Contact[]
  activities: Activity[]
  outreach?: any[]
  calls?: any[]
  meetings?: any[]
  proposals?: any[]
  tasks?: any[]
}

const sectors = [
  'Hotel', 'Resort', 'Family hotel', 'Boutique hotel', 'Event venue',
  'Pediatric clinic', 'Pediatrician', 'Child development center', 'Orthophonist',
  'Psychomotor specialist', 'Family wellness center', 'School', 'Nursery',
  'Corporate family service buyer', 'Other',
]

const statuses = [
  'New', 'Contacted', 'No Response', 'Interested', 'Meeting Booked', 'Meeting Done',
  'Proposal Sent', 'Negotiation', 'Pilot Agreed', 'Signed Partner', 'Not Fit', 'Follow Up Later', 'Lost',
]

const priorityScores = ['A', 'B', 'C']
const warmth = ['Cold', 'Warm', 'Hot']

const initialProspectForm = {
  name: '', sector: 'Hotel', sub_sector: '', city: '', address: '', website: '', instagram: '', linkedin: '', google_maps_url: '', phone: '', email: '',
  main_contact_name: '', main_contact_role: '', decision_maker_name: '', decision_maker_role: '', decision_maker_phone: '', decision_maker_email: '',
  status: 'New', priority_score: 'B', relationship_warmth: 'Cold', fit_score: '6', urgency_score: '5', decision_power_score: '5', revenue_potential_score: '6',
  potential_service_fit: '', current_family_services: '', pain_points: '', opportunity_description: '', estimated_monthly_value: '', estimated_annual_value: '',
  next_follow_up_at: '', next_action: '',
}

function money(value?: number | null) {
  return new Intl.NumberFormat('fr-MA', { style: 'currency', currency: 'MAD', maximumFractionDigits: 0 }).format(Number(value || 0))
}

function dateLabel(value?: string | null) {
  if (!value) return '—'
  const d = new Date(value)
  if (Number.isNaN(d.getTime())) return '—'
  return d.toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' })
}

function isHotelSector(sector: string) {
  return ['Hotel', 'Resort', 'Family hotel', 'Boutique hotel', 'Event venue'].includes(sector)
}

function isClinicSector(sector: string) {
  return ['Pediatric clinic', 'Pediatrician', 'Child development center', 'Orthophonist', 'Psychomotor specialist', 'Family wellness center'].includes(sector)
}

function isOverdue(value?: string | null) {
  if (!value) return false
  const d = new Date(value)
  return !Number.isNaN(d.getTime()) && d.getTime() < Date.now()
}

function cleanPayload(form: Record<string, string>) {
  const out: Record<string, any> = {}
  Object.entries(form).forEach(([key, value]) => {
    if (['fit_score', 'urgency_score', 'decision_power_score', 'revenue_potential_score'].includes(key)) {
      out[key] = value ? Number(value) : null
    } else if (['estimated_monthly_value', 'estimated_annual_value'].includes(key)) {
      out[key] = value ? Number(value) : 0
    } else {
      out[key] = value?.trim() || null
    }
  })
  out.name = form.name.trim()
  out.sector = form.sector
  out.status = form.status
  out.priority_score = form.priority_score
  out.relationship_warmth = form.relationship_warmth
  return out
}

export default function B2BEnterpriseProspectCRM() {
  const [prospects, setProspects] = useState<Prospect[]>([])
  const [selected, setSelected] = useState<ProspectDetail | null>(null)
  const [loading, setLoading] = useState(true)
  const [saving, setSaving] = useState(false)
  const [error, setError] = useState<string | null>(null)
  const [query, setQuery] = useState('')
  const [sectorFilter, setSectorFilter] = useState('All')
  const [statusFilter, setStatusFilter] = useState('All')
  const [priorityFilter, setPriorityFilter] = useState('All')
  const [viewMode, setViewMode] = useState<'all' | 'hotels' | 'clinics' | 'priority' | 'overdue'>('all')
  const [modal, setModal] = useState<'create' | 'edit' | 'contact' | 'qualification' | null>(null)
  const [form, setForm] = useState<Record<string, string>>(initialProspectForm)
  const [contactForm, setContactForm] = useState({ name: '', role: '', phone: '', email: '', linkedin: '', influence_level: 'Medium', preferred_channel: 'Email', notes: '', is_decision_maker: false })

  async function loadProspects() {
    try {
      setError(null)
      const res = await fetch('/api/b2b-partnerships/prospects', { cache: 'no-store' })
      const json = await res.json()
      if (!json.ok) throw new Error(json.error || 'Unable to load prospects')
      setProspects(json.data || [])
    } catch (e) {
      setError(e instanceof Error ? e.message : 'Unable to load prospects')
    } finally {
      setLoading(false)
    }
  }

  async function openDetail(id: string) {
    try {
      const res = await fetch(`/api/b2b-partnerships/prospects/${id}`, { cache: 'no-store' })
      const json = await res.json()
      if (!json.ok) throw new Error(json.error || 'Unable to load prospect detail')
      setSelected(json.data)
    } catch (e) {
      setError(e instanceof Error ? e.message : 'Unable to load prospect detail')
    }
  }

  useEffect(() => {
    loadProspects()
    const timer = window.setInterval(loadProspects, 30000)
    return () => window.clearInterval(timer)
  }, [])

  const filtered = useMemo(() => {
    const q = query.trim().toLowerCase()
    return prospects.filter((p) => {
      const matchesQuery = !q || [p.name, p.sector, p.city, p.email, p.phone, p.decision_maker_name, p.potential_service_fit].join(' ').toLowerCase().includes(q)
      const matchesSector = sectorFilter === 'All' || p.sector === sectorFilter
      const matchesStatus = statusFilter === 'All' || p.status === statusFilter
      const matchesPriority = priorityFilter === 'All' || p.priority_score === priorityFilter
      const matchesMode =
        viewMode === 'all' ||
        (viewMode === 'hotels' && isHotelSector(p.sector)) ||
        (viewMode === 'clinics' && isClinicSector(p.sector)) ||
        (viewMode === 'priority' && p.priority_score === 'A') ||
        (viewMode === 'overdue' && isOverdue(p.next_follow_up_at))
      return matchesQuery && matchesSector && matchesStatus && matchesPriority && matchesMode
    })
  }, [prospects, query, sectorFilter, statusFilter, priorityFilter, viewMode])

  const stats = useMemo(() => {
    const hotels = prospects.filter((p) => isHotelSector(p.sector)).length
    const clinics = prospects.filter((p) => isClinicSector(p.sector)).length
    const priorityA = prospects.filter((p) => p.priority_score === 'A').length
    const overdue = prospects.filter((p) => isOverdue(p.next_follow_up_at)).length
    const monthly = prospects.reduce((s, p) => s + Number(p.estimated_monthly_value || 0), 0)
    return { hotels, clinics, priorityA, overdue, monthly }
  }, [prospects])

  function openCreate() {
    setForm(initialProspectForm)
    setModal('create')
  }

  function openEdit() {
    if (!selected?.prospect) return
    const p = selected.prospect
    setForm({
      ...initialProspectForm,
      ...Object.fromEntries(Object.entries(p).map(([k, v]) => [k, v == null ? '' : String(v)])),
      fit_score: String(p.fit_score ?? ''), urgency_score: String(p.urgency_score ?? ''), decision_power_score: String(p.decision_power_score ?? ''), revenue_potential_score: String(p.revenue_potential_score ?? ''),
      estimated_monthly_value: String(p.estimated_monthly_value ?? ''), estimated_annual_value: String(p.estimated_annual_value ?? ''),
      next_follow_up_at: p.next_follow_up_at ? p.next_follow_up_at.slice(0, 16) : '',
    })
    setModal('edit')
  }

  async function submitProspect(e: FormEvent) {
    e.preventDefault()
    setSaving(true)
    try {
      const payload = cleanPayload(form)
      const url = modal === 'edit' && selected?.prospect ? `/api/b2b-partnerships/prospects/${selected.prospect.id}` : '/api/b2b-partnerships/prospects'
      const res = await fetch(url, { method: modal === 'edit' ? 'PATCH' : 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(payload) })
      const json = await res.json()
      if (!json.ok) throw new Error(json.error || 'Unable to save prospect')
      setModal(null)
      await loadProspects()
      if (json.data?.id) await openDetail(json.data.id)
    } catch (e) {
      setError(e instanceof Error ? e.message : 'Unable to save prospect')
    } finally {
      setSaving(false)
    }
  }

  async function submitContact(e: FormEvent) {
    e.preventDefault()
    if (!selected?.prospect) return
    setSaving(true)
    try {
      const res = await fetch('/api/b2b-partnerships/contacts', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ ...contactForm, prospect_id: selected.prospect.id }) })
      const json = await res.json()
      if (!json.ok) throw new Error(json.error || 'Unable to add contact')
      setModal(null)
      setContactForm({ name: '', role: '', phone: '', email: '', linkedin: '', influence_level: 'Medium', preferred_channel: 'Email', notes: '', is_decision_maker: false })
      await openDetail(selected.prospect.id)
    } catch (e) {
      setError(e instanceof Error ? e.message : 'Unable to add contact')
    } finally {
      setSaving(false)
    }
  }

  const selectedActivities = Array.isArray((selected as any)?.activities)
    ? (selected as any).activities
    : Array.isArray((selected as any)?.timeline)
      ? (selected as any).timeline
      : []

  const selectedContacts = Array.isArray((selected as any)?.contacts) ? (selected as any).contacts : []
  const selectedTasks = Array.isArray((selected as any)?.tasks) ? (selected as any).tasks : []
  const selectedMeetings = Array.isArray((selected as any)?.meetings) ? (selected as any).meetings : []
  const selectedOutreach = Array.isArray((selected as any)?.outreach) ? (selected as any).outreach : []
  const selectedCalls = Array.isArray((selected as any)?.calls) ? (selected as any).calls : []
  const selectedProposals = Array.isArray((selected as any)?.proposals) ? (selected as any).proposals : []

  return (
    <main className={styles.workspace}>
      <section className={styles.hero}>
        <div>
          <p className={styles.eyebrow}>ANGELCARE B2B CRM</p>
          <h1>Prospect Directory & Qualification Command</h1>
          <p className={styles.heroText}>Manage hotels, resorts, pediatric clinics, decision makers, partnership fit, revenue potential, next actions and qualification depth from one premium white-background execution workspace.</p>
        </div>
        <div className={styles.heroActions}>
          <button className={styles.primaryButton} onClick={openCreate}>Nouveau prospect</button>
          <button className={styles.secondaryButton} onClick={() => setViewMode('hotels')}>Pipeline hôtels</button>
          <button className={styles.secondaryButton} onClick={() => setViewMode('clinics')}>Pipeline cliniques</button>
          <button className={styles.ghostButton} onClick={loadProspects}>Synchroniser</button>
        </div>
      </section>

      {error && <div className={styles.errorPanel}><strong>Action required</strong><span>{error}</span><button onClick={loadProspects}>Retry sync</button></div>}

      <section className={styles.statsGrid}>
        <article className={styles.statCard}><span>Total prospects</span><strong>{prospects.length}</strong><small>CRM database</small></article>
        <article className={styles.statCard}><span>Hospitality</span><strong>{stats.hotels}</strong><small>Hotels, resorts, venues</small></article>
        <article className={styles.statCard}><span>Clinics & child health</span><strong>{stats.clinics}</strong><small>Pediatric ecosystem</small></article>
        <article className={styles.statCard}><span>Priority A</span><strong>{stats.priorityA}</strong><small>High-value opportunities</small></article>
        <article className={styles.statCard}><span>Overdue follow-ups</span><strong>{stats.overdue}</strong><small>Requires action</small></article>
        <article className={styles.statCard}><span>Monthly potential</span><strong>{money(stats.monthly)}</strong><small>Estimated pipeline value</small></article>
      </section>

      <section className={styles.segmentBar}>
        {[
          ['all', 'All prospects', 'Complete CRM view'], ['hotels', 'Hotels & resorts', 'Family hospitality accounts'], ['clinics', 'Pediatric clinics', 'Child health ecosystem'], ['priority', 'Priority A', 'Highest potential'], ['overdue', 'Overdue', 'Follow-ups at risk'],
        ].map(([key, label, sub]) => (
          <button key={key} className={viewMode === key ? styles.segmentActive : styles.segment} onClick={() => setViewMode(key as any)}><strong>{label}</strong><small>{sub}</small></button>
        ))}
      </section>

      <section className={styles.crmLayout}>
        <div className={styles.directoryPanel}>
          <div className={styles.panelHeader}>
            <div><h2>Enterprise Prospect Directory</h2><p>Filter, qualify, prioritize and open deep execution records.</p></div>
            <div className={styles.headerActions}><button className={styles.secondaryButton}>Importer CSV</button><button className={styles.primaryButton} onClick={openCreate}>Add prospect</button></div>
          </div>

          <div className={styles.filters}>
            <input value={query} onChange={(e) => setQuery(e.target.value)} placeholder="Search by name, city, decision maker, fit..." />
            <select value={sectorFilter} onChange={(e) => setSectorFilter(e.target.value)}><option>All</option>{sectors.map((s) => <option key={s}>{s}</option>)}</select>
            <select value={statusFilter} onChange={(e) => setStatusFilter(e.target.value)}><option>All</option>{statuses.map((s) => <option key={s}>{s}</option>)}</select>
            <select value={priorityFilter} onChange={(e) => setPriorityFilter(e.target.value)}><option>All</option>{priorityScores.map((s) => <option key={s}>{s}</option>)}</select>
          </div>

          {loading ? <div className={styles.emptyState}>Loading ANGELCARE B2B prospects...</div> : filtered.length === 0 ? (
            <div className={styles.emptyState}><h3>Start building the B2B pipeline</h3><p>Add the first hotel, resort, pediatric clinic, pediatrician, or child development center. Each record will carry decision-maker data, qualification scoring, next actions and commercial opportunity depth.</p><button className={styles.primaryButton} onClick={openCreate}>Create first prospect</button></div>
          ) : (
            <div className={styles.tableShell}>
              <table className={styles.table}>
                <thead><tr><th>Prospect</th><th>Sector</th><th>Decision maker</th><th>Priority</th><th>Status</th><th>Value</th><th>Next action</th><th /></tr></thead>
                <tbody>{filtered.map((p) => (
                  <tr key={p.id} onClick={() => openDetail(p.id)}>
                    <td><strong>{p.name}</strong><small>{p.city || 'City not set'} · {p.email || p.phone || 'No direct contact'}</small></td>
                    <td><span className={styles.softBadge}>{p.sector}</span></td>
                    <td><strong>{p.decision_maker_name || p.main_contact_name || '—'}</strong><small>{p.decision_maker_role || p.main_contact_role || 'Role pending'}</small></td>
                    <td><span className={p.priority_score === 'A' ? styles.priorityA : styles.priority}>{p.priority_score}</span></td>
                    <td><span className={styles.statusBadge}>{p.status}</span></td>
                    <td>{money(p.estimated_monthly_value)}</td>
                    <td className={isOverdue(p.next_follow_up_at) ? styles.overdue : ''}><strong>{p.next_action || 'Define next action'}</strong><small>{dateLabel(p.next_follow_up_at)}</small></td>
                    <td><button className={styles.tableAction}>Open</button></td>
                  </tr>
                ))}</tbody>
              </table>
            </div>
          )}
        </div>

        <aside className={styles.detailPanel}>
          {!selected ? (
            <div className={styles.detailEmpty}><h3>Select a prospect</h3><p>Open a prospect to manage qualification, contacts, decision makers, commercial fit, revenue value and timeline.</p><button className={styles.primaryButton} onClick={openCreate}>New prospect</button></div>
          ) : (
            <div className={styles.detailContent}>
              <div className={styles.detailTop}>
                <div><span className={styles.softBadge}>{selected.prospect.sector}</span><h2>{selected.prospect.name}</h2><p>{selected.prospect.city || 'City pending'} · {selected.prospect.status}</p></div>
                <button className={styles.secondaryButton} onClick={openEdit}>Edit record</button>
              </div>

              <div className={styles.scoreGrid}>
                <div><span>Fit</span><strong>{selected.prospect.fit_score ?? '—'}/10</strong></div>
                <div><span>Urgency</span><strong>{selected.prospect.urgency_score ?? '—'}/10</strong></div>
                <div><span>Decision power</span><strong>{selected.prospect.decision_power_score ?? '—'}/10</strong></div>
                <div><span>Revenue</span><strong>{selected.prospect.revenue_potential_score ?? '—'}/10</strong></div>
              </div>

              <section className={styles.detailSection}><h3>Business fit</h3><p>{selected.prospect.potential_service_fit || 'No service fit defined yet.'}</p><h4>Pain points</h4><p>{selected.prospect.pain_points || 'No pain points captured yet.'}</p></section>

              <section className={styles.detailSection}><div className={styles.sectionTitle}><h3>Decision makers & contacts</h3><button onClick={() => setModal('contact')} className={styles.smallButton}>Add contact</button></div>{selectedContacts.length === 0 ? <p>No contacts yet.</p> : selectedContacts.map((c: any) => <div key={c.id} className={styles.contactCard}><strong>{c.name}</strong><span>{c.role || 'Role pending'} · {c.email || c.phone || 'No contact channel'}</span>{c.is_decision_maker && <em>Decision maker</em>}</div>)}</section>

              <section className={styles.detailSection}><h3>Execution timeline</h3>{selectedActivities.length === 0 ? <p>No activity yet.</p> : selected.activities.slice(0, 8).map((a) => <div key={a.id} className={styles.timelineItem}><strong>{a.title}</strong><span>{a.description || a.activity_type}</span><small>{dateLabel(a.created_at)}</small></div>)}</section>
            </div>
          )}
        </aside>
      </section>

      {(modal === 'create' || modal === 'edit' || modal === 'qualification') && (
        <div className={styles.modalBackdrop} onClick={() => setModal(null)}>
          <form className={styles.megaModal} onSubmit={submitProspect} onClick={(e) => e.stopPropagation()}>
            <div className={styles.modalHeader}><div><p className={styles.eyebrow}>{modal === 'edit' ? 'Update prospect' : 'New B2B prospect'}</p><h2>{modal === 'edit' ? 'Edit enterprise prospect record' : 'Create a deep B2B partnership record'}</h2><span>Structured for hotels, resorts, pediatric clinics and child development partners.</span></div><button type="button" onClick={() => setModal(null)}>×</button></div>
            <div className={styles.modalGrid}>
              <section><h3>1. Identity & segment</h3><label>Prospect name<input required value={form.name} onChange={(e) => setForm({ ...form, name: e.target.value })} /></label><label>Sector<select value={form.sector} onChange={(e) => setForm({ ...form, sector: e.target.value })}>{sectors.map((s) => <option key={s}>{s}</option>)}</select></label><label>Sub-sector<input value={form.sub_sector} onChange={(e) => setForm({ ...form, sub_sector: e.target.value })} /></label><label>City<input value={form.city} onChange={(e) => setForm({ ...form, city: e.target.value })} /></label><label>Address<textarea value={form.address} onChange={(e) => setForm({ ...form, address: e.target.value })} /></label></section>
              <section><h3>2. Contact channels</h3><label>Phone<input value={form.phone} onChange={(e) => setForm({ ...form, phone: e.target.value })} /></label><label>Email<input value={form.email} onChange={(e) => setForm({ ...form, email: e.target.value })} /></label><label>Website<input value={form.website} onChange={(e) => setForm({ ...form, website: e.target.value })} /></label><label>LinkedIn<input value={form.linkedin} onChange={(e) => setForm({ ...form, linkedin: e.target.value })} /></label><label>Instagram<input value={form.instagram} onChange={(e) => setForm({ ...form, instagram: e.target.value })} /></label></section>
              <section><h3>3. Decision maker</h3><label>Main contact<input value={form.main_contact_name} onChange={(e) => setForm({ ...form, main_contact_name: e.target.value })} /></label><label>Main contact role<input value={form.main_contact_role} onChange={(e) => setForm({ ...form, main_contact_role: e.target.value })} /></label><label>Decision maker<input value={form.decision_maker_name} onChange={(e) => setForm({ ...form, decision_maker_name: e.target.value })} /></label><label>Decision maker role<input value={form.decision_maker_role} onChange={(e) => setForm({ ...form, decision_maker_role: e.target.value })} /></label><label>Decision maker email<input value={form.decision_maker_email} onChange={(e) => setForm({ ...form, decision_maker_email: e.target.value })} /></label></section>
              <section><h3>4. Qualification scoring</h3><label>Status<select value={form.status} onChange={(e) => setForm({ ...form, status: e.target.value })}>{statuses.map((s) => <option key={s}>{s}</option>)}</select></label><label>Priority<select value={form.priority_score} onChange={(e) => setForm({ ...form, priority_score: e.target.value })}>{priorityScores.map((s) => <option key={s}>{s}</option>)}</select></label><label>Relationship warmth<select value={form.relationship_warmth} onChange={(e) => setForm({ ...form, relationship_warmth: e.target.value })}>{warmth.map((s) => <option key={s}>{s}</option>)}</select></label><label>Fit score<input type="number" min="1" max="10" value={form.fit_score} onChange={(e) => setForm({ ...form, fit_score: e.target.value })} /></label><label>Revenue score<input type="number" min="1" max="10" value={form.revenue_potential_score} onChange={(e) => setForm({ ...form, revenue_potential_score: e.target.value })} /></label></section>
              <section className={styles.wide}><h3>5. ANGELCARE service fit</h3><label>Current child/family services<textarea value={form.current_family_services} onChange={(e) => setForm({ ...form, current_family_services: e.target.value })} /></label><label>Potential ANGELCARE fit<textarea value={form.potential_service_fit} onChange={(e) => setForm({ ...form, potential_service_fit: e.target.value })} /></label><label>Pain points<textarea value={form.pain_points} onChange={(e) => setForm({ ...form, pain_points: e.target.value })} /></label></section>
              <section className={styles.wide}><h3>6. Commercial opportunity & next action</h3><label>Opportunity description<textarea value={form.opportunity_description} onChange={(e) => setForm({ ...form, opportunity_description: e.target.value })} /></label><label>Estimated monthly value<input type="number" value={form.estimated_monthly_value} onChange={(e) => setForm({ ...form, estimated_monthly_value: e.target.value })} /></label><label>Estimated annual value<input type="number" value={form.estimated_annual_value} onChange={(e) => setForm({ ...form, estimated_annual_value: e.target.value })} /></label><label>Next follow-up<input type="datetime-local" value={form.next_follow_up_at} onChange={(e) => setForm({ ...form, next_follow_up_at: e.target.value })} /></label><label>Next action<textarea value={form.next_action} onChange={(e) => setForm({ ...form, next_action: e.target.value })} /></label></section>
            </div>
            <div className={styles.modalFooter}><button type="button" className={styles.ghostButton} onClick={() => setModal(null)}>Cancel</button><button disabled={saving} className={styles.primaryButton}>{saving ? 'Saving...' : 'Save prospect record'}</button></div>
          </form>
        </div>
      )}

      {modal === 'contact' && selected && (
        <div className={styles.modalBackdrop} onClick={() => setModal(null)}>
          <form className={styles.contactModal} onSubmit={submitContact} onClick={(e) => e.stopPropagation()}>
            <div className={styles.modalHeader}><div><p className={styles.eyebrow}>Decision-maker layer</p><h2>Add contact for {selected.prospect.name}</h2><span>Capture influence level, preferred channel, and decision-maker status.</span></div><button type="button" onClick={() => setModal(null)}>×</button></div>
            <div className={styles.contactGrid}><label>Name<input required value={contactForm.name} onChange={(e) => setContactForm({ ...contactForm, name: e.target.value })} /></label><label>Role<input value={contactForm.role} onChange={(e) => setContactForm({ ...contactForm, role: e.target.value })} /></label><label>Phone<input value={contactForm.phone} onChange={(e) => setContactForm({ ...contactForm, phone: e.target.value })} /></label><label>Email<input value={contactForm.email} onChange={(e) => setContactForm({ ...contactForm, email: e.target.value })} /></label><label>LinkedIn<input value={contactForm.linkedin} onChange={(e) => setContactForm({ ...contactForm, linkedin: e.target.value })} /></label><label>Influence<select value={contactForm.influence_level} onChange={(e) => setContactForm({ ...contactForm, influence_level: e.target.value })}><option>Low</option><option>Medium</option><option>High</option><option>Final decision maker</option></select></label><label className={styles.wide}>Notes<textarea value={contactForm.notes} onChange={(e) => setContactForm({ ...contactForm, notes: e.target.value })} /></label><label className={styles.checkbox}><input type="checkbox" checked={contactForm.is_decision_maker} onChange={(e) => setContactForm({ ...contactForm, is_decision_maker: e.target.checked })} /> Mark as decision maker</label></div>
            <div className={styles.modalFooter}><button type="button" className={styles.ghostButton} onClick={() => setModal(null)}>Cancel</button><button disabled={saving} className={styles.primaryButton}>{saving ? 'Saving...' : 'Add contact'}</button></div>
          </form>
        </div>
      )}
    </main>
  )
}
