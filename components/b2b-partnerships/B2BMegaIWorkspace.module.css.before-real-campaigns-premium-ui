.workspace {
  display: grid;
  gap: 22px;
  padding: 6px 0 36px;
  color: #0f172a;
}
.hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 360px;
  gap: 22px;
  padding: 30px;
  border: 1px solid #e5e7eb;
  border-radius: 34px;
  background: linear-gradient(135deg, #ffffff 0%, #f8fbff 74%, #eff6ff 100%);
  box-shadow: 0 26px 70px rgba(15, 23, 42, 0.08);
}
.eyebrow {
  display: inline-flex;
  width: fit-content;
  padding: 8px 12px;
  border-radius: 999px;
  background: #fff7ed;
  color: #9a3412;
  font-size: 11px;
  font-weight: 950;
  letter-spacing: .12em;
  text-transform: uppercase;
}
.hero h1 {
  margin: 14px 0 12px;
  max-width: 920px;
  font-size: clamp(34px, 5vw, 72px);
  line-height: .9;
  letter-spacing: -.065em;
  font-weight: 980;
}
.hero p {
  margin: 0;
  max-width: 820px;
  color: #64748b;
  font-size: 16px;
  line-height: 1.65;
}
.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  margin-top: 22px;
}
.primaryButton,
.secondaryButton,
.dangerButton {
  min-height: 46px;
  padding: 0 17px;
  border-radius: 15px;
  font-size: 13px;
  font-weight: 900;
  cursor: pointer;
}
.primaryButton {
  border: 0;
  color: #fff;
  background: #0f172a;
  box-shadow: 0 16px 30px rgba(15,23,42,.24);
}
.secondaryButton {
  border: 1px solid #e5e7eb;
  color: #0f172a;
  background: #fff;
}
.dangerButton {
  border: 1px solid #fed7aa;
  color: #9a3412;
  background: #fff7ed;
}
.sideCard,
.panel,
.card,
.modal {
  border: 1px solid #e5e7eb;
  background: rgba(255,255,255,.96);
  box-shadow: 0 22px 56px rgba(15,23,42,.07);
}
.sideCard {
  border-radius: 28px;
  padding: 22px;
}
.sideCard strong {
  display:block;
  font-size: 24px;
  margin-bottom: 10px;
}
.sideCard span {
  color:#64748b;
  line-height: 1.55;
}
.kpis {
  display:grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14px;
}
.kpi {
  padding: 18px;
  border-radius: 24px;
  background: #fff;
  border: 1px solid #e5e7eb;
}
.kpi small {
  display:block;
  color:#64748b;
  font-weight:900;
  letter-spacing:.05em;
  text-transform:uppercase;
}
.kpi strong {
  display:block;
  margin-top: 12px;
  font-size: 30px;
  letter-spacing:-.04em;
}
.grid {
  display:grid;
  grid-template-columns: minmax(0, 1.2fr) minmax(360px, .8fr);
  gap: 20px;
}
.panel {
  border-radius: 28px;
  padding: 22px;
}
.panelHeader {
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:16px;
  margin-bottom: 18px;
}
.panelHeader h2 {
  margin:0;
  font-size: 24px;
  letter-spacing:-.035em;
}
.panelHeader p {
  margin:6px 0 0;
  color:#64748b;
  line-height:1.55;
}
.tableWrap {
  overflow:auto;
  border:1px solid #e5e7eb;
  border-radius:20px;
}
.tableWrap table {
  width:100%;
  border-collapse:collapse;
  min-width: 760px;
}
.tableWrap th {
  padding:13px 14px;
  text-align:left;
  color:#64748b;
  background:#f8fafc;
  font-size:11px;
  letter-spacing:.08em;
  text-transform:uppercase;
}
.tableWrap td {
  padding:14px;
  border-top:1px solid #eef2f7;
  vertical-align:top;
  font-size:13px;
}
.tableWrap td strong {
  display:block;
  margin-bottom:4px;
}
.tableWrap td small {
  color:#64748b;
}
.badge {
  display:inline-flex;
  padding:7px 10px;
  border-radius:999px;
  background:#eff6ff;
  color:#1d4ed8;
  font-weight:900;
  font-size:11px;
}
.formGrid {
  display:grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14px;
}
.field {
  display:grid;
  gap:7px;
}
.field label {
  font-size:12px;
  font-weight:900;
  color:#334155;
}
.field input,
.field select,
.field textarea {
  width:100%;
  border:1px solid #dbe3ef;
  border-radius:14px;
  padding:12px 13px;
  color:#0f172a;
  background:#fff;
  font:inherit;
}
.field textarea {
  min-height:110px;
  resize:vertical;
}
.full { grid-column:1 / -1; }
.cards {
  display:grid;
  gap:12px;
}
.card {
  border-radius:22px;
  padding:16px;
}
.card h3 {
  margin:0 0 8px;
  letter-spacing:-.025em;
}
.card p { margin:0; color:#64748b; line-height:1.55; }
.modalBackdrop {
  position:fixed;
  inset:0;
  z-index:60;
  display:grid;
  place-items:center;
  padding:30px;
  background:rgba(15,23,42,.48);
  backdrop-filter: blur(7px);
}
.modal {
  width:min(1180px, 96vw);
  max-height: 90vh;
  overflow:auto;
  border-radius:32px;
}
.modalHeader,
.modalFooter {
  padding:22px 26px;
  display:flex;
  justify-content:space-between;
  gap:18px;
  align-items:center;
  border-bottom:1px solid #e5e7eb;
}
.modalHeader h2 { margin:6px 0 0; font-size:28px; letter-spacing:-.04em; }
.modalHeader button {
  width:44px; height:44px; border-radius:14px; border:1px solid #e5e7eb; background:#fff; cursor:pointer; font-size:22px;
}
.modalBody { padding:26px; display:grid; gap:20px; }
.modalFooter { border-top:1px solid #e5e7eb; border-bottom:0; justify-content:flex-end; }
.error {
  padding:14px 16px;
  border:1px solid #fecaca;
  background:#fff1f2;
  color:#991b1b;
  border-radius:18px;
  font-weight:800;
}
@media (max-width: 1100px) {
  .hero, .grid { grid-template-columns:1fr; }
  .kpis { grid-template-columns: repeat(2, minmax(0, 1fr)); }
}
@media (max-width: 720px) {
  .formGrid, .kpis { grid-template-columns:1fr; }
  .hero { padding:20px; }
}
