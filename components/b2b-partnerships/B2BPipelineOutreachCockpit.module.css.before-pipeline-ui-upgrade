.shell {
  min-height: 100vh;
  padding: 28px;
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 48%, #f3f6fb 100%);
  color: #0f172a;
}
.hero {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 24px;
  align-items: end;
  padding: 28px;
  border: 1px solid #e2e8f0;
  border-radius: 30px;
  background: #ffffff;
  box-shadow: 0 24px 70px rgba(15, 23, 42, .08);
}
.heroText h1 { margin: 8px 0 10px; font-size: clamp(34px, 4vw, 58px); letter-spacing: -2px; line-height: .94; }
.heroText p { max-width: 860px; color: #64748b; font-size: 16px; line-height: 1.75; }
.eyebrow { display: inline-flex; width: fit-content; border-radius: 999px; padding: 8px 11px; background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; font-size: 11px; font-weight: 900; letter-spacing: .08em; text-transform: uppercase; }
.heroActions { display: flex; flex-wrap: wrap; justify-content: flex-end; gap: 10px; }
.primaryBtn, .secondaryBtn { border: 0; border-radius: 14px; padding: 12px 15px; font-weight: 900; cursor: pointer; transition: .2s ease; }
.primaryBtn { color: white; background: linear-gradient(135deg, #2563eb, #1d4ed8); box-shadow: 0 16px 32px rgba(37, 99, 235, .22); }
.secondaryBtn { color: #0f172a; background: #fff; border: 1px solid #e2e8f0; }
.primaryBtn:hover, .secondaryBtn:hover { transform: translateY(-1px); }
.primaryBtn:disabled, .secondaryBtn:disabled { opacity: .55; cursor: not-allowed; transform: none; }
.diagnostic { margin-top: 18px; padding: 18px; border-radius: 22px; border: 1px solid #fecaca; background: #fff5f5; color: #991b1b; display: flex; align-items: center; justify-content: space-between; gap: 14px; }
.diagnostic p { margin: 0; color: #7f1d1d; }
.diagnostic button { border: 1px solid #fecaca; background: white; border-radius: 12px; padding: 10px 13px; font-weight: 800; cursor: pointer; }
.metricGrid { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 14px; margin-top: 18px; }
.metricCard { padding: 18px; border-radius: 24px; background: #ffffff; border: 1px solid #e2e8f0; box-shadow: 0 12px 34px rgba(15, 23, 42, .06); }
.metricCard span { display: block; font-size: 12px; font-weight: 900; color: #64748b; text-transform: uppercase; letter-spacing: .05em; }
.metricCard strong { display: block; margin-top: 8px; font-size: 28px; letter-spacing: -1px; }
.metricCard small { display: block; margin-top: 6px; color: #64748b; font-weight: 700; }
.metricDanger { border-color: #fecaca; background: linear-gradient(180deg, #fff, #fff7f7); }
.workspaceSwitch { margin-top: 18px; padding: 6px; width: fit-content; display: flex; gap: 4px; border-radius: 18px; background: #eef2f7; border: 1px solid #e2e8f0; }
.workspaceSwitch button { border: 0; border-radius: 14px; padding: 11px 16px; background: transparent; font-weight: 900; color: #475569; cursor: pointer; }
.workspaceSwitch .activeSwitch { background: #fff; color: #1d4ed8; box-shadow: 0 8px 20px rgba(15, 23, 42, .08); }
.commandBar { margin-top: 18px; display: grid; grid-template-columns: minmax(280px, 420px) 1fr; gap: 14px; align-items: end; }
.searchBox { background: #fff; border: 1px solid #e2e8f0; border-radius: 20px; padding: 12px; box-shadow: 0 12px 30px rgba(15,23,42,.05); }
.searchBox span { display: block; color: #64748b; font-size: 11px; font-weight: 900; text-transform: uppercase; margin-bottom: 6px; }
.searchBox input { width: 100%; border: 0; outline: none; font-weight: 750; color: #0f172a; }
.segments { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
.segments button { padding: 11px 13px; border-radius: 999px; border: 1px solid #e2e8f0; background: #fff; color: #334155; font-weight: 850; cursor: pointer; }
.segments .segmentActive { border-color: #bfdbfe; color: #1d4ed8; background: #eff6ff; }
.pipelineCanvas { margin-top: 18px; display: grid; grid-template-columns: repeat(5, minmax(280px, 1fr)); gap: 14px; overflow-x: auto; padding-bottom: 10px; }
.pipelineColumn { min-height: 620px; padding: 16px; border-radius: 26px; background: #fff; border: 1px solid #e2e8f0; box-shadow: 0 20px 50px rgba(15, 23, 42, .06); }
.pipelineColumn header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; }
.pipelineColumn header strong { font-size: 17px; letter-spacing: -.3px; }
.pipelineColumn header span { display: block; margin-top: 5px; font-size: 12px; color: #64748b; line-height: 1.45; }
.pipelineColumn header em { font-style: normal; min-width: 32px; height: 32px; border-radius: 999px; display: grid; place-items: center; background: #f8fafc; border: 1px solid #e2e8f0; font-weight: 950; }
.pipelineColumn[data-accent='blue'] { border-top: 5px solid #3b82f6; }
.pipelineColumn[data-accent='amber'] { border-top: 5px solid #f59e0b; }
.pipelineColumn[data-accent='purple'] { border-top: 5px solid #7c3aed; }
.pipelineColumn[data-accent='green'] { border-top: 5px solid #10b981; }
.pipelineColumn[data-accent='slate'] { border-top: 5px solid #64748b; }
.stagePills { display: flex; flex-wrap: wrap; gap: 6px; margin: 14px 0; }
.stagePills span { font-size: 10px; font-weight: 900; padding: 6px 8px; border-radius: 999px; background: #f8fafc; border: 1px solid #e2e8f0; color: #475569; }
.cardStack { display: grid; gap: 12px; }
.pipelineCard { padding: 14px; border-radius: 20px; background: #fbfdff; border: 1px solid #e2e8f0; }
.cardTop { display: flex; justify-content: space-between; gap: 10px; }
.priority { width: 32px; height: 32px; border-radius: 12px; display: grid; place-items: center; background: #0f172a; color: #fff; font-weight: 950; }
.sector { font-size: 11px; font-weight: 900; padding: 7px 9px; border-radius: 999px; background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
.cardTitle { display: block; margin: 12px 0 8px; padding: 0; border: 0; background: transparent; text-align: left; color: #0f172a; font-size: 16px; font-weight: 950; cursor: pointer; }
.pipelineCard p { margin: 0; color: #64748b; line-height: 1.55; font-size: 13px; }
.cardFacts { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 12px; }
.cardFacts span { font-size: 11px; font-weight: 850; color: #334155; border: 1px solid #e2e8f0; background: #fff; border-radius: 999px; padding: 7px 8px; }
.nextLine { margin-top: 12px; padding: 10px; border-radius: 14px; background: #f8fafc; color: #475569; font-size: 12px; line-height: 1.45; }
.nextLine[data-overdue='true'] { background: #fff1f2; color: #be123c; }
.cardActions { display: grid; grid-template-columns: repeat(3, 1fr); gap: 7px; margin-top: 12px; }
.cardActions button { border: 1px solid #e2e8f0; background: #fff; border-radius: 12px; padding: 9px; font-weight: 850; cursor: pointer; }
.columnEmpty { border: 1px dashed #cbd5e1; border-radius: 18px; padding: 18px; text-align: center; color: #94a3b8; font-weight: 800; }
.outreachLayout { margin-top: 18px; display: grid; grid-template-columns: 390px 1fr; gap: 16px; align-items: start; }
.scriptPanel, .outreachMain, .queueCard, .tableCard { background: #fff; border: 1px solid #e2e8f0; border-radius: 26px; box-shadow: 0 18px 50px rgba(15, 23, 42, .06); }
.scriptPanel { padding: 18px; position: sticky; top: 18px; }
.scriptPanel h2, .scriptPanel h3 { margin: 14px 0 8px; }
.scriptPanel pre, .callScript pre { white-space: pre-wrap; font-family: inherit; font-size: 12px; line-height: 1.58; color: #475569; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 18px; padding: 14px; max-height: 260px; overflow: auto; }
.outreachMain { padding: 16px; }
.queueGrid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px; }
.queueCard { padding: 16px; box-shadow: none; }
.queueCard header, .tableCard header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
.queueCard header strong, .tableCard header strong { font-size: 16px; }
.queueCard header span, .tableCard header span { display: block; margin-top: 4px; font-size: 12px; color: #64748b; }
.queueRow { display: grid; grid-template-columns: 1fr auto; gap: 10px; align-items: center; padding: 11px 0; border-top: 1px solid #eef2f7; }
.queueRow button { border: 0; background: transparent; text-align: left; font-weight: 900; cursor: pointer; }
.queueRow button small { display: block; color: #64748b; margin-top: 3px; font-weight: 700; }
.queueRow div { display: flex; gap: 6px; }
.queueRow div button { padding: 8px 10px; border: 1px solid #e2e8f0; border-radius: 12px; background: #fff; }
.tableCard { margin-top: 14px; padding: 16px; box-shadow: none; }
.tableWrap { width: 100%; overflow-x: auto; border: 1px solid #e2e8f0; border-radius: 18px; background: #fff; }
.tableWrap table { width: 100%; border-collapse: collapse; }
.tableWrap th { padding: 12px; text-align: left; font-size: 11px; color: #64748b; background: #f8fafc; text-transform: uppercase; letter-spacing: .05em; }
.tableWrap td { padding: 13px 12px; border-top: 1px solid #eef2f7; color: #334155; font-size: 13px; }
.tableWrap td strong { display: block; color: #0f172a; }
.tableWrap td small { display: block; color: #64748b; margin-top: 3px; }
.tableWrap td[data-overdue='true'] { color: #be123c; font-weight: 900; }
.tableWrap em { font-style: normal; border-radius: 999px; padding: 6px 8px; background: #f1f5f9; font-size: 11px; font-weight: 850; }
.drawerBackdrop, .modalBackdrop { position: fixed; inset: 0; z-index: 80; background: rgba(15, 23, 42, .38); backdrop-filter: blur(6px); display: flex; justify-content: flex-end; }
.drawer { width: min(760px, 100%); height: 100%; background: #fff; overflow: auto; box-shadow: -30px 0 80px rgba(15, 23, 42, .24); padding: 24px; }
.drawer header, .megaModal header { display: flex; justify-content: space-between; align-items: flex-start; gap: 18px; border-bottom: 1px solid #e2e8f0; padding-bottom: 18px; }
.drawer header h2, .megaModal header h2 { margin: 8px 0 4px; font-size: 30px; letter-spacing: -1px; }
.drawer header p, .megaModal header p { color: #64748b; margin: 0; }
.drawer header button, .megaModal header button { width: 42px; height: 42px; border-radius: 14px; border: 1px solid #e2e8f0; background: #fff; font-size: 22px; cursor: pointer; }
.drawerActions { display: flex; flex-wrap: wrap; gap: 10px; margin: 18px 0; }
.drawerGrid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
.infoCard { padding: 16px; border: 1px solid #e2e8f0; border-radius: 20px; background: #fbfdff; }
.infoCard span { color: #64748b; font-size: 11px; font-weight: 900; text-transform: uppercase; }
.infoCard strong { display: block; margin: 8px 0 4px; font-size: 18px; }
.infoCard small { color: #64748b; line-height: 1.45; }
.deepNotes { margin-top: 14px; padding: 18px; border-radius: 22px; background: #f8fafc; border: 1px solid #e2e8f0; }
.deepNotes h3 { margin-top: 0; }
.deepNotes p { color: #475569; line-height: 1.6; }
.modalBackdrop { justify-content: center; align-items: center; padding: 24px; }
.megaModal { width: min(1160px, 100%); max-height: 92vh; overflow: auto; background: #fff; border-radius: 30px; box-shadow: 0 40px 120px rgba(15, 23, 42, .32); padding: 24px; }
.modalGrid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 14px; margin-top: 18px; }
.modalTwoCols { display: grid; grid-template-columns: 360px 1fr; gap: 16px; margin-top: 18px; }
.callScript { border: 1px solid #e2e8f0; border-radius: 22px; padding: 16px; background: #f8fafc; }
.modalGrid label { display: grid; gap: 7px; color: #334155; font-size: 12px; font-weight: 900; }
.modalGrid input, .modalGrid select, .modalGrid textarea { width: 100%; border: 1px solid #e2e8f0; border-radius: 14px; padding: 12px; outline: none; background: #fff; color: #0f172a; }
.modalGrid textarea { min-height: 150px; resize: vertical; }
.fullField { grid-column: 1 / -1; }
.megaModal footer { margin-top: 18px; padding-top: 16px; border-top: 1px solid #e2e8f0; display: flex; justify-content: flex-end; gap: 10px; }
.emptyState { margin-top: 18px; padding: 40px; text-align: center; background: #fff; border: 1px dashed #cbd5e1; border-radius: 26px; color: #64748b; }
.emptyState strong { display: block; color: #0f172a; font-size: 22px; }
.emptyState p { line-height: 1.65; }
.emptyState div { display: flex; justify-content: center; gap: 10px; }
.emptyState button { border: 1px solid #e2e8f0; background: #fff; border-radius: 14px; padding: 11px 14px; font-weight: 850; cursor: pointer; }
.softText { color: #94a3b8; font-weight: 750; }
.toast { position: fixed; right: 24px; bottom: 24px; z-index: 120; color: #fff; background: #0f172a; padding: 14px 16px; border-radius: 16px; font-weight: 900; box-shadow: 0 20px 50px rgba(15,23,42,.24); animation: toastFade 3s ease forwards; }
@keyframes toastFade { 0%{opacity:0; transform: translateY(10px)} 10%{opacity:1; transform: translateY(0)} 85%{opacity:1} 100%{opacity:0} }
@media (max-width: 1180px) { .metricGrid { grid-template-columns: repeat(3, 1fr); } .commandBar, .outreachLayout, .modalTwoCols { grid-template-columns: 1fr; } .scriptPanel { position: static; } }
@media (max-width: 760px) { .shell { padding: 14px; } .hero { grid-template-columns: 1fr; } .metricGrid, .queueGrid, .drawerGrid, .modalGrid { grid-template-columns: 1fr; } .pipelineCanvas { grid-template-columns: 1fr; overflow: visible; } .heroActions, .segments { justify-content: flex-start; } }
