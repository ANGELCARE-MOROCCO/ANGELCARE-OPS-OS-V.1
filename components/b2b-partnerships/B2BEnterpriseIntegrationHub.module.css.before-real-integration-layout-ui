    radial-gradient(circle at 70% 94%, rgba(168, 85, 247, .11), transparent 34%),
    linear-gradient(180deg, #f8fafc 0%, #eef4f8 100%) !important;
}

.hero,
.header,
.commandHero,
.integrationHero,
.bridgeHero {
  position: relative !important;
  overflow: hidden !important;
  isolation: isolate;
  border-radius: 38px !important;
  border: 1px solid rgba(226, 232, 240, .98) !important;
  background:
    radial-gradient(circle at 84% 12%, rgba(37, 99, 235, .20), transparent 30%),
    radial-gradient(circle at 14% 88%, rgba(16, 185, 129, .15), transparent 34%),
    radial-gradient(circle at 96% 90%, rgba(168, 85, 247, .12), transparent 28%),
    linear-gradient(135deg, #ffffff 0%, #f8fbff 52%, #f5f9ff 100%) !important;
  box-shadow:
    0 34px 96px rgba(15, 23, 42, .12),
    inset 0 1px 0 rgba(255,255,255,.96) !important;
}

.hero::before,
.header::before,
.commandHero::before,
.integrationHero::before,
.bridgeHero::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  background-image:
    linear-gradient(rgba(15, 23, 42, .034) 1px, transparent 1px),
    linear-gradient(90deg, rgba(15, 23, 42, .034) 1px, transparent 1px);
  background-size: 30px 30px;
  mask-image: linear-gradient(90deg, rgba(0,0,0,.72), transparent 78%);
}

.hero::after,
.header::after,
.commandHero::after,
.integrationHero::after,
.bridgeHero::after {
  content: "🔗";
  position: absolute;
  right: 34px;
  bottom: 28px;
  display: grid;
  place-items: center;
  width: 106px;
  height: 106px;
  border-radius: 36px;
  background:
    linear-gradient(135deg, rgba(37, 99, 235, .14), rgba(16, 185, 129, .12)),
    #ffffff;
  border: 1px solid rgba(226, 232, 240, .94);
  box-shadow: 0 30px 70px rgba(37, 99, 235, .19);
  font-size: 46px;
}

.hero :global(h1),
.header :global(h1),
.commandHero :global(h1),
.integrationHero :global(h1),
