.shell{display:grid;grid-template-columns:320px minmax(0,1fr);gap:24px;min-height:calc(100vh - 110px);padding:22px;background:linear-gradient(180deg,#f8fafc 0%,#eef3f8 100%)}
.sidebar{position:sticky;top:96px;align-self:start;height:calc(100vh - 130px);overflow:auto;padding:18px;border:1px solid rgba(226,232,240,.95);border-radius:30px;background:rgba(255,255,255,.96);box-shadow:0 24px 70px rgba(15,23,42,.08)}
.brandBlock{padding:18px;border-radius:24px;background:#fff;border:1px solid #e5e7eb}.brandPill{display:inline-flex;width:fit-content;padding:8px 11px;border-radius:999px;background:#eff6ff;color:#1d4ed8;font-size:11px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}.brandBlock h2{margin:12px 0 8px;color:#0f172a;font-size:24px;font-weight:950;letter-spacing:-.04em}.brandBlock p{margin:0;color:#64748b;font-size:13px;line-height:1.55}.nav{display:grid;gap:9px;margin-top:18px}.navItem{display:grid;grid-template-columns:42px minmax(0,1fr);gap:12px;align-items:center;padding:13px;border:1px solid transparent;border-radius:18px;text-decoration:none;color:#334155;background:transparent;transition:.18s ease}.navItem:hover{border-color:#dbeafe;background:#f8fafc;transform:translateX(2px)}.navItem.active{border-color:#bfdbfe;background:linear-gradient(135deg,#eff6ff,#fff);box-shadow:0 16px 36px rgba(37,99,235,.12)}.navIcon{width:42px;height:42px;display:grid;place-items:center;border-radius:15px;background:#fff;border:1px solid #e5e7eb;box-shadow:0 10px 22px rgba(15,23,42,.06)}.navItem strong{display:block;color:#0f172a;font-size:13px;font-weight:900}.navItem small{display:block;margin-top:3px;color:#64748b;font-size:11px;line-height:1.35}.sidebarPanel{margin-top:18px;padding:18px;border-radius:24px;background:#fff;border:1px solid #e5e7eb;color:#0f172a;box-shadow:0 18px 42px rgba(15,23,42,.08)}.panelLabel{display:inline-flex;margin-bottom:9px;color:#1d4ed8;font-size:10px;font-weight:900;letter-spacing:.12em;text-transform:uppercase}.sidebarPanel strong{display:block;font-size:17px;font-weight:900}.sidebarPanel p{margin:8px 0 14px;color:#64748b;font-size:12px;line-height:1.5}.panelStats{display:grid;gap:7px}.panelStats span{padding:9px 10px;border:1px solid #e5e7eb;border-radius:13px;background:#f8fafc;color:#334155;font-size:11px;font-weight:800}.main{min-width:0}.moduleHeader{display:flex;justify-content:space-between;gap:22px;align-items:center;margin-bottom:18px;padding:22px 24px;border:1px solid rgba(226,232,240,.9);border-radius:30px;background:rgba(255,255,255,.96);box-shadow:0 24px 70px rgba(15,23,42,.08)}.eyebrow{display:inline-flex;margin-bottom:7px;color:#64748b;font-size:11px;font-weight:900;letter-spacing:.13em;text-transform:uppercase}.moduleHeader h1{margin:0;color:#0f172a;font-size:clamp(28px,3vw,44px);line-height:.95;font-weight:950;letter-spacing:-.055em}.moduleHeader p{margin:10px 0 0;color:#64748b;max-width:680px;line-height:1.55}.headerActions{display:flex;flex-wrap:wrap;gap:10px;justify-content:flex-end}.primaryAction,.secondaryAction{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:0 16px;border-radius:15px;font-size:13px;font-weight:900;text-decoration:none;white-space:nowrap}.primaryAction{color:white;background:#2563eb;box-shadow:0 14px 30px rgba(37,99,235,.25)}.secondaryAction{color:#0f172a;background:white;border:1px solid #e5e7eb}.content{min-width:0}@media(max-width:1180px){.shell{grid-template-columns:1fr}.sidebar{position:static;height:auto}.nav{grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:760px){.shell{padding:12px}.nav{grid-template-columns:1fr}.moduleHeader{flex-direction:column;align-items:stretch}.headerActions{justify-content:flex-start}}
