  id: string
  name: string
  contact: string
  email: string
  phone: string
  type: string
  category: string
  city: string
  district: string
  status: "Active" | "Pending" | "Inactive"
  programs: string[]
  revenueImpact: number
  engagement: number
  joinedOn: string
  website: string
  summary: string
  logo?: string
}

