const typeTabs = ["All Partners", "Preschools & Kindergarten", "Maternity Clinics", "Orthophonistes", "Hotels", "Corporates", "Associations"]

function money(value: number) {
  if (value >= 1000000) return `MAD ${(value / 1000000).toFixed(2)}M`
  return `MAD ${value.toLocaleString("en-US")}`
}

function Card({ children, className = "" }: { children: ReactNode; className?: string }) {
  return (
    <section className={`rounded-[26px] border border-white/15 bg-[linear-gradient(145deg,rgba(18,30,54,.98),rgba(8,16,31,.99))] p-5 text-white shadow-[0_20px_70px_rgba(0,0,0,.25)] ${className}`}>
      {children}
    </section>
  )
}

function Kpi({ icon: Icon, label, value, delta }: { icon: any; label: string; value: string | number; delta: string }) {
  return (
    <Card className="min-h-[110px]">
      <div className="flex items-center gap-4">
        <span className="flex h-12 w-12 items-center justify-center rounded-2xl bg-white/[0.08]">
          <Icon className="h-6 w-6 text-white" />
        </span>
        <div>
          <p className="text-xs font-black uppercase tracking-[0.18em] text-white">{label}</p>
          <p className="mt-1 text-2xl font-black text-white">{value}</p>
          <p className="mt-2 text-xs font-black text-emerald-200">↑ {delta} vs last 30 days</p>
        </div>
      </div>
    </Card>
  )
}

function TypeBadge({ type }: { type: string }) {
  const palette: Record<string, string> = {
    "Preschool & Kindergarten": "bg-blue-500/20 text-blue-100 border-blue-300/20",
    "Maternity Clinic": "bg-pink-500/20 text-pink-100 border-pink-300/20",
    Orthophoniste: "bg-rose-500/20 text-rose-100 border-rose-300/20",
    Hotel: "bg-cyan-500/20 text-cyan-100 border-cyan-300/20",
    Corporate: "bg-emerald-500/20 text-emerald-100 border-emerald-300/20",
    Association: "bg-violet-500/20 text-violet-100 border-violet-300/20",
  }
  return <span className={`rounded-lg border px-3 py-1 text-xs font-black ${palette[type] || "bg-white/10 text-white border-white/15"}`}>{type}</span>
}

function PartnerAvatar({ partner }: { partner: Partner }) {
  const Icon = partner.type.includes("Preschool") ? GraduationCap : partner.type.includes("Maternity") ? Stethoscope : partner.type.includes("Ortho") ? Activity : partner.type.includes("Hotel") ? Hotel : partner.type.includes("Corporate") ? Building2 : Network
  return (
    <div className="flex h-12 w-12 items-center justify-center rounded-full border border-white/15 bg-white/[0.08]">
      <Icon className="h-6 w-6 text-white" />
    </div>
  )
}

function PartnerProfilePanel({
  partner,
  onClose,
}: {
  partner: Partner
  onClose: () => void
}) {
  return (
    <aside className="sticky top-6 h-fit rounded-[30px] border border-white/15 bg-[linear-gradient(145deg,rgba(18,30,54,.98),rgba(8,16,31,.99))] p-6 text-white shadow-2xl">
      <div className="mb-5 flex justify-end">
        <button onClick={onClose} className="rounded-xl bg-white/[0.08] p-2 hover:bg-white/[0.14]">
          <X className="h-4 w-4 text-white" />
        </button>
      </div>
      <div className="flex items-start gap-4">
        <PartnerAvatar partner={partner} />
        <div className="min-w-0">
          <h3 className="text-xl font-black leading-6 text-white">{partner.name}</h3>
          <p className="mt-1 text-sm font-bold text-white">{partner.type}</p>
          <span className="mt-3 inline-flex rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-black text-white">{partner.status}</span>
        </div>
      </div>

      <div className="mt-6 grid grid-cols-5 gap-2">
        {[Mail, Phone, MapPin, ChevronRight, MoreHorizontal].map((Icon, index) => (
          <button key={index} className="rounded-2xl border border-white/15 bg-white/[0.07] p-3 hover:bg-violet-600/40">
            <Icon className="mx-auto h-5 w-5 text-white" />
          </button>
        ))}
      </div>

      <div className="mt-6 flex gap-3 border-b border-white/15 text-sm font-black text-white">
        {["Overview", "Programs", "Performance", "Documents"].map((tab, index) => (
          <button key={tab} className={`pb-3 ${index === 0 ? "border-b-2 border-violet-400 text-white" : "text-white/80"}`}>{tab}</button>
        ))}
      </div>

      <div className="mt-6 space-y-6">
        <section>
          <h4 className="text-sm font-black uppercase tracking-[0.18em] text-white">Partner Information</h4>
          <div className="mt-4 space-y-3 text-sm">
            {[
              ["Contact Person", partner.contact],
              ["Email", partner.email],
              ["Phone", partner.phone],
              ["Location", `${partner.city}, ${partner.district}`],
              ["Website", partner.website],
              ["Joined On", partner.joinedOn],
            ].map(([label, value]) => (
              <div key={label} className="grid grid-cols-[120px_1fr] gap-3">
                <p className="font-black text-white/75">{label}</p>
                <p className="font-bold text-white">{value}</p>
              </div>
            ))}
          </div>
        </section>

        <section>
          <h4 className="text-sm font-black uppercase tracking-[0.18em] text-white">Business Summary</h4>
          <p className="mt-3 text-sm font-bold leading-6 text-white">{partner.summary}</p>
          <span className="mt-3 inline-flex rounded-xl bg-violet-500/20 px-3 py-2 text-xs font-black text-white">{partner.category}</span>
        </section>

        <section>
          <h4 className="text-sm font-black uppercase tracking-[0.18em] text-white">Programs ({partner.programs.length})</h4>
          <div className="mt-3 space-y-3">
            {partner.programs.map((program, i) => (
              <div key={program} className="rounded-2xl border border-white/15 bg-white/[0.07] p-4">
                <div className="flex items-center justify-between gap-3">
                  <p className="text-sm font-black text-white">{program}</p>
                  <span className="rounded-full bg-emerald-500/20 px-3 py-1 text-xs font-black text-white">Active</span>
                </div>
                <p className="mt-1 text-xs font-bold text-white">{i === 0 ? "Revenue Share • 15%" : "Fixed Fee • MAD 25,000"}</p>
              </div>
            ))}
          </div>
        </section>

        <section>
          <h4 className="text-sm font-black uppercase tracking-[0.18em] text-white">Recent Activity</h4>
          <div className="mt-3 space-y-3">
            {[
              ["Contract renewed", "May 30, 2025 • 10:15 AM"],
              ["New program added", "May 28, 2025 • 02:30 PM"],
              ["Payment received", "May 25, 2025 • 11:45 AM"],
              ["Meeting completed", "May 20, 2025 • 04:00 PM"],
            ].map(([title, date]) => (
              <div key={title} className="flex gap-3 rounded-2xl border border-white/15 bg-white/[0.05] p-3">
                <CheckCircle2 className="mt-0.5 h-4 w-4 shrink-0 text-emerald-300" />
                <div>
                  <p className="text-sm font-black text-white">{title}</p>
                  <p className="text-xs font-bold text-white/75">{date}</p>
                </div>
              </div>
            ))}
          </div>
        </section>

        <div className="grid grid-cols-2 gap-3">
          <button className="rounded-2xl border border-violet-300/30 bg-violet-600/20 px-4 py-3 text-sm font-black text-white">Edit Partner</button>
          <button className="rounded-2xl border border-white/15 bg-white/[0.07] px-4 py-3 text-sm font-black text-white">View Full Profile</button>
        </div>
        <button className="w-full rounded-2xl border border-red-300/30 bg-red-500/10 px-4 py-4 text-sm font-black text-red-100">
          <Trash2 className="mr-2 inline h-4 w-4" />
          Delete Partner
        </button>
      </div>
    </aside>
  )
}

export default function PartnersDirectoryWorkspace({ partners = [] }: { partners?: Partner[] }) {
  const rows = partners.length ? partners : partnersSeed
  const [query, setQuery] = useState("")
  const [activeTab, setActiveTab] = useState("All Partners")
  const [selected, setSelected] = useState<Partner>(rows[0])

  const filtered = useMemo(() => {
    let next = rows
    if (activeTab !== "All Partners") {
      const normalized = activeTab.replace("s", "")
      next = next.filter((p) => activeTab.includes(p.type) || p.type.includes(normalized) || activeTab.includes(p.category))
    }
    if (query.trim()) {
      const q = query.toLowerCase()
      next = next.filter((p) => [p.name, p.contact, p.email, p.type, p.category, p.city, p.district].join(" ").toLowerCase().includes(q))
    }
    return next
  }, [rows, activeTab, query])

  const totalRevenue = rows.reduce((s, p) => s + p.revenueImpact, 0)
  const activePartners = rows.filter((p) => p.status === "Active").length
  const avgEngagement = Math.round(rows.reduce((s, p) => s + p.engagement, 0) / Math.max(1, rows.length))
  const totalPrograms = rows.reduce((s, p) => s + p.programs.length, 0)

  return (
    <div className="w-full space-y-7 text-white">
      <div className="flex flex-wrap items-start justify-between gap-5">
        <div>
          <h1 className="text-4xl font-black text-white">Partners Directory</h1>
          <p className="mt-2 text-sm font-bold text-white">Browse, manage, and grow your partner network across all partner types.</p>
        </div>
        <button className="rounded-2xl border border-white/15 bg-white/[0.07] p-3 text-white hover:bg-white/[0.14]">
          <X className="h-5 w-5 text-white" />
        </button>
      </div>

      <div className="grid gap-4 xl:grid-cols-6">
        <Kpi icon={FileText} label="Total Partners" value={rows.length} delta="18%" />
        <Kpi icon={ShieldCheck} label="Active Partners" value={activePartners} delta="12%" />
        <Kpi icon={CalendarDays} label="New This Month" value="23" delta="20%" />
        <Kpi icon={Sparkles} label="Total Revenue Impact" value={money(totalRevenue)} delta="22%" />
        <Kpi icon={BarChart3} label="Engagement Rate" value={`${avgEngagement}%`} delta="8%" />
        <Kpi icon={TrendingUp} label="Partnership Programs" value={totalPrograms} delta="16%" />
      </div>

      <div className="grid gap-7 xl:grid-cols-[1fr_360px]">
        <main className="space-y-6">
          <Card>
            <div className="grid gap-4 xl:grid-cols-[1.6fr_repeat(5,1fr)]">
              <label className="relative">
                <Search className="absolute left-4 top-3.5 h-5 w-5 text-white/80" />
                <input value={query} onChange={(e) => setQuery(e.target.value)} placeholder="Search partners by name, contact, or ID..." className="w-full rounded-2xl border border-white/15 bg-[#070d1c] py-3 pl-12 pr-4 text-sm font-bold text-white outline-none placeholder:text-white/65" />
              </label>
              {["Partner Type", "Partner Category", "Location", "Status", "Program"].map((label) => (
                <select key={label} className="rounded-2xl border border-white/15 bg-[#070d1c] px-4 py-3 text-sm font-black text-white outline-none">
                  <option>{label === "Partner Type" ? "All Types" : label === "Partner Category" ? "All Categories" : label === "Location" ? "All Locations" : label === "Status" ? "All Statuses" : "All Programs"}</option>
                </select>
              ))}
              <button className="rounded-2xl border border-violet-300/25 bg-violet-600/20 px-4 py-3 text-sm font-black text-white">
                <Filter className="mr-2 inline h-4 w-4 text-white" />
                More Filters
              </button>
            </div>
          </Card>

          <div className="flex gap-3 overflow-x-auto pb-1">
            {typeTabs.map((tab) => {
              const count = tab === "All Partners" ? rows.length : rows.filter((p) => tab.includes(p.type) || p.type.includes(tab.replace("s", "")) || tab.includes(p.category)).length
              return (
                <button key={tab} onClick={() => setActiveTab(tab)} className={`shrink-0 rounded-2xl border px-5 py-3 text-sm font-black text-white ${activeTab === tab ? "border-violet-300 bg-violet-600" : "border-white/15 bg-white/[0.07]"}`}>
                  {tab} ({count})
                </button>
              )
            })}
          </div>

          <Card className="p-0">
            <div className="overflow-x-auto">
              <table className="w-full min-w-[1250px] text-left">
                <thead className="border-b border-white/15 text-xs uppercase tracking-[0.18em] text-white">
                  <tr>
                    <th className="px-6 py-5"><input type="checkbox" className="h-4 w-4 accent-violet-500" /></th>
                    {["Partner", "Type / Category", "Location", "Status", "Programs", "Revenue Impact", "Engagement", "Joined On", "Actions"].map((h) => (
                      <th key={h} className="px-4 py-5">{h}</th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {filtered.map((partner) => (
                    <tr key={partner.id} onClick={() => setSelected(partner)} className={`cursor-pointer border-b border-white/10 hover:bg-white/[0.05] ${selected?.id === partner.id ? "bg-violet-600/10" : ""}`}>
                      <td className="px-6 py-5"><input type="checkbox" className="h-4 w-4 accent-violet-500" /></td>
                      <td className="px-4 py-5">
                        <div className="flex items-center gap-4">
                          <PartnerAvatar partner={partner} />
                          <div>
                            <p className="font-black text-white">{partner.name}</p>
                            <p className="text-xs font-bold text-white/80">{partner.contact}</p>
                            <p className="text-xs font-bold text-white/65">{partner.email}</p>
                          </div>
                        </div>
                      </td>
                      <td className="px-4 py-5">
                        <TypeBadge type={partner.type} />
                        <p className="mt-2 text-xs font-bold text-white/75">{partner.category}</p>
                      </td>
                      <td className="px-4 py-5">
                        <p className="font-black text-white">{partner.city}</p>
                        <p className="text-xs font-bold text-white/75">{partner.district}</p>
                      </td>
                      <td className="px-4 py-5">
                        <span className={`rounded-full px-3 py-1 text-xs font-black text-white ${partner.status === "Active" ? "bg-emerald-500/25" : partner.status === "Pending" ? "bg-orange-500/25" : "bg-red-500/25"}`}>{partner.status}</span>
                      </td>
                      <td className="px-4 py-5 text-sm font-black text-white">{partner.programs.length} Programs</td>
                      <td className="px-4 py-5">
                        <p className="font-black text-white">{money(partner.revenueImpact)}</p>
                        {partner.revenueImpact > 0 ? <p className="text-xs font-black text-emerald-200">↑ {Math.max(8, Math.round(partner.engagement / 4))}%</p> : <p className="text-xs font-black text-white/70">—</p>}
                      </td>
                      <td className="px-4 py-5">
                        <div className="flex items-center gap-3">
                          <span className="font-black text-white">{partner.engagement}%</span>
                          <div className="h-2 w-24 rounded-full bg-white/15">
                            <div className="h-2 rounded-full bg-emerald-400" style={{ width: `${partner.engagement}%` }} />
                          </div>
                        </div>
                      </td>
                      <td className="px-4 py-5 text-sm font-bold text-white">{partner.joinedOn}</td>
                      <td className="px-4 py-5">
                        <button className="rounded-xl border border-white/15 bg-white/[0.07] p-3 hover:bg-violet-600">
                          <MoreHorizontal className="h-5 w-5 text-white" />
                        </button>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div className="flex flex-wrap items-center justify-between gap-4 px-6 py-5 text-sm font-bold text-white">
              <p>Showing 1 to {filtered.length} of {rows.length} results</p>
              <div className="flex items-center gap-3">
                {["‹", "1", "2", "3", "…", "29", "›"].map((x, i) => (
                  <button key={`${x}-${i}`} className={`rounded-xl px-3 py-2 ${x === "1" ? "bg-violet-600" : "bg-white/[0.07]"}`}>{x}</button>
                ))}
              </div>
              <select className="rounded-xl border border-white/15 bg-[#070d1c] px-4 py-2 text-white">
                <option>Rows per page: 10</option>
                <option>Rows per page: 25</option>
              </select>
            </div>
          </Card>

          <button className="rounded-2xl border border-white/15 bg-white/[0.07] px-5 py-4 text-sm font-black text-white hover:bg-violet-600">
            <ArrowDownToLine className="mr-2 inline h-4 w-4 text-white" />
            Export Directory
          </button>
        </main>

        <PartnerProfilePanel partner={selected} onClose={() => setSelected(rows[0])} />
      </div>
    </div>
  )
}
