-7 w-7 place-items-center rounded-full bg-rose-50 text-xs font-black text-rose-600 group-hover:grid">×</button></div>)}<div className="mt-4 flex flex-wrap gap-4 text-[11px] font-bold text-slate-500"><Legend color="bg-emerald-300" label="Booked" /><Legend color="bg-blue-300" label="In Progress" /><Legend color="bg-orange-300" label="Gap" /><Legend color="bg-rose-300" label="At Risk" /></div></Panel>
}

function IncidentsPanel({ incidents, open, hideEntity }: { incidents: IncidentAlert[]; open: (item: IncidentAlert) => void; hideEntity: (id: string, label: string) => void }) {
  return <Panel title="Incidents & Alerts" action="View all incidents →"> <div className="divide-y divide-slate-100">{incidents.map((incident) => <div key={incident.id} className="group flex w-full gap-3 rounded-2xl px-2 py-3 text-left hover:bg-slate-50"><button onClick={() => open(incident)} className="contents"><span className={`mt-1 grid h-9 w-9 place-items-center rounded-2xl font-black ${incident.severity === 'critical' ? 'bg-rose-50 text-rose-600' : incident.severity === 'warning' ? 'bg-orange-50 text-orange-600' : 'bg-blue-50 text-blue-600'}`}>!</span><span className="min-w-0 flex-1"><b className="text-sm">{incident.title}</b><br/><span className="text-xs text-slate-500">{incident.mission} · {incident.zone}</span><br/><span className="line-clamp-1 text-xs text-slate-600">{incident.detail}</span><span className="mt-1 inline-block rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-black text-slate-500">{incident.workflow.split('→')[0].trim()}</span></span><span className="text-[11px] font-bold text-slate-400">{incident.time}</span></button><button onClick={() => hideEntity(incident.id, incident.title)} title="Remove incident" className="hidden h-7 w-7 shrink-0 place-items-center rounded-full bg-rose-50 text-xs font-black text-rose-600 group-hover:grid">×</button></div>)}</div><p className="mt-2 text-xs font-bold text-slate-400">Click incident for full enterprise triage modal</p></Panel>
}

function ReportsPanel({ reports, open, hideEntity }: { reports: ReportRow[]; open: (item: ReportRow) => void; hideEntity: (id: string, label: string) => void }) {
  return <Panel title="Reports Validation Queue" helper={`${reports.length} pending`} action="View all →"><div className="overflow-x-auto rounded-2xl border border-slate-100"><table className="w-full min-w-[920px] text-left text-xs"><thead className="bg-slate-50 text-slate-400"><tr>{['Mission','Client','Caregiver','Report','Quality','Tags','SLA','Workflow',''].map((h) => <th key={h} className="px-3 py-3 font-black">{h}</th>)}</tr></thead><tbody className="divide-y divide-slate-100">{reports.map((report) => <tr key={report.id} className="group bg-white hover:bg-blue-50/40"><td onClick={() => open(report)} className="cursor-pointer px-3 py-3 font-black text-blue-700">{report.mission}</td><td onClick={() => open(report)} className="cursor-pointer px-3 py-3">{report.client}</td><td onClick={() => open(report)} className="cursor-pointer px-3 py-3">{report.caregiver}</td><td onClick={() => open(report)} className="cursor-pointer px-3 py-3"><b>{report.reportType}</b><br/><span className="text-slate-400">{report.issue}</span></td><td onClick={() => open(report)} className="cursor-pointer px-3 py-3"><span className={`rounded-full px-2 py-1 font-black ${report.qualityScore < 60 ? 'bg-rose-50 text-rose-700' : report.qualityScore < 80 ? 'bg-orange-50 text-orange-700' : 'bg-emerald-50 text-emerald-700'}`}>{report.qualityScore}%</span></td><td onClick={() => open(report)} className="cursor-pointer px-3 py-3"><div className="flex flex-wrap gap-1">{report.tags.slice(0, 2).map((tag) => <span key={tag} className="rounded-full bg-slate-100 px-2 py-1 text-[10px] font-black text-slate-600">{tag}</span>)}</div></td><td onClick={() => open(report)} className="cursor-pointer px-3 py-3 font-black text-slate-500">{report.sla}</td><td onClick={() => open(report)} className="cursor-pointer px-3 py-3"><span className={report.status === 'Escalated' ? 'font-black text-rose-600' : report.status === 'Needs Info' ? 'font-black text-orange-500' : 'font-black text-blue-600'}>{report.status}</span></td><td className="px-3 py-3"><button onClick={() => hideEntity(report.id, report.mission)} className="hidden h-7 w-7 place-items-center rounded-full bg-rose-50 text-xs font-black text-rose-600 group-hover:grid">×</button></td></tr>)}</tbody></table></div></Panel>
}

function FollowUpPanel({ followUps, open }: { followUps: any[]; open: (title: string, detail: string) => void }) { return <Panel title="Operational Follow-up">{followUps.map((item) => <button key={item.label} onClick={() => open(item.label, item.helper)} className="mb-3 flex w-full items-center justify-between rounded-3xl border border-slate-100 p-4 text-left hover:bg-slate-50"><span><b>{item.label}</b><br/><span className="text-xs text-slate-500">{item.helper}</span></span><span className="text-2xl font-black">{item.count}</span><span className="text-slate-400">›</span></button>)}</Panel> }

function Panel({ title, helper, action, children }: { title: string; helper?: string; action?: string; children: React.ReactNode }) { return <section className="rounded-[2rem] border border-slate-200 bg-white p-4 shadow-sm"><div className="mb-4 flex items-center justify-between"><h2 className="font-black">{title} {helper ? <span className="rounded-full bg-slate-100 px-2 py-1 text-xs font-black text-slate-500">{helper}</span> : null}</h2>{action ? <button className="text-xs font-black text-blue-600">{action}</button> : null}</div>{children}</section> }
function Pill({ tone, children }: { tone: string; children: React.ReactNode }) { return <span className={`rounded-full px-2 py-1 text-[11px] font-black ${tone === 'red' ? 'bg-rose-50 text-rose-700' : tone === 'orange' ? 'bg-orange-50 text-orange-700' : tone === 'blue' ? 'bg-blue-50 text-blue-700' : 'bg-emerald-50 text-emerald-700'}`}>{children}</span> }
function RiskPill({ risk }: { risk: string }) { return <span className={`rounded-full px-2 py-0.5 text-[10px] font-black ${risk === 'critical' ? 'bg-rose-100 text-rose-700' : risk === 'high' ? 'bg-orange-100 text-orange-700' : risk === 'moderate' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'}`}>{risk}</span> }
function ActionToast({ logs }: { logs: ActionLog[] }) { if (!logs.length) return null; return <div className="fixed bottom-5 right-5 z-[10000] w-80 space-y-2">{logs.slice(0, 2).map((log) => <div key={log.id} className="rounded-2xl border border-slate-200 bg-white p-4 text-sm shadow-2xl"><b>{log.label}</b><br/><span className="text-xs text-slate-500">Recorded at {log.at}</span></div>)}</div> }

function OpsModal({ modal, close, recordAction, hideEntity }: { modal: ModalState; close: () => void; recordAction: (label: string, action: string, entityId?: string | null) => void; hideEntity: (id: string, label: string) => void }) {
  if (modal.type === 'none') return null
  const title = modal.type === 'kpi' ? modal.item.label : modal.type === 'mission' ? `${modal.item.code} · ${modal.item.service}` : modal.type === 'zone' ? `${modal.item.name} operations` : modal.type === 'agent' ? modal.item.name : modal.type === 'incident' ? modal.item.title : modal.type === 'report' ? `${modal.item.mission} report validation` : modal.type === 'coverage' ? `${modal.item.zone} coverage` : modal.title
  const removable = modal.type === 'mission' || modal.type === 'incident' || modal.type === 'report' || modal.type === 'coverage' || modal.type === 'agent'
  const removableId = removable ? (modal.item as any).id : null
  return (
    <div className="fixed inset-0 z-[9999] grid place-items-center bg-slate-950/35 p-6 backdrop-blur-sm" onClick={close}>
      <div className="max-h-[92vh] w-full max-w-6xl overflow-auto rounded-[2.2rem] border border-slate-200 bg-white shadow-2xl" onClick={(event) => event.stopPropagation()}>
        <div className="sticky top-0 z-10 flex items-start justify-between gap-6 border-b border-slate-100 bg-white/95 p-6 backdrop-blur-xl"><div><p className="text-xs font-black uppercase tracking-[0.32em] text-blue-500">CareLink Ops Enterprise Workflow</p><h2 className="mt-2 text-3xl font-black">{title}</h2></div><button onClick={close} className="grid h-11 w-11 place-items-center rounded-full bg-slate-100 text-xl font-black">×</button></div>
        <div className="p-6">
          {modal.type === 'mission' ? <MissionModal item={modal.item} /> : null}
          {modal.type === 'incident' ? <IncidentModal item={modal.item} /> : null}
          {modal.type === 'report' ? <ReportModal item={modal.item} /> : null}
          {modal.type === 'coverage' ? <CoverageModal item={modal.item} /> : null}
          {modal.type === 'zone' ? <ZoneModal item={modal.item} /> : null}
          {modal.type === 'agent' ? <AgentModal item={modal.item} /> : null}
          {modal.type === 'kpi' ? <CommandContent detail={`${modal.item.value}${modal.item.suffix ? ` ${modal.item.suffix}` : ''} active records. Drill into ownership, SLA, operational risk, filtered boards, exports, and action queues.`} /> : null}
          {modal.type === 'command' ? <CommandContent detail={modal.detail} /> : null}
          <div className="mt-6 grid grid-cols-5 gap-3">
            <button onClick={() => recordAction('Opened full board', 'open_board', title)} className="rounded-2xl bg-slate-950 px-4 py-3 text-sm font-black text-white">Open board</button>
            <button onClick={() => recordAction('Assigned owner', 'assign_owner', title)} className="rounded-2xl border border-slate-200 px-4 py-3 text-sm font-black hover:bg-slate-50">Assign owner</button>
            <button onClick={() => recordAction('Escalation created', 'create_escalation', title)} className="rounded-2xl border border-orange-200 bg-orange-50 px-4 py-3 text-sm font-black text-orange-700">Escalate</button>
            <button onClick={() => { recordAction('Validated action', 'validate', title); close() }} className="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-black text-emerald-700">Validate</button>{removable && removableId ? <button onClick={() => hideEntity(String(removableId), title)} className="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-black text-rose-700">Remove from app</button> : null}
          </div>
        </div>
      </div>
    </div>
  )
}

function MissionModal({ item }: { item: MissionFlowItem }) { return <div className="grid gap-5 xl:grid-cols-[1.1fr_.9fr]"><section className="rounded-3xl border border-slate-200 p-5"><div className="flex items-center justify-between"><div><p className="text-xs font-black uppercase tracking-widest text-slate-400">Mission identity</p><h3 className="mt-2 text-2xl font-black">{item.code}</h3></div><RiskPill risk={item.risk} /></div><div className="mt-5 grid grid-cols-2 gap-3 text-sm"><Info label="Client" value={item.client} /><Info label="Beneficiary" value={item.beneficiary} /><Info label="Service" value={item.service} /><Info label="Schedule" value={`${item.time} – ${item.scheduledEnd}`} /><Info label="Address" value={item.address} /><Info label="Agent" value={item.assignee || 'Not assigned'} /></div><div className="mt-5"><p className="text-xs font-black uppercase tracking-widest text-slate-400">Operational instructions</p><ul className="mt-2 space-y-2 text-sm text-slate-600">{item.instructions.map((x) => <li key={x} className="rounded-2xl bg-slate-50 p-3">✓ {x}</li>)}</ul></div></section><section className="rounded-3xl border border-slate-200 p-5"><p className="text-xs font-black uppercase tracking-widest text-slate-400">Lifecycle & readiness</p><div className="mt-4 space-y-3">{item.lifecycle.map((step, index) => <div key={step} className="flex items-center gap-3"><span className="grid h-7 w-7 place-items-center rounded-full bg-emerald-50 text-xs font-black text-emerald-700">{index + 1}</span><span className="text-sm font-bold text-slate-700">{step}</span></div>)}</div><div className="mt-5 rounded-3xl bg-blue-50 p-4"><b>Readiness {item.readiness}%</b><div className="mt-2 h-2 overflow-hidden rounded-full bg-white"><span className="block h-full rounded-full bg-blue-600" style={{ width: `${item.readiness}%` }} /></div></div>{item.blockers.length ? <div className="mt-4 rounded-3xl bg-rose-50 p-4 text-sm text-rose-700"><b>Blockers</b>{item.blockers.map((b) => <p key={b}>• {b}</p>)}</div> : null}</section></div> }
function IncidentModal({ item }: { item: IncidentAlert }) { return <div className="grid grid-cols-3 gap-4"><InfoCard title="Severity" value={item.severity.toUpperCase()} tone={item.severity === 'critical' ? 'red' : 'orange'} /><InfoCard title="Owner" value={item.owner} /><InfoCard title="SLA" value={item.sla} /><section className="col-span-2 rounded-3xl border border-slate-200 p-5"><h3 className="font-black">Triage context</h3><p className="mt-3 text-sm leading-7 text-slate-600">{item.mission} · {item.zone}<br/>{item.detail}</p><p className="mt-4 rounded-2xl bg-slate-50 p-4 text-sm font-bold text-slate-600">Workflow: {item.workflow}</p></section><section className="rounded-3xl border border-slate-200 p-5"><h3 className="font-black">Available actions</h3><div className="mt-3 space-y-2">{item.actions.map((x) => <button key={x} className="w-full rounded-2xl border border-slate-200 px-3 py-2 text-left text-sm font-bold hover:bg-slate-50">{x}</button>)}</div></section></div> }
function ReportModal({ item }: { item: ReportRow }) { return <div className="grid grid-cols-[1fr_.8fr] gap-5"><section className="rounded-3xl border border-slate-200 p-5"><h3 className="font-black">Validation workflow</h3><div className="mt-4 grid grid-cols-2 gap-3 text-sm"><Info label="Mission" value={item.mission} /><Info label="Client" value={item.client} /><Info label="Caregiver" value={item.caregiver} /><Info label="Completed" value={item.completed} /><Info label="Issue" value={item.issue} /><Info label="SLA" value={item.sla} /></div><p className="mt-4 rounded-2xl bg-blue-50 p-4 text-sm font-bold text-blue-700">{item.workflow}</p></section><section className="rounded-3xl border border-slate-200 p-5"><h3 className="font-black">Report quality</h3><p className="mt-3 text-4xl font-black">{item.qualityScore}%</p><div className="mt-2 h-2 overflow-hidden rounded-full bg-slate-100"><span className={`block h-full rounded-full ${item.qualityScore < 60 ? 'bg-rose-500' : item.qualityScore < 80 ? 'bg-orange-500' : 'bg-emerald-500'}`} style={{ width: `${item.qualityScore}%` }} /></div><div className="mt-4 flex flex-wrap gap-2">{item.tags.map((tag) => <span key={tag} className="rounded-full bg-slate-100 px-3 py-1 text-xs font-black text-slate-600">{tag}</span>)}</div></section></div> }
function CoverageModal({ item }: { item: CoverageRow }) { return <CommandContent detail={`${item.zone} · ${item.date}. Capacity ${item.capacity}, utilization ${item.utilization}%. ${item.notes} Gaps: ${item.gaps.length ? item.gaps.join(', ') : 'No gap currently detected.'}`} /> }
function ZoneModal({ item }: { item: OpsCity | OpsZone }) { return <CommandContent detail={`${item.name} operations snapshot: ${item.missions} missions, ${item.agents} agents, ${item.atRisk} at-risk missions, ${item.coverage}% coverage. Use this view to assign backup agents, inspect sector load, and open zone-specific dispatch lanes.`} /> }
function AgentModal({ item }: { item: AgentReadiness }) { return <CommandContent detail={`${item.name} is ${item.status}. Readiness ${item.readiness}%, compliance ${item.compliance}, city ${item.city}, zone ${item.zone}. Skills: ${item.skills.join(', ')}. Next mission: ${item.nextMission || 'none'}.`} /> }
function CommandContent({ detail }: { detail: string }) { return <section className="rounded-3xl border border-slate-200 bg-slate-50 p-6 text-sm leading-7 text-slate-700">{detail}</section> }
function Info({ label, value }: { label: string; value: string }) { return <div className="rounded-2xl bg-slate-50 p-3"><p className="text-[10px] font-black uppercase tracking-widest text-slate-400">{label}</p><p className="mt-1 break-words text-sm font-bold leading-5 text-slate-800">{value}</p></div> }
function InfoCard({ title, value, tone = 'blue' }: { title: string; value: string; tone?: string }) { return <div className={`rounded-3xl border p-5 ${tone === 'red' ? 'border-rose-100 bg-rose-50 text-rose-700' : tone === 'orange' ? 'border-orange-100 bg-orange-50 text-orange-700' : 'border-blue-100 bg-blue-50 text-blue-700'}`}><p className="text-xs font-black uppercase tracking-widest opacity-70">{title}</p><p className="mt-2 text-xl font-black">{value}</p></div> }
