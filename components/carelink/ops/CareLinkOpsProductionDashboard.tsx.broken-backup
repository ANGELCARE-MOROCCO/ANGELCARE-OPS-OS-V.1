'use client'

import { useCallback, useEffect, useMemo, useRef, useState } from 'react'
import type { AgentReadiness, CoverageRow, IncidentAlert, MapViewMode, MissionFlowItem, OpsCity, OpsDashboardPayload, OpsKpi, OpsZone, ReportRow } from '../../../lib/carelink/ops-dashboard-data'

type ModalState =
  | { type: 'none' }
  | { type: 'kpi'; item: OpsKpi }
  | { type: 'mission'; item: MissionFlowItem }
  | { type: 'zone'; item: OpsZone | OpsCity }
  | { type: 'agent'; item: AgentReadiness }
  | { type: 'incident'; item: IncidentAlert }
  | { type: 'report'; item: ReportRow }
  | { type: 'coverage'; item: CoverageRow }
  | { type: 'command'; title: string; detail: string }

type ActionLog = { id: string; label: string; at: string }

declare global {
  interface Window { L?: any }
}

const fallbackPayload: OpsDashboardPayload = {
  ok: true,
  generatedAt: new Date().toISOString(),
  kpis: [],
  cities: [],
  zones: [],
  lanes: [],
  agents: [],
  incidents: [],
  reports: [],
  coverage: [],
  followUps: [],
}

const toneCard: Record<string, string> = {
  blue: 'border-blue-100 bg-gradient-to-br from-white to-blue-50/70 text-blue-700 shadow-blue-100/70',
  cyan: 'border-cyan-100 bg-gradient-to-br from-white to-cyan-50/70 text-cyan-700 shadow-cyan-100/70',
  green: 'border-emerald-100 bg-gradient-to-br from-white to-emerald-50/70 text-emerald-700 shadow-emerald-100/70',
  orange: 'border-orange-100 bg-gradient-to-br from-white to-orange-50/70 text-orange-700 shadow-orange-100/70',
  red: 'border-rose-100 bg-gradient-to-br from-white to-rose-50/70 text-rose-700 shadow-rose-100/70',
  purple: 'border-violet-100 bg-gradient-to-br from-white to-violet-50/70 text-violet-700 shadow-violet-100/70',
  slate: 'border-slate-100 bg-gradient-to-br from-white to-slate-50 text-slate-700 shadow-slate-100/70',
}

const laneSkin: Record<string, string> = {
  unassigned: 'border-slate-200 bg-slate-50/80',
  assigned: 'border-blue-200 bg-blue-50/70',
  accepted: 'border-indigo-200 bg-indigo-50/70',
  en_route: 'border-cyan-200 bg-cyan-50/70',
  in_progress: 'border-emerald-200 bg-emerald-50/80',
  report_pending: 'border-teal-200 bg-teal-50/80',
  validation: 'border-violet-200 bg-violet-50/70',
  at_risk: 'border-rose-200 bg-rose-50/80',
}

const zoneColors: Record<string, string> = {
  low: '#2563eb',
  moderate: '#10b981',
  high: '#f97316',
  'at-risk': '#ef4444',
}

function nowLabel() {
  return new Intl.DateTimeFormat('en-GB', { hour: '2-digit', minute: '2-digit', second: '2-digit' }).format(new Date())
}

function dayLabel(offset: number) {
  const base = new Date('2026-06-16T12:00:00')
  base.setDate(base.getDate() + offset)
  return new Intl.DateTimeFormat('en-GB', { weekday: 'short', day: '2-digit', month: 'short' }).format(base)
}

export default function CareLinkOpsProductionDashboard() {
  const [lastUpdated, setLastUpdated] = useState('')

  useEffect(() => {
    setLastUpdated(new Date().toLocaleTimeString('fr-FR'))
  }, [])

  const [payload, setPayload] = useState<OpsDashboardPayload>(fallbackPayload)
  const [loading, setLoading] = useState(true)
  const [lastUpdated, setLastUpdated] = useState(nowLabel())
  const [modal, setModal] = useState<ModalState>({ type: 'none' })
  const [query, setQuery] = useState('')
  const [logs, setLogs] = useState<ActionLog[]>([])
  const [activeNav, setActiveNav] = useState('Overview')
  const [missionFlowExpanded, setMissionFlowExpanded] = useState(false)
  const [mapMode, setMapMode] = useState<MapViewMode>('cities')
  const [selectedCity, setSelectedCity] = useState('rabat')
  const [dayOffset, setDayOffset] = useState(0)
  const [hiddenEntityIds, setHiddenEntityIds] = useState<string[]>([])

  useEffect(() => {
    try {
      const saved = window.localStorage.getItem('carelink-ops-hidden-entities')
      if (saved) setHiddenEntityIds(JSON.parse(saved))
    } catch {
      setHiddenEntityIds([])
    }
  }, [])

  const hideEntity = useCallback((id: string, label: string) => {
    setHiddenEntityIds((current) => {
      const next = Array.from(new Set([...current, id]))
      try { window.localStorage.setItem('carelink-ops-hidden-entities', JSON.stringify(next)) } catch {}
      return next
    })
    setLogs((current) => [{ id: `${Date.now()}`, label: `${label} removed from cockpit`, at: nowLabel() }, ...current].slice(0, 6))
    setModal({ type: 'none' })
  }, [])

  const restoreHiddenEntities = useCallback(() => {
    setHiddenEntityIds([])
    try { window.localStorage.removeItem('carelink-ops-hidden-entities') } catch {}
    setLogs((current) => [{ id: `${Date.now()}`, label: 'Restored removed cockpit items', at: nowLabel() }, ...current].slice(0, 6))
  }, [])

  const load = useCallback(async () => {
    setLoading(true)
    try {
      const res = await fetch('/api/carelink/ops/dashboard', { cache: 'no-store' })
      const json = (await res.json()) as OpsDashboardPayload
      setPayload(json?.ok ? json : fallbackPayload)
      setLastUpdated(nowLabel())
    } catch {
      setPayload(fallbackPayload)
      setLastUpdated(nowLabel())
    } finally {
      setLoading(false)
    }
  }, [])

  useEffect(() => { load() }, [load])

  const visiblePayload = useMemo<OpsDashboardPayload>(() => {
    const hidden = new Set(hiddenEntityIds)
    return {
      ...payload,
      lanes: ((payload as any).lanes || (payload as any).missionFlow || []).map((lane: any) => ({ ...lane, items: ((lane.items || lane.missions || []) as any[]).filter((item: any) => item?.id ? !hidden.has(item.id) : true) })),
      agents: (((payload as any).agents || []) as any[]).filter((item: any) => item?.id ? !hidden.has(item.id) : true),
      incidents: (((payload as any).incidents || []) as any[]).filter((item: any) => item?.id ? !hidden.has(item.id) : true),
      reports: (((payload as any).reports || []) as any[]).filter((item: any) => item?.id ? !hidden.has(item.id) : true),
      coverage: ((((payload as any).coverage || (payload as any).schedule?.rows || []) as any[])).filter((item: any) => item?.id ? !hidden.has(item.id) : true),
    }
  }, [payload, hiddenEntityIds])

  const recordAction = useCallback(async (label: string, action: string, entityId?: string | null) => {
    setLogs((current) => [{ id: `${Date.now()}`, label, at: nowLabel() }, ...current].slice(0, 6))
    try {
      await fetch('/api/carelink/ops/actions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, entityId }),
      })
    } catch {
      // UI remains responsive while persistence is being connected.
    }
  }, [])

  const filteredMissions = useMemo(() => {
    const q = query.trim().toLowerCase()
    const items = ((visiblePayload as any).lanes || []).flatMap((lane: any) => ((lane.items || []) as any[]).map((item: any) => ({ ...item, lane: lane.label })))
    if (!q) return items.slice(0, 8)
    return items.filter((item) => `${item.code} ${item.zone} ${item.city} ${item.service} ${item.client} ${item.assignee || ''}`.toLowerCase().includes(q)).slice(0, 8)
  }, [visiblePayload.lanes, query])

  return (
    <main className="min-h-screen bg-[#f6f8fb] text-slate-950">
      <div className="grid min-h-screen grid-cols-[236px_1fr]">
        <aside className="sticky top-0 h-screen border-r border-slate-200 bg-white/95 px-4 py-5 shadow-[12px_0_40px_rgba(15,23,42,0.04)]">
          <div className="flex items-center gap-3 px-1">
            <div className="grid h-11 w-11 place-items-center rounded-2xl bg-gradient-to-br from-blue-600 via-sky-500 to-cyan-300 text-sm font-black text-white shadow-lg shadow-blue-200">AC</div>
            <div>
              <p className="text-lg font-black tracking-tight">AngelCare</p>
              <p className="text-xs font-semibold text-slate-500">CareLink Ops</p>
            </div>
          </div>
          <nav className="mt-8 space-y-1">
            {[
              ['Overview', '▦'], ['Dispatch', '⌁'], ['Missions', '◇'], ['Agents', '♙'], ['Schedule', '□'], ['Incidents', '⚠'], ['Reports', '▤'], ['Compliance', '◇'], ['Settings', '⚙'],
            ].map(([label, icon]) => (
              <button
                key={label}
                onClick={() => {
                  setActiveNav(label)
                  recordAction(`Opened ${label}`, 'nav_open', label)
                  if (label !== 'Overview') setModal({ type: 'command', title: `${label} module`, detail: `This navigation opens the ${label} command context. Dedicated route can be wired at /carelink-ops/${label.toLowerCase()} while this cockpit keeps live operations continuity.` })
                }}
                className={`flex w-full items-center justify-between rounded-2xl px-3 py-3 text-left text-sm font-extrabold transition ${activeNav === label ? 'bg-blue-50 text-blue-700 ring-1 ring-blue-100' : 'text-slate-600 hover:bg-slate-50 hover:text-slate-950'}`}
              >
                <span className="flex items-center gap-3"><span className="text-base">{icon}</span>{label}</span>
                {label === 'Incidents' ? <span className="rounded-full bg-rose-500 px-2 py-0.5 text-[10px] font-black text-white">6</span> : null}
              </button>
            ))}
          </nav>
          <div className="absolute bottom-5 left-4 right-4 space-y-3">
            <div className="rounded-3xl border border-slate-200 bg-white p-4 shadow-sm">
              <p className="text-xs font-black uppercase tracking-widest text-slate-500">Live System Status</p>
              <div className="mt-3 space-y-3 text-xs">
                <p className="flex items-start gap-2"><span className="mt-1 h-2 w-2 rounded-full bg-emerald-500" /> <span><b>Platform</b><br /><span className="text-slate-500">All systems operational</span></span></p>
                <p className="flex items-start gap-2"><span className="mt-1 h-2 w-2 rounded-full bg-emerald-500" /> <span><b>Map / Dispatch</b><br /><span className="text-slate-500">OpenStreetMap + Ops data synced</span></span></p>
              </div>
              <button onClick={() => setModal({ type: 'command', title: 'System status', detail: 'Platform, map services, mission APIs, notification queue, and report validation services are operational. Last dashboard sync completed successfully.' })} className="mt-4 w-full rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-black hover:bg-slate-50">View status</button>
            </div>
            <div className="flex items-center gap-3 rounded-3xl border border-slate-200 bg-white p-3 text-xs text-slate-500">
              <div className="grid h-9 w-9 place-items-center rounded-xl bg-cyan-50 text-blue-600">⌂</div>
              <div><b className="text-blue-600">AngelCare</b> CareLink Ops<br />Enterprise Control v3.2</div>
            </div>
          </div>
        </aside>

        <section className="min-w-0">
          <header className="sticky top-0 z-20 border-b border-slate-200 bg-white/90 px-8 py-5 backdrop-blur-xl">
            <div className="flex items-center justify-between gap-6">
              <div>
                <h1 className="text-3xl font-black tracking-tight">CareLink Operations Control</h1>
                <p className="mt-1 text-sm font-medium text-slate-500">Enterprise dispatch cockpit for scheduled home-care, childcare, field agents, reports, and incidents.</p>
              </div>
              <div className="flex items-center gap-4">
                <p className="hidden text-sm font-bold text-slate-600 xl:block">Tuesday, June 16, 2026</p>
                <label className="relative flex h-11 w-[390px] items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 text-sm shadow-inner">
                  <span className="text-slate-400">⌕</span>
                  <input value={query} onChange={(event) => setQuery(event.target.value)} placeholder="Search missions, agents, clients, incidents..." className="w-full bg-transparent outline-none" />
                  <kbd className="rounded-md bg-white px-2 py-1 text-[10px] font-black text-slate-400 shadow-sm">⌘ K</kbd>
                </label>
                <button onClick={() => setModal({ type: 'command', title: 'Notifications', detail: '12 operational notifications: 2 critical incidents, 3 report escalations, 5 dispatch follow-ups, and 2 compliance alerts.' })} className="relative grid h-11 w-11 place-items-center rounded-2xl border border-slate-200 bg-white text-lg shadow-sm">♢<span className="absolute -right-1 -top-1 rounded-full bg-rose-500 px-1.5 text-[10px] font-black text-white">12</span></button>
                <button onClick={() => setModal({ type: 'command', title: 'Dispatch inbox', detail: '3 active dispatch threads require review: client absent, address issue, and report correction request.' })} className="relative grid h-11 w-11 place-items-center rounded-2xl border border-slate-200 bg-white text-lg shadow-sm">✉<span className="absolute -right-1 -top-1 rounded-full bg-rose-500 px-1.5 text-[10px] font-black text-white">3</span></button>
                <button onClick={() => setModal({ type: 'command', title: 'AngelCare Ops profile', detail: 'Operations Lead profile menu: account, command preferences, notification routing, and audit session.' })} className="flex items-center gap-3 rounded-2xl border border-slate-200 bg-white px-3 py-2 shadow-sm">
                  <span className="grid h-8 w-8 place-items-center rounded-full bg-gradient-to-br from-blue-600 to-cyan-300 text-xs font-black text-white">AC</span>
                  <span className="hidden text-left text-xs font-bold xl:block">AngelCare Ops<br/><span className="font-semibold text-slate-400">Operations Lead</span></span>
                </button>
              </div>
            </div>
            <div className="mt-3 flex justify-end gap-3 text-xs font-bold text-slate-500">
              <span suppressHydrationWarning>Last updated: {lastUpdated || '—'}</span>
              <button onClick={load} className="rounded-xl border border-slate-200 bg-white px-3 py-1.5 font-black text-slate-700 hover:bg-slate-50">↻ Refresh</button>{hiddenEntityIds.length ? <button onClick={restoreHiddenEntities} className="rounded-xl border border-rose-200 bg-rose-50 px-3 py-1.5 font-black text-rose-700 hover:bg-rose-100">Restore removed ({hiddenEntityIds.length})</button> : null}
            </div>
            {query ? <SearchResults items={filteredMissions} open={(item) => setModal({ type: 'mission', item })} /> : null}
          </header>

          <div className="space-y-5 p-7">
            <section className="grid grid-cols-8 gap-4">
              {((visiblePayload as any).kpis || []).map((kpi: any) => <KpiCard key={kpi.key} item={kpi} open={() => setModal({ type: 'kpi', item: kpi })} />)}
            </section>

            <section className="grid grid-cols-[34%_1fr] gap-5">
              <OperationsMap cities={visiblePayload.cities} zones={visiblePayload.zones} mode={mapMode} setMode={setMapMode} selectedCity={selectedCity} setSelectedCity={setSelectedCity} open={(item) => setModal({ type: 'zone', item })} />
              <DispatchFlow lanes={visiblePayload.lanes} expanded={missionFlowExpanded} setExpanded={setMissionFlowExpanded} openMission={(item) => setModal({ type: 'mission', item })} hideEntity={hideEntity} openAll={() => setModal({ type: 'command', title: 'Mission operations board', detail: 'Open the full mission operations board with SLA filters, city filters, agent assignment, batch escalation, and export actions.' })} />
            </section>

            <section className="grid grid-cols-[32%_1fr_27%] gap-5">
              <AgentReadinessPanel agents={visiblePayload.agents} open={(item) => setModal({ type: 'agent', item })} hideEntity={hideEntity} />
              <ScheduleCoveragePanel coverage={visiblePayload.coverage} dayOffset={dayOffset} setDayOffset={setDayOffset} open={(item) => setModal({ type: 'coverage', item })} hideEntity={hideEntity} />
              <IncidentsPanel incidents={visiblePayload.incidents} open={(item) => setModal({ type: 'incident', item })} hideEntity={hideEntity} />
            </section>

            <section className="grid grid-cols-[1fr_27%] gap-5">
              <ReportsPanel reports={visiblePayload.reports} open={(item) => setModal({ type: 'report', item })} hideEntity={hideEntity} />
              <FollowUpPanel followUps={visiblePayload.followUps} open={(title, detail) => setModal({ type: 'command', title, detail })} />
            </section>
          </div>
        </section>
      </div>
      {loading ? <div className="fixed right-6 top-24 rounded-2xl border border-blue-100 bg-white px-4 py-3 text-sm font-black text-blue-700 shadow-xl">Syncing CareLink Ops…</div> : null}
      <ActionToast logs={logs} />
      <OpsModal modal={modal} close={() => setModal({ type: 'none' })} recordAction={recordAction} hideEntity={hideEntity} />
    </main>
  )
}

function KpiCard({ item, open }: { item: OpsKpi; open: () => void }) {
  return (
    <button onClick={open} className={`rounded-3xl border p-4 text-left shadow-sm transition hover:-translate-y-0.5 hover:shadow-xl ${toneCard[item.tone] || toneCard.slate}`}>
      <div className="flex items-start justify-between gap-2">
        <span className="grid h-10 w-10 place-items-center rounded-2xl bg-white/80 text-lg shadow-sm">●</span>
        <span className="rounded-full bg-white/80 px-2 py-1 text-[10px] font-black text-slate-500">{item.delta || 'Live'}</span>
      </div>
      <p className="mt-3 text-xs font-black uppercase tracking-wider text-slate-500">{item.label}</p>
      <p className="mt-1 text-3xl font-black text-slate-950">{item.value}<span className="ml-1 text-sm font-black text-slate-400">{item.suffix}</span></p>
      <p className="mt-2 text-xs font-extrabold">{item.helper}</p>
    </button>
  )
}

function SearchResults({ items, open }: { items: Array<MissionFlowItem & { lane: string }>; open: (item: MissionFlowItem) => void }) {
  return (
    <div className="absolute right-8 top-[90px] z-30 w-[560px] rounded-3xl border border-slate-200 bg-white p-3 shadow-2xl">
      <p className="px-3 py-2 text-xs font-black uppercase tracking-widest text-slate-400">Search results</p>
      {items.map((item) => <button key={item.id} onClick={() => open(item)} className="grid w-full grid-cols-[1fr_auto] items-center gap-4 rounded-2xl px-3 py-3 text-left hover:bg-slate-50"><span><b>{item.code}</b><br /><span className="text-xs text-slate-500">{item.client} · {item.zone} · {item.service}</span></span><span className="rounded-full bg-blue-50 px-3 py-1 text-xs font-black text-blue-700">{item.lane}</span></button>)}
    </div>
  )
}

function OperationsMap({ cities, zones, mode, setMode, selectedCity, setSelectedCity, open }: { cities: OpsCity[]; zones: OpsZone[]; mode: MapViewMode; setMode: (mode: MapViewMode) => void; selectedCity: string; setSelectedCity: (city: string) => void; open: (item: OpsCity | OpsZone) => void }) {
  const mapRef = useRef<HTMLDivElement | null>(null)
  const mapInstance = useRef<any>(null)
  const layerRef = useRef<any[]>([])
  const safeCities = Array.isArray(cities) ? cities : []
  const safeZones = Array.isArray(zones) ? zones : []
  const selected = safeCities.find((city: any) => city.id === selectedCity) || safeCities[0]
  const visibleZones = mode === 'zones' && selected ? zones.filter((zone) => zone.cityId === selected.id) : zones

  useEffect(() => {
    if (!mapRef.current || mapInstance.current) return
    const loadLeaflet = async () => {
      if (!document.querySelector('link[data-carelink-leaflet]')) {
        const link = document.createElement('link')
        link.rel = 'stylesheet'
        link.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css'
        link.setAttribute('data-carelink-leaflet', 'true')
        document.head.appendChild(link)
      }
      if (!window.L) {
        await new Promise<void>((resolve, reject) => {
          const script = document.createElement('script')
          script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'
          script.onload = () => resolve()
          script.onerror = () => reject(new Error('Leaflet failed to load'))
          document.body.appendChild(script)
        })
      }
      if (!mapRef.current || !window.L || mapInstance.current) return
      const L = window.L
      const map = L.map(mapRef.current, { zoomControl: true, scrollWheelZoom: true, dragging: true }).setView([33.92, -6.93], 8)
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', { attribution: '&copy; OpenStreetMap contributors', maxZoom: 18 }).addTo(map)
      mapInstance.current = map
    }
    loadLeaflet().catch(() => undefined)
  }, [])

  useEffect(() => {
    const L = window.L
    const map = mapInstance.current
    if (!L || !map) return
    layerRef.current.forEach((layer) => map.removeLayer(layer))
    layerRef.current = []

    if (mode === 'cities') {
      cities.forEach((city) => {
        const color = zoneColors[city.load]
        const marker = L.circleMarker(city.center, { radius: 18, color, weight: 3, fillColor: color, fillOpacity: 0.22 }).addTo(map)
        const label = L.divIcon({ html: `<button style="border:0;background:white;border-radius:18px;padding:8px 11px;box-shadow:0 14px 34px rgba(15,23,42,.18);font-family:Inter,system-ui;cursor:pointer"><b style="color:${color};font-size:13px">${city.name}</b><br/><span style="font-size:11px;color:#475569">${city.missions} missions · ${city.coverage}%</span></button>`, className: 'carelink-city-marker', iconSize: [130, 54], iconAnchor: [65, 27] })
        const labelMarker = L.marker(city.center, { icon: label }).addTo(map)
        marker.on('click', () => { setSelectedCity(city.id); open(city) })
        labelMarker.on('click', () => { setSelectedCity(city.id); open(city) })
        layerRef.current.push(marker, labelMarker)
      })
      map.setView([33.92, -6.93], 7)
    } else if (selected) {
      selected.sectors.forEach((zone) => {
        const color = zoneColors[zone.load]
        const polygon = L.polygon(zone.polygon, { color, fillColor: color, fillOpacity: 0.15, weight: 3 }).addTo(map)
        polygon.on('click', () => open(zone))
        const icon = L.divIcon({ html: `<button style="border:0;background:#fff;border-radius:16px;padding:7px 10px;box-shadow:0 10px 30px rgba(15,23,42,.18);font-family:Inter,system-ui;cursor:pointer"><b style="color:${color};font-size:13px">${zone.name}</b><br/><span style="font-size:11px;color:#475569">${zone.missions} · ${zone.atRisk} risk</span></button>`, className: 'carelink-zone-marker', iconSize: [112, 52], iconAnchor: [56, 26] })
        const marker = L.marker(zone.center, { icon }).addTo(map).on('click', () => open(zone))
        layerRef.current.push(polygon, marker)
      })
      map.setView(selected.center, selected.zoom)
    }
  }, [cities, zones, selected, selectedCity, mode, open, setSelectedCity])

  return (
    <section className="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
      <div className="flex items-center justify-between border-b border-slate-100 px-5 py-4">
        <div>
          <h2 className="font-black">Morocco Operations Map</h2>
          <p className="text-xs font-bold text-slate-500">Free OpenStreetMap · real Moroccan city/sector structure · synced with ops payload</p>
        </div>
        <span className="rounded-full bg-emerald-50 px-3 py-1 text-xs font-black text-emerald-700">● Live</span>
      </div>
      <div className="flex flex-wrap items-center gap-2 border-b border-slate-100 px-5 py-3">
        <Segment active={mode === 'cities'} onClick={() => setMode('cities')}>Cities</Segment>
        <Segment active={mode === 'zones'} onClick={() => setMode('zones')}>Zones by city</Segment>
        <select value={selectedCity} onChange={(event) => { setSelectedCity(event.target.value); setMode('zones') }} className="ml-auto rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-black outline-none">
          {safeCities.map((city: any) => <option key={city.id} value={city.id}>{city.name} · {city.region}</option>)}
        </select>
      </div>
      <div className="relative h-[324px] bg-slate-100">
        <div ref={mapRef} className="relative z-0 h-full w-full [&_.leaflet-control-container]:z-[20] [&_.leaflet-pane]:z-[1] [&_.leaflet-top]:z-[20] [&_.leaflet-bottom]:z-[20]" />
