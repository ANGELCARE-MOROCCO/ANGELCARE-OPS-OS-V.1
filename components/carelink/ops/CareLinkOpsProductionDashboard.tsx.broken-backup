          <p className="text-xs font-bold text-slate-500">Expandable enterprise flow lanes with SLA/risk/readiness indicators. Use +more or lane expand to open real content.</p>
        </div>
        <div className="flex gap-2">
          <button onClick={() => { setExpanded(!expanded); if (expanded) setExpandedLane(null) }} className="rounded-2xl border border-slate-200 bg-white px-3 py-2 text-xs font-black hover:bg-slate-50">{expanded ? 'Retract lanes' : 'Expand all lanes'}</button>
          <button onClick={openAll} className="rounded-2xl bg-blue-600 px-3 py-2 text-xs font-black text-white shadow-lg shadow-blue-100">View all missions →</button>
