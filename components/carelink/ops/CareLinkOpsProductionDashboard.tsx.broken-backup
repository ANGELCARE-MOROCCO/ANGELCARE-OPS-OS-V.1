            return <div key={lane.key} className={`rounded-3xl border p-3 transition-all ${laneOpen ? 'min-h-[520px]' : 'min-h-[278px]'} ${laneSkin[lane.key] || 'bg-slate-50'}`}>
              <div className="flex items-center justify-between gap-2">
                <p className="truncate text-[11px] font-black uppercase tracking-wide text-slate-600">{lane.label}</p>
                <button onClick={() => setExpandedLane(laneOpen ? null : lane.key)} className="shrink-0 rounded-full bg-white px-2 py-0.5 text-[10px] font-black text-slate-500 shadow-sm">{lane.count}</button>
              </div>
              <div className="mt-3 space-y-2">
                {items.map((item: MissionFlowItem) => <div key={item.id} className="group rounded-2xl border border-white/80 bg-white p-2.5 text-xs shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg">
                  <button onClick={() => openMission(item)} className="w-full text-left">
                    <div className="flex items-center justify-between gap-2 font-black"><span className="truncate">{item.code}</span><span className="shrink-0">{item.time}</span></div>
                    <p className="mt-1 truncate text-[12px] font-extrabold text-slate-700" title={item.client}>{item.client}</p>
                    <p className="line-clamp-2 text-[11px] leading-4 text-slate-500" title={`${item.zone} · ${item.service}`}>{item.zone} · {item.service}</p>
                    <div className="mt-2 flex items-center justify-between gap-2"><RiskPill risk={item.risk} /><span className="text-[10px] font-black text-slate-500">Ready {item.readiness}%</span></div>
                    {item.delay ? <p className={`mt-2 text-right text-[11px] font-black ${item.delay.includes('late') || item.delay.includes('absent') || item.delay.includes('Client') ? 'text-rose-600' : 'text-emerald-600'}`}>{item.delay}</p> : null}
                  </button>
                  <div className="mt-2 hidden grid-cols-2 gap-2 group-hover:grid">
                    <button onClick={() => openMission(item)} className="rounded-xl bg-slate-950 px-2 py-1.5 text-[10px] font-black text-white">Open</button>
                    <button onClick={() => hideEntity(item.id, item.code)} className="rounded-xl border border-rose-200 bg-rose-50 px-2 py-1.5 text-[10px] font-black text-rose-700">Remove</button>
                  </div>
                </div>)}
                {lane.count > items.length ? <button onClick={() => { setExpandedLane(lane.key); setExpanded(true) }} className="w-full rounded-2xl border border-dashed border-slate-300 bg-white/70 px-3 py-3 text-xs font-black text-slate-500 hover:border-blue-300 hover:bg-blue-50 hover:text-blue-700">+{lane.count - items.length} more · expand lane</button> : null}
                {!items.length ? <div className="rounded-2xl border border-dashed border-slate-200 bg-white/60 p-4 text-center text-xs font-bold text-slate-400">No visible missions in this lane</div> : null}
              </div>
            </div>
          })}
        </div>
      </div>
    </section>
  )
}

function AgentReadinessPanel({ agents, open, hideEntity }: { agents: AgentReadiness[]; open: (item: AgentReadiness) => void; hideEntity: (id: string, label: string) => void }) {
  return <Panel title="Agent Readiness" helper="Live" action="View all agents →"> <div className="space-y-2">{agents.map((agent) => <div key={agent.id} className="group grid w-full grid-cols-[1.1fr_76px_1fr_96px_28px] items-center gap-2 rounded-2xl border border-transparent px-2 py-2.5 text-left text-xs hover:border-slate-100 hover:bg-slate-50"><button onClick={() => open(agent)} className="contents"><span className="flex items-center gap-2"><span className="grid h-8 w-8 place-items-center rounded-full bg-blue-50 text-blue-700 font-black">{agent.name[0]}</span><span><b>{agent.name}</b><br/><span className="text-slate-400">{agent.city} · {agent.zone}</span></span></span><span><b>{agent.readiness}%</b><span className="mt-1 block h-1.5 overflow-hidden rounded-full bg-slate-100"><span className="block h-full rounded-full bg-emerald-500" style={{ width: `${agent.readiness}%` }} /></span></span><span className="truncate text-slate-500">{agent.skills.join(', ')}</span><Pill tone={agent.compliance === 'Docs Expiring' ? 'orange' : agent.compliance === 'Blocked' ? 'red' : 'green'}>{agent.compliance}</Pill></button><button onClick={() => hideEntity(agent.id, agent.name)} title="Remove from cockpit" className="hidden h-7 w-7 place-items-center rounded-full bg-rose-50 text-xs font-black text-rose-600 group-hover:grid">×</button></div>)}</div><p className="mt-3 text-xs font-bold text-slate-400">+18 more agents · click any profile for operational passport</p></Panel>
}

function ScheduleCoveragePanel({ coverage, dayOffset, setDayOffset, open, hideEntity }: { coverage: CoverageRow[]; dayOffset: number; setDayOffset: (value: number) => void; open: (item: CoverageRow) => void; hideEntity: (id: string, label: string) => void }) {
