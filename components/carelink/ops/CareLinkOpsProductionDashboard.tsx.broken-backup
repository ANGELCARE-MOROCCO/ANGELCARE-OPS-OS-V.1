        <div className={`grid gap-3 ${expanded ? 'min-w-[1380px] grid-cols-8' : 'min-w-[1120px] grid-cols-8'}`}>
          {lanes.map((lane) => {
            const laneOpen = expanded || expandedLane === lane.key
