function Legend({ color, label }: { color: string; label: string }) { return <span className="flex items-center gap-2"><span className={`h-2.5 w-2.5 rounded-full ${color}`} />{label}</span> }

function DispatchFlow({ lanes, expanded, setExpanded, openMission, openAll, hideEntity }: { lanes: any[]; expanded: boolean; setExpanded: (value: boolean) => void; openMission: (item: MissionFlowItem) => void; openAll: () => void; hideEntity: (id: string, label: string) => void }) {
  const [expandedLane, setExpandedLane] = useState<string | null>(null)
  return (
    <section className="rounded-[2rem] border border-slate-200 bg-white p-4 shadow-sm">
      <div className="mb-4 flex items-center justify-between gap-3">
