+function missionOrderValue(row: Record<string, unknown>, fallback: number) {
+  const raw = row.sort_order ?? row.line_order ?? row.order ?? row.occurrence_index ?? fallback
+  const parsed = Number(raw)
+  return Number.isFinite(parsed) ? parsed : fallback
+}
+
+function sortMissionOrderRows<T extends Record<string, unknown>>(rows: T[] | null | undefined): T[] {
+  return [...(rows || [])].sort((a, b) => missionOrderValue(a, 0) - missionOrderValue(b, 0))
+}
+
+async function safeMissionOrderRows(supabase: Awaited<ReturnType<typeof createClient>>, table: string, missionIds: number[]) {
+  const ids = [...new Set(missionIds.filter((id) => Number.isSafeInteger(id) && id > 0))]
+  if (!ids.length) return []
+  const query = supabase.from(table).select('*')
+  const { data, error } = ids.length === 1 ? await query.eq('mission_id', ids[0]) : await query.in('mission_id', ids)
+  if (error) {
+    console.warn(`[CareLink mission dossier] ${table} load skipped: ${error.message}`)
+    return []
+  }
+  return sortMissionOrderRows((data || []) as Record<string, unknown>[])
+}
+
+async function safeMissionOrderSingleRows(supabase: Awaited<ReturnType<typeof createClient>>, table: string, missionIds: number[]) {
+  return safeMissionOrderRows(supabase, table, missionIds)
+}
+
+function firstByMissionPriority<T extends Record<string, unknown>>(rows: T[], priorityIds: number[]): T | null {
+  for (const missionId of priorityIds) {
+    const match = rows.find((row) => Number(row.mission_id) === missionId)
+    if (match) return match
+  }
+  return rows[0] || null
+}
