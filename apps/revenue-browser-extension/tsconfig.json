{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": [
      "ES2022",
      "DOM",
      "WebWorker",
      "DOM.Iterable"
    ],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "rootDir": "src",
    "outDir": ".build",
    "noEmitOnError": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.json"
  ]
}
