{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "next-env.d.ts",
    "app/(protected)/revenue-command-os/**/*.ts",
    "app/(protected)/revenue-command-os/**/*.tsx",
    "app/api/revenue-command-os/**/*.ts",
    "lib/revenue-command-os/**/*.ts",
    "lib/auth/requireAccess.ts",
    "lib/getUser.ts",
    "lib/supabase/server.ts",
    "lib/supabase/env.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "backups",
    "_archive"
  ]
}
