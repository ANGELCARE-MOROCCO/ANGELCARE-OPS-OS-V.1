  ['⌂', 'Command Center', '/academy'],
  ['👥', 'Trainees', '/academy/trainees'],
  ['▣', 'Enrollments', '/academy/enrollments'],
  ['◴', 'Attendance', '/academy/attendance'],
  ['▰', 'Payments', '/academy/payments'],
  ['♢', 'Certificates', '/academy/certificates'],
  ['♟', 'Trainers', '/academy/trainers'],
  ['▤', 'Programs', '/academy/programs'],
  ['✦', 'Job Placement', '/academy/job-placement'],
  ['♡', 'Partners & Employers', '/academy/partners-employers'],
  ['◂', 'Announcements', '/academy/announcements'],
  ['▥', 'Reports & Analytics', '/academy/reports'],
  ['◇', 'Integrations', '/academy/integrations'],
  ['⚙', 'Automation', '/academy/automation'],
  ['⚙', 'Settings', '/academy/settings'],
]

const palette = ['#6d5dfc', '#2f80ed', '#16a34a', '#f59e0b', '#ef4444', '#14b8a6', '#8b5cf6']

function textOf(value: any, fallback = '—') {
  if (value === null || value === undefined || String(value).trim() === '') return fallback
  return String(value)
}

function nameOf(trainer: Trainer) {
  return textOf(trainer.full_name || trainer.name, 'Unnamed Trainer')
}

function initials(value: string) {
  return value.split(/\s+/).filter(Boolean).slice(0, 2).map((part) => part[0]?.toUpperCase()).join('') || 'TR'
}

function asArray<T = any>(value: any): T[] {
  if (!value) return []
  if (Array.isArray(value)) return value
  if (typeof value === 'string') return value.split(',').map((item) => item.trim()).filter(Boolean) as T[]
  return []
}

function toNumber(value: any, fallback = 0) {
  const parsed = Number(value)
  return Number.isFinite(parsed) ? parsed : fallback
}

function pct(value: any) {
  return Math.max(0, Math.min(100, Math.round(toNumber(value, 0))))
}

function dateKey(date: Date) {
  return date.toISOString().slice(0, 10)
}

function parseDate(value?: string) {
  if (!value) return null
  const date = new Date(value)
  return Number.isNaN(date.getTime()) ? null : date
}

function startOfWeek(date: Date) {
  const copy = new Date(date)
  const day = copy.getDay() || 7
  copy.setDate(copy.getDate() - day + 1)
  copy.setHours(0, 0, 0, 0)
  return copy
}

function addDays(date: Date, days: number) {
  const copy = new Date(date)
  copy.setDate(copy.getDate() + days)
  return copy
}

function formatTime(value?: string) {
  const date = parseDate(value)
  if (!date) return '—'
  return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
}

function formatDay(value?: string) {
  const date = parseDate(value)
  if (!date) return '—'
  return date.toLocaleDateString([], { month: 'short', day: '2-digit' })
}

function normalizePayload(raw: any): { trainers: Trainer[]; assignments: Assignment[] } {
  const trainers = raw?.trainers || raw?.data || raw?.items || raw?.records || []
  const assignments = raw?.assignments || raw?.sessions || raw?.dispatches || []
  return { trainers: Array.isArray(trainers) ? trainers : [], assignments: Array.isArray(assignments) ? assignments : [] }
}

function assignmentStart(item: Assignment) {
  return item.start_time || item.start_at || item.start_date || item.date
}

function assignmentEnd(item: Assignment) {
  return item.end_time || item.end_at || item.end_date || item.start_time || item.date
}

function assignmentTitle(item: Assignment) {
  return textOf(item.title || item.program_title || item.cohort_title, 'Training Session')
}

function belongsToTrainer(item: Assignment, trainer: Trainer) {
  return String(item.trainer_id || '') === String(trainer.id) || textOf(item.trainer_name, '') === nameOf(trainer)
}

function calcLoad(trainer: Trainer) {
  const explicit = trainer.utilization_percent ?? trainer.current_load
  return pct(explicit)
}

function isAvailable(trainer: Trainer) {
  const status = textOf(trainer.status, '').toLowerCase()
  return status.includes('available') || status.includes('active') || status.includes('ready')
}

function statusTone(trainer: Trainer) {
  const load = calcLoad(trainer)
  const status = textOf(trainer.status, '').toLowerCase()
  if (status.includes('leave') || status.includes('unavailable') || status.includes('inactive')) return 'danger'
  if (load >= 90) return 'danger'
  if (load >= 75) return 'warn'
  if (isAvailable(trainer)) return 'success'
  return 'neutral'
}

function buildExportRows(trainers: Trainer[]) {
  const header = ['Name', 'Email', 'Mobile', 'Status', 'Specialty', 'Readiness', 'Utilization', 'Dispatch Score']
  const rows = trainers.map((t) => [
    nameOf(t), textOf(t.email, ''), textOf(t.mobile, ''), textOf(t.status, ''), textOf(t.main_specialty || t.specialty, ''),
    String(pct(t.readiness_score)), String(calcLoad(t)), String(toNumber(t.dispatch_score, 0)),
  ])
  return [header, ...rows].map((row) => row.map((cell) => `"${String(cell).replaceAll('"', '""')}"`).join(',')).join('\n')
}

const emptyTrainer: Partial<Trainer> = {
  full_name: '',
  email: '',
  mobile: '',
  professional_title: 'Registered Trainer',
  gender: '',
  city: '',
  languages: [],
  bio: '',
  employment_type: 'internal',
  status: 'available',
  seniority_level: 'senior',
  main_specialty: 'General Training',
  secondary_specialties: ['Soft Skills', 'Leadership', 'Communication'],
  readiness_score: 0,
  dispatch_score: 0,
  utilization_percent: 0,
  weekly_capacity: 40,
  docs_verified: 0,
  docs_required: 5,
}

export default function AcademyTrainersClient() {
  const [trainers, setTrainers] = useState<Trainer[]>([])
  const [assignments, setAssignments] = useState<Assignment[]>([])
  const [loading, setLoading] = useState(true)
  const [saving, setSaving] = useState(false)
  const [query, setQuery] = useState('')
  const [availabilityFilter, setAvailabilityFilter] = useState('all')
  const [specialtyFilter, setSpecialtyFilter] = useState('all')
  const [loadFilter, setLoadFilter] = useState('all')
  const [viewMode, setViewMode] = useState<ViewMode>('day')
  const [focusDate, setFocusDate] = useState(() => new Date())
  const [selectedTrainer, setSelectedTrainer] = useState<Trainer | null>(null)
  const [modalMode, setModalMode] = useState<ModalMode | null>(null)
  const [draft, setDraft] = useState<Partial<Trainer>>(emptyTrainer)
  const [activeStep, setActiveStep] = useState(1)
  const [selectedWorkload, setSelectedWorkload] = useState<Trainer | null>(null)

  async function load() {
    setLoading(true)
    try {
      const [trainerRes, assignmentRes] = await Promise.all([
        fetch(API_TRAINERS, { cache: 'no-store' }),
        fetch(API_ASSIGNMENTS, { cache: 'no-store' }).catch(() => null),
      ])
      const trainerJson = await trainerRes.json().catch(() => ({}))
      const assignmentJson = assignmentRes ? await assignmentRes.json().catch(() => ({})) : {}
      const normalized = normalizePayload(trainerJson)
      setTrainers(normalized.trainers)
      setAssignments([...(normalized.assignments || []), ...asArray<Assignment>(assignmentJson.assignments || assignmentJson.data || assignmentJson.items)])
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => { load() }, [])

  const todayKey = dateKey(focusDate)
  const weekStart = useMemo(() => startOfWeek(focusDate), [focusDate])
  const weekDays = useMemo(() => Array.from({ length: 7 }, (_, i) => addDays(weekStart, i)), [weekStart])
  const monthDays = useMemo(() => {
    const first = new Date(focusDate.getFullYear(), focusDate.getMonth(), 1)
    const total = new Date(focusDate.getFullYear(), focusDate.getMonth() + 1, 0).getDate()
    return Array.from({ length: total }, (_, index) => new Date(focusDate.getFullYear(), focusDate.getMonth(), index + 1))
  }, [focusDate])

  const filteredTrainers = useMemo(() => {
    const search = query.toLowerCase().trim()
    return trainers.filter((trainer) => {
      const haystack = [nameOf(trainer), trainer.email, trainer.mobile, trainer.city, trainer.main_specialty, trainer.specialty, asArray(trainer.languages).join(' '), asArray(trainer.secondary_specialties).join(' ')].join(' ').toLowerCase()
      if (search && !haystack.includes(search)) return false
      if (availabilityFilter !== 'all') {
        const available = isAvailable(trainer)
        if (availabilityFilter === 'available' && !available) return false
        if (availabilityFilter === 'busy' && available) return false
      }
      if (specialtyFilter !== 'all' && textOf(trainer.main_specialty || trainer.specialty, '').toLowerCase() !== specialtyFilter) return false
      if (loadFilter !== 'all') {
        const load = calcLoad(trainer)
        if (loadFilter === 'high' && load < 75) return false
        if (loadFilter === 'normal' && (load < 35 || load >= 75)) return false
        if (loadFilter === 'low' && load >= 35) return false
      }
      return true
    })
  }, [trainers, query, availabilityFilter, specialtyFilter, loadFilter])

  const specialties = useMemo(() => Array.from(new Set(trainers.map((t) => textOf(t.main_specialty || t.specialty, 'General Training')).filter(Boolean))), [trainers])

  const todayAssignments = useMemo(() => assignments.filter((assignment) => {
    const start = parseDate(assignmentStart(assignment))
    return start && dateKey(start) === todayKey
  }), [assignments, todayKey])

  const upcomingAssignments = useMemo(() => assignments
    .filter((assignment) => {
      const start = parseDate(assignmentStart(assignment))
      return start && start >= new Date(new Date().setHours(0, 0, 0, 0))
    })
    .sort((a, b) => Number(parseDate(assignmentStart(a))) - Number(parseDate(assignmentStart(b))))
    .slice(0, 8), [assignments])

  const stats = useMemo(() => {
    const active = trainers.filter((t) => !textOf(t.status, '').toLowerCase().includes('inactive')).length
    const available = trainers.filter(isAvailable).length
    const assignedToday = new Set(todayAssignments.map((a) => String(a.trainer_id || a.trainer_name || ''))).size
    const upcoming = upcomingAssignments.length
    const coverageRate = upcoming ? Math.round((upcoming / Math.max(1, upcoming + Math.max(0, available - assignedToday))) * 100) : 0
    const avgLoad = trainers.length ? Math.round(trainers.reduce((sum, t) => sum + calcLoad(t), 0) / trainers.length) : 0
    const gaps = Math.max(0, upcomingAssignments.filter((a) => !a.trainer_id && !a.trainer_name).length + trainers.filter((t) => calcLoad(t) >= 90).length)
    return { active, available, assignedToday, upcoming, coverageRate, avgLoad, gaps }
  }, [trainers, todayAssignments, upcomingAssignments])

  const alerts = useMemo(() => {
    const list: { title: string; detail: string; severity: 'high' | 'medium' | 'low' }[] = []
    trainers.filter((t) => calcLoad(t) >= 90).slice(0, 3).forEach((t) => list.push({ title: `${nameOf(t)} workload above 90%`, detail: 'Review assignments and rebalance load.', severity: 'high' }))
    upcomingAssignments.filter((a) => !a.trainer_id && !a.trainer_name).slice(0, 3).forEach((a) => list.push({ title: `${assignmentTitle(a)} needs trainer coverage`, detail: `${formatDay(assignmentStart(a))} · ${formatTime(assignmentStart(a))}`, severity: 'high' }))
    trainers.filter((t) => pct(t.readiness_score) < 40).slice(0, 3).forEach((t) => list.push({ title: `${nameOf(t)} readiness incomplete`, detail: 'Profile, documents or compliance need review.', severity: 'medium' }))
    return list.slice(0, 6)
  }, [trainers, upcomingAssignments])

  function openCreate() {
    setDraft({ ...emptyTrainer, reference_number: `TRN-${new Date().getFullYear()}-${Math.floor(10000 + Math.random() * 89999)}` })
    setSelectedTrainer(null)
    setModalMode('create')
    setActiveStep(1)
  }

  function openTrainer(trainer: Trainer, mode: ModalMode = 'view') {
    setSelectedTrainer(trainer)
    setDraft({ ...trainer })
    setModalMode(mode)
    setActiveStep(1)
  }

  function closeModal() {
    setModalMode(null)
    setSelectedTrainer(null)
    setDraft(emptyTrainer)
  }

  function changeDraft(key: string, value: any) {
    setDraft((current) => ({ ...current, [key]: value }))
  }

  async function saveTrainer(asDraft = false) {
    setSaving(true)
    try {
      const payload = { ...draft, save_as_draft: asDraft, status: asDraft ? 'draft' : draft.status || 'available' }
      const isEdit = modalMode === 'edit' && selectedTrainer?.id
      const url = isEdit ? `${API_TRAINERS}/${selectedTrainer.id}` : API_TRAINERS
      const res = await fetch(url, {
        method: isEdit ? 'PATCH' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      })
      const json = await res.json().catch(() => ({}))
      if (!res.ok || json.ok === false) throw new Error(json.error || 'Unable to save trainer')
      await load()
      const record = json.data || json.trainer || json.record
      if (record) openTrainer(record, 'view')
      else closeModal()
    } catch (error: any) {
      alert(error?.message || 'Unable to save trainer')
    } finally {
      setSaving(false)
    }
  }

  async function assignTrainer(trainer: Trainer) {
    const title = prompt(`Assignment title for ${nameOf(trainer)}`)
    if (!title) return
    const start = prompt('Start date/time ISO or YYYY-MM-DD HH:mm', `${dateKey(new Date())} 09:00`)
    if (!start) return
    const end = prompt('End date/time ISO or YYYY-MM-DD HH:mm', `${dateKey(new Date())} 12:00`)
    try {
      const res = await fetch(API_ASSIGNMENTS, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ trainer_id: trainer.id, trainer_name: nameOf(trainer), title, start_time: start, end_time: end, status: 'assigned' }),
      })
      const json = await res.json().catch(() => ({}))
      if (!res.ok || json.ok === false) throw new Error(json.error || 'Assignment failed')
      await load()
    } catch (error: any) {
      alert(error?.message || 'Assignment failed')
    }
  }

  function exportCsv() {
    const blob = new Blob([buildExportRows(filteredTrainers)], { type: 'text/csv;charset=utf-8;' })
    const url = URL.createObjectURL(blob)
    const a = document.createElement('a')
    a.href = url
    a.download = `academy-trainers-${dateKey(new Date())}.csv`
    a.click()
    URL.revokeObjectURL(url)
  }

  return (
    <div className="trainerShell">
      <AcademySidebar />
      <main className="trainerMain">
        <section className="trainerHeader">
          <div>
            <div className="breadcrumbs">Home › Trainers › Dispatch</div>
            <h1>Trainers Dispatch & Management</h1>
            <p>Real-time command center for trainer operations, availability, load balancing and live assignments.</p>
          </div>
          <div className="headerActions">
            <div className="searchBox">⌕<input value={query} onChange={(event) => setQuery(event.target.value)} placeholder="Search trainers, skills, programs..." /></div>
            <button className="ghost" onClick={() => setViewMode('day')}>Dispatch Board</button>
            <button className="primary" onClick={openCreate}>＋ Add Trainer</button>
            <button className="ghost" onClick={exportCsv}>Export</button>
          </div>
        </section>

        <section className="kpiGrid">
          <Kpi icon="♙" title="Active Trainers" value={stats.active} hint={`${trainers.length} live registry`} tone="blue" />
          <Kpi icon="⊙" title="Assigned Today" value={stats.assignedToday} hint="sessions planned" tone="purple" />
          <Kpi icon="♧" title="Upcoming Sessions" value={stats.upcoming} hint="next 7 days" tone="teal" />
          <Kpi icon="◎" title="Coverage Rate" value={`${stats.coverageRate}%`} hint="covered assignments" tone="orange" />
          <Kpi icon="▣" title="Average Load" value={`${stats.avgLoad}%`} hint="capacity used" tone="green" />
        </section>

        <section className="filtersBar">
          <input value={query} onChange={(event) => setQuery(event.target.value)} placeholder="Search trainers by name, skill, city, email..." />
          <select value={availabilityFilter} onChange={(event) => setAvailabilityFilter(event.target.value)}><option value="all">Availability · All</option><option value="available">Available</option><option value="busy">Busy / Not Available</option></select>
          <select value={specialtyFilter} onChange={(event) => setSpecialtyFilter(event.target.value)}><option value="all">Specialty · All</option>{specialties.map((specialty) => <option key={specialty} value={specialty.toLowerCase()}>{specialty}</option>)}</select>
          <select value={loadFilter} onChange={(event) => setLoadFilter(event.target.value)}><option value="all">Load · All</option><option value="high">High Load</option><option value="normal">Normal Load</option><option value="low">Low Load</option></select>
          <button onClick={load}>Refresh</button>
        </section>

        <section className="dispatchLayout">
          <aside className="leftRail">
            <StatusOverview trainers={trainers} />
            <WorkloadPanel trainers={filteredTrainers} onOpen={(trainer) => { setSelectedWorkload(trainer); openTrainer(trainer, 'view') }} />
          </aside>

          <section className="centerBoard">
            <div className="boardTop">
              <div><h2>Live Training Schedule</h2><p>{viewMode === 'day' ? 'Training-based daily dispatch · 08:00 → 21:00' : viewMode === 'week' ? 'Weekly training coverage cards by date' : 'Monthly training coverage map'}</p></div>
              <div className="viewControls">
                <button className={viewMode === 'day' ? 'active' : ''} onClick={() => setViewMode('day')}>Day</button>
                <button className={viewMode === 'week' ? 'active' : ''} onClick={() => setViewMode('week')}>Week</button>
                <button className={viewMode === 'month' ? 'active' : ''} onClick={() => setViewMode('month')}>Month</button>
                <button onClick={() => setFocusDate(new Date())}>Today</button>
                <button onClick={() => setFocusDate(addDays(focusDate, viewMode === 'month' ? -30 : viewMode === 'week' ? -7 : -1))}>‹</button>
                <button onClick={() => setFocusDate(addDays(focusDate, viewMode === 'month' ? 30 : viewMode === 'week' ? 7 : 1))}>›</button>
              </div>
            </div>
            {viewMode === 'day' && <DaySchedule trainers={filteredTrainers.slice(0, 6)} assignments={assignments} focusDate={focusDate} onAssign={assignTrainer} />}
            {viewMode === 'week' && <WeekSchedule days={weekDays} assignments={assignments} trainers={filteredTrainers} />}
            {viewMode === 'month' && <MonthSchedule days={monthDays} assignments={assignments} />}
          </section>

          <aside className="rightRail">
            <UpcomingPanel assignments={upcomingAssignments} />
            <AlertsPanel alerts={alerts} />
            <AvailabilityPanel trainers={filteredTrainers} />
          </aside>
        </section>
      </main>

      {modalMode && (
        <TrainerDossierModal
          mode={modalMode}
          draft={draft}
          trainer={selectedTrainer}
          activeStep={activeStep}
          saving={saving}
          onStep={setActiveStep}
          onChange={changeDraft}
          onClose={closeModal}
          onEdit={() => setModalMode('edit')}
          onSave={saveTrainer}
        />
      )}

      <style jsx global>{css}</style>
    </div>
  )
}

function AcademySidebar() {
  return (
    <aside className="academySidebar">
      <div className="academyBrand"><div className="brandLogo">A</div><div><strong>AngelCare</strong><span>ACADEMY OS</span></div></div>
      <div className="sidebarSection">ACADEMY</div>
      <nav>{sidebar.map(([icon, label, href]) => <a key={label} className={label === 'Trainers' ? 'active' : ''} href={href}><span>{icon}</span>{label}</a>)}</nav>
      <div className="sidebarUser"><div className="userAvatar">SU</div><div><strong>System User</strong><span>Academy Admin</span></div></div>
    </aside>
  )
}

function Kpi({ icon, title, value, hint, tone }: { icon: string; title: string; value: any; hint: string; tone: string }) {
  return <article className={`kpi ${tone}`}><div className="kpiIcon">{icon}</div><div><span>{title}</span><strong>{value}</strong><small>{hint}</small></div><Spark /></article>
}
function Spark() { return <svg className="spark" viewBox="0 0 100 30"><path d="M2 22 L12 20 L20 23 L30 13 L40 16 L52 7 L62 15 L73 10 L84 17 L98 8" fill="none" stroke="currentColor" strokeWidth="3" strokeLinecap="round" /></svg> }
function StatusOverview({ trainers }: { trainers: Trainer[] }) {
  const total = trainers.length
  const available = trainers.filter(isAvailable).length
  const overloaded = trainers.filter((t) => calcLoad(t) >= 90).length
  const highLoad = trainers.filter((t) => calcLoad(t) >= 70 && calcLoad(t) < 90).length
  const unavailable = trainers.filter((t) => !isAvailable(t)).length
  const avgLoad = total ? Math.round(trainers.reduce((sum, t) => sum + calcLoad(t), 0) / total) : 0
  const avgReadiness = total ? Math.round(trainers.reduce((sum, t) => sum + pct(t.readiness_score), 0) / total) : 0
  const docsRisk = trainers.filter((t) => toNumber(t.docs_verified, 0) < toNumber(t.docs_required, 5)).length
  const availableDeg = total ? Math.round((available / total) * 360) : 0
  const highDeg = total ? availableDeg + Math.round((highLoad / total) * 360) : 0
  const overloadDeg = total ? highDeg + Math.round((overloaded / total) * 360) : 0
  return (
    <section className="panel statusPanel upgradedStatus">
      <div className="panelHead"><h3>Trainer Status Overview</h3><button>Live</button></div>
      <div className="statusHero">
        <div
          className="donut premiumDonut"
          style={{ background: `conic-gradient(#22c55e 0 ${availableDeg}deg, #f59e0b ${availableDeg}deg ${highDeg}deg, #ef4444 ${highDeg}deg ${overloadDeg}deg, #e5e7eb ${overloadDeg}deg 360deg)` }}
        >
          <strong>{total}</strong><span>trainers</span>
        </div>
        <div className="statusStack">
          <StatusMini label="Available" value={available} tone="green" />
          <StatusMini label="High Load" value={highLoad} tone="amber" />
          <StatusMini label="Overloaded" value={overloaded} tone="red" />
          <StatusMini label="Unavailable" value={unavailable} tone="gray" />
        </div>
      </div>
      <div className="statusTiles">
        <div><span>Average readiness</span><strong>{avgReadiness}%</strong><i style={{ width: `${avgReadiness}%` }} /></div>
        <div><span>Average workload</span><strong>{avgLoad}%</strong><i style={{ width: `${avgLoad}%` }} /></div>
        <div><span>Document risk</span><strong>{docsRisk}</strong><i style={{ width: `${Math.min(100, docsRisk * 18)}%` }} /></div>
      </div>
    </section>
  )
}
function StatusMini({ label, value, tone }: { label: string; value: any; tone: string }) { return <div className={`statusMini ${tone}`}><b>{value}</b><span>{label}</span></div> }
function Legend({ label, value, color }: { label: string; value: any; color: string }) { return <div className="legendRow"><span><i style={{ background: color }} />{label}</span><strong>{value}</strong></div> }
function WorkloadPanel({ trainers, onOpen }: { trainers: Trainer[]; onOpen: (t: Trainer) => void }) {
  return (
    <section className="panel workloadPanel upgradedWorkload">
      <div className="panelHead"><h3>Trainer Workload Overview</h3><button>Operational</button></div>
      <div className="workloadCards">
        {trainers.slice(0, 7).map((trainer) => {
          const load = calcLoad(trainer)
          const tone = load >= 90 ? 'danger' : load >= 70 ? 'warn' : load >= 35 ? 'normal' : 'light'
          return (
            <button key={trainer.id} className={`workloadCard ${tone}`} onClick={() => onOpen(trainer)}>
              <span className="workloadAvatar">{initials(nameOf(trainer))}</span>
              <main><strong>{nameOf(trainer)}</strong><small>{textOf(trainer.main_specialty || trainer.specialty, 'General Training')}</small><div className="bar"><i style={{ width: `${load}%` }} /></div></main>
              <aside><b>{load}%</b><em>{load >= 90 ? 'Critical' : load >= 70 ? 'High' : load >= 35 ? 'Normal' : 'Low'}</em></aside>
            </button>
          )
        })}
      </div>
    </section>
  )
}
function DaySchedule({ trainers, assignments, focusDate, onAssign }: { trainers: Trainer[]; assignments: Assignment[]; focusDate: Date; onAssign: (trainer: Trainer) => void }) {
  const hours = Array.from({ length: 14 }, (_, i) => 8 + i)
  const dayAssignments = assignments
    .filter((assignment) => {
      const start = parseDate(assignmentStart(assignment))
      return start && dateKey(start) === dateKey(focusDate)
    })
    .sort((a, b) => Number(parseDate(assignmentStart(a))) - Number(parseDate(assignmentStart(b))))
  const availableTrainers = trainers.filter(isAvailable).sort((a, b) => calcLoad(a) - calcLoad(b))
  function assignedTrainer(item: Assignment) {
    return trainers.find((trainer) => belongsToTrainer(item, trainer)) || null
  }
  function itemsForHour(hour: number) {
    return dayAssignments.filter((item) => parseDate(assignmentStart(item))?.getHours() === hour)
  }
  return (
    <div className="scheduleTimeline">
      <div className="scheduleDateBar">
        <strong>{focusDate.toLocaleDateString([], { weekday: 'long', month: 'long', day: '2-digit', year: 'numeric' })}</strong>
        <span>Operational hours 08:00 → 21:00 · training cards grouped by scheduled start time · trainers attached inside each training</span>
      </div>
      {hours.map((hour) => {
        const items = itemsForHour(hour)
        return (
          <div className="scheduleHourRow" key={hour}>
            <div className="hourRail"><strong>{String(hour).padStart(2, '0')}:00</strong><span>{hour < 12 ? 'Morning' : hour < 18 ? 'Afternoon' : 'Evening'}</span></div>
            <div className="scheduleSessionStack">
              {items.length ? items.map((item, index) => {
                const trainer = assignedTrainer(item)
                const fallbackTrainer = availableTrainers[index % Math.max(1, availableTrainers.length)]
                return (
                  <article className="trainingSlotCard" key={item.id || `${hour}-${index}`}>
                    <div className="trainingAccent" style={{ background: palette[index % palette.length] }} />
                    <main>
                      <div className="trainingMeta"><span>{formatTime(assignmentStart(item))} – {formatTime(assignmentEnd(item))}</span><em>{textOf(item.delivery_format || item.type, 'Training')}</em></div>
                      <strong>{assignmentTitle(item)}</strong>
                      <small>{textOf(item.cohort_reference || item.location, 'Academy schedule')}</small>
                    </main>
                    {trainer ? (
                      <button className="trainerDispatchCard assigned" onClick={() => onAssign(trainer)}>
                        <span>{initials(nameOf(trainer))}</span><div><b>{nameOf(trainer)}</b><small>{calcLoad(trainer)}% load · {textOf(trainer.status, 'available')}</small></div>
                      </button>
                    ) : fallbackTrainer ? (
                      <button className="trainerDispatchCard open" onClick={() => onAssign(fallbackTrainer)}>
                        <span>＋</span><div><b>Assign trainer</b><small>Suggested: {nameOf(fallbackTrainer)}</small></div>
                      </button>
                    ) : (
                      <div className="trainerDispatchCard risk"><span>!</span><div><b>No trainer available</b><small>Coverage gap</small></div></div>
                    )}
                  </article>
                )
              }) : <div className="emptyScheduleSlot">No training scheduled in this hour</div>}
            </div>
          </div>
        )
      })}
    </div>
  )
}
function WeekSchedule({ days, assignments, trainers }: { days: Date[]; assignments: Assignment[]; trainers: Trainer[] }) {
  return <div className="weekBoard upgradedWeekBoard">{days.map((day) => { const items = assignments.filter((a) => { const start = parseDate(assignmentStart(a)); return start && dateKey(start) === dateKey(day) }).sort((a,b)=>Number(parseDate(assignmentStart(a)))-Number(parseDate(assignmentStart(b)))); return <article key={dateKey(day)}><h4>{day.toLocaleDateString([], { weekday: 'short', month: 'short', day: '2-digit' })}</h4><span className="weekCount">{items.length} schedules</span>{items.length ? items.slice(0, 5).map((item, i) => { const trainer = trainers.find((t)=>belongsToTrainer(item,t)); return <div className="weekCard" key={item.id || i}><strong>{assignmentTitle(item)}</strong><span>{formatTime(assignmentStart(item))} · {trainer ? nameOf(trainer) : textOf(item.trainer_name, 'Unassigned')}</span></div> }) : <p>No training scheduled</p>}</article> })}</div>
}
function MonthSchedule({ days, assignments }: { days: Date[]; assignments: Assignment[] }) { return <div className="monthBoard upgradedMonthBoard">{days.map((day) => { const items = assignments.filter((a) => { const start = parseDate(assignmentStart(a)); return start && dateKey(start) === dateKey(day) }); return <div key={dateKey(day)} className={items.length ? 'has' : ''}><strong>{day.getDate()}</strong>{items.length ? <><span>{items.length} training</span><small>{assignmentTitle(items[0])}</small></> : null}</div> })}</div> }
function UpcomingPanel({ assignments }: { assignments: Assignment[] }) { return <section className="panel upcoming"><h3>Upcoming Assignments</h3>{assignments.length ? assignments.slice(0, 4).map((a, i) => <article key={a.id || i}><div><strong>{formatDay(assignmentStart(a))}</strong><span>{formatTime(assignmentStart(a))}</span></div><main><b>{assignmentTitle(a)}</b><small>{textOf(a.trainer_name, 'Trainer needed')} · {textOf(a.cohort_reference || a.location, 'Academy')}</small></main><i /></article>) : <p className="empty">No upcoming assignments yet.</p>}</section> }
function AlertsPanel({ alerts }: { alerts: { title: string; detail: string; severity: string }[] }) { return <section className="panel alerts"><h3>Alerts & Notifications</h3>{alerts.length ? alerts.map((alert, i) => <article key={i} className={alert.severity}><span>△</span><div><b>{alert.title}</b><small>{alert.detail}</small></div></article>) : <p className="empty">No live alerts.</p>}</section> }
function AvailabilityPanel({ trainers }: { trainers: Trainer[] }) { return <section className="panel availability"><div className="panelHead"><h3>Trainer Availability</h3><button>View Calendar</button></div>{trainers.slice(0, 5).map((t) => <article key={t.id}><span>{initials(nameOf(t))}</span><strong>{nameOf(t)}</strong><em className={isAvailable(t) ? 'ok' : 'bad'}>{isAvailable(t) ? 'Available' : 'Unavailable'}</em><small>{calcLoad(t)}%</small></article>)}</section> }

function TrainerDossierModal({ mode, draft, trainer, activeStep, saving, onStep, onChange, onClose, onEdit, onSave }: any) {
  const readOnly = mode === 'view'
  const name = textOf(draft.full_name || draft.name, mode === 'create' ? 'New Trainer' : 'Trainer')
  const steps = ['Identity & Profile', 'Status & Classification', 'Certificates & Documents', 'Expertise & Delivery', 'Availability & Dispatch', 'Compensation & Terms', 'Performance & History', 'Admin & Controls']
  return <div className="modalBackdrop"><section className="trainerModal"><header className="modalTop"><div className="modalTitle"><div className="modalIcon">♟</div><div><h2>{mode === 'create' ? 'Add New Trainer' : name}</h2><p>Create and configure a complete trainer dossier</p></div></div><div className="modalActions"><label>Reference #</label><input value={textOf(draft.reference_number || draft.trainer_code, `TRN-${new Date().getFullYear()}-${String(Math.floor(Math.random() * 99999)).padStart(5, '0')}`)} onChange={(e) => onChange('reference_number', e.target.value)} disabled={readOnly} />{mode === 'view' ? <button className="primary" onClick={onEdit}>Edit</button> : <><button className="ghost" disabled={saving} onClick={() => onSave(true)}>Save Draft</button><button className="primary" disabled={saving} onClick={() => onSave(false)}>{mode === 'edit' ? 'Save Trainer' : 'Create Trainer'}</button></>}<button className="ghost" onClick={onClose}>Close</button></div></header><div className="modalBody"><aside className="modalSteps">{steps.map((step, index) => <button key={step} className={activeStep === index + 1 ? 'active' : ''} onClick={() => onStep(index + 1)}><span>{index + 1}</span><strong>{step}</strong><small>{index === 0 ? 'Personal information' : index === 1 ? 'Role and capabilities' : index === 2 ? 'Compliance uploads' : index === 3 ? 'Skills and programs' : index === 4 ? 'Schedule & assignment' : index === 5 ? 'Rates and commercial' : index === 6 ? 'Scores and activities' : 'Notes and approvals'}</small></button>)}</aside><main className="modalContent"><section className="modalCard identity"><h3>1 Identity & Profile</h3><div className="photoBox">Upload photo<small>JPG/PNG</small></div><Field label="Full Name" value={draft.full_name || draft.name} onChange={(v) => onChange('full_name', v)} disabled={readOnly} required /><Field label="Trainer Code" value={draft.trainer_code || draft.reference_number} onChange={(v) => onChange('trainer_code', v)} disabled={readOnly} required /><Field label="Professional Title" value={draft.professional_title} onChange={(v) => onChange('professional_title', v)} disabled={readOnly} /><Field label="Gender" value={draft.gender} onChange={(v) => onChange('gender', v)} disabled={readOnly} /><Field label="Mobile" value={draft.mobile} onChange={(v) => onChange('mobile', v)} disabled={readOnly} /><Field label="Email" value={draft.email} onChange={(v) => onChange('email', v)} disabled={readOnly} /><Field label="City / Base Location" value={draft.city || draft.base_location} onChange={(v) => onChange('city', v)} disabled={readOnly} /><Field label="Languages" value={asArray(draft.languages).join(', ')} onChange={(v) => onChange('languages', v.split(',').map((x) => x.trim()))} disabled={readOnly} /><label className="wide">Short Professional Bio<textarea value={textOf(draft.bio, '')} onChange={(e) => onChange('bio', e.target.value)} disabled={readOnly} /></label></section><section className="modalCard status"><h3>2 Professional Status & Classification</h3><Field label="Employment Type" value={draft.employment_type} onChange={(v) => onChange('employment_type', v)} disabled={readOnly} /><Field label="Status" value={draft.status} onChange={(v) => onChange('status', v)} disabled={readOnly} /><Field label="Seniority Level" value={draft.seniority_level} onChange={(v) => onChange('seniority_level', v)} disabled={readOnly} /><Field label="Main Specialty" value={draft.main_specialty || draft.specialty} onChange={(v) => onChange('main_specialty', v)} disabled={readOnly} /><Field label="Readiness %" value={draft.readiness_score} onChange={(v) => onChange('readiness_score', Number(v))} disabled={readOnly} /><Field label="Dispatch Score" value={draft.dispatch_score} onChange={(v) => onChange('dispatch_score', Number(v))} disabled={readOnly} /></section><section className="modalCard triple"><div><h3>3 Certifications</h3><p>No certifications yet</p></div><div><h3>Documents Uploads</h3><p>No documents yet</p></div><div><h3>Compliance Verification</h3>{['Medical Fitness', 'Background Check', 'ID Verification', 'Reference Check', 'Contract Signed'].map((item) => <p key={item}><span className="okDot" />{item}<b>Verified</b></p>)}</div></section><section className="modalCard expertise"><h3>4 Expertise & Delivery Capability</h3><div className="chips">{asArray(draft.secondary_specialties).concat(['Childcare', 'First Aid', 'Safety']).slice(0, 8).map((item: string) => <span key={item}>{item}</span>)}</div><Field label="Programs Qualified" value="12 Programs" disabled /><Field label="Max Hours / Day" value="6" disabled={readOnly} /><Field label="Regions Covered" value={draft.city || 'UAE, GCC'} disabled={readOnly} /><Field label="Delivery Formats" value="Onsite, Online, Hybrid" disabled={readOnly} /></section><section className="modalCard availabilityBlock"><h3>5 Availability & Dispatch Control</h3><div className="days">{['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((day) => <button key={day}>✓<span>{day}</span></button>)}</div><Field label="Preferred Slots" value="09:00 - 17:00" disabled={readOnly} /><Field label="Current Load" value={`${calcLoad(draft as Trainer)}%`} disabled={readOnly} /><Field label="Weekly Capacity" value={draft.weekly_capacity || 40} onChange={(v) => onChange('weekly_capacity', Number(v))} disabled={readOnly} /></section><section className="modalCard compensation"><h3>6 Compensation & Commercial Terms</h3><Field label="Base Rate Type" value="Per Day" disabled={readOnly} /><Field label="Base Rate" value={(draft.compensation as any)?.base_rate || 0} disabled={readOnly} /><Field label="Hourly Rate" value={(draft.compensation as any)?.hourly_rate || 0} disabled={readOnly} /><Field label="Travel Fee" value={(draft.compensation as any)?.travel_fee || 0} disabled={readOnly} /><Field label="Accommodation" value="Provided" disabled={readOnly} /><Field label="Payment Method" value="Bank Transfer" disabled={readOnly} /></section><section className="modalCard performance"><h3>7 Performance, Quality History</h3>{[['Session Rating', toNumber(draft.session_rating, 0)], ['Completion Rate', `${pct(draft.completion_rate)}%`], ['Punctuality Score', `${pct(draft.punctuality_score)}%`], ['Incident Count', toNumber(draft.incident_count, 0)], ['Utilization', `${calcLoad(draft as Trainer)}%`]].map(([a, b]) => <div className="miniMetric" key={a}>{a}<strong>{b}</strong></div>)}</section><section className="modalCard admin"><h3>8 Administrative Notes & Internal Controls</h3><textarea value={textOf((draft as any).internal_notes, '')} onChange={(e) => onChange('internal_notes', e.target.value)} disabled={readOnly} placeholder="Internal remarks..." /><div className="finalChecks"><span>• Profile Complete</span><span>• Documents Verified</span><span>• Contract Signed</span><span>• Compliance Clear</span></div></section></main><aside className="summaryPreview"><h3>Trainer Summary Preview</h3><div className="bigAvatar">{initials(name)}</div><h2>{name}</h2><p>{textOf(draft.professional_title, 'Registered Trainer')}</p><span className="pill">{textOf(draft.status, 'available')}</span><div className="summaryStats"><div><b>{pct(draft.readiness_score)}%</b><span>Readiness</span></div><div><b>{toNumber(draft.dispatch_score, 0)}</b><span>Dispatch</span></div><div><b>{calcLoad(draft as Trainer)}%</b><span>Utilization</span></div><div><b>{toNumber(draft.docs_verified, 0)}/{toNumber(draft.docs_required, 5)}</b><span>Docs</span></div></div><h4>Assignments</h4><p className="empty">No assignments yet.</p></aside></div></section></div>
}
