{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "allowJs": false,
    "resolveJsonModule": true,
    "baseUrl": "../..",
    "paths": { "@/*": ["*"] }
  },
  "include": [
    "../../lib/market-os/ambassadors/**/*.ts",
    "../../app/api/market-os/ambassadors/**/*.ts",
    "./static-stubs.d.ts"
  ],
  "exclude": ["../../lib/market-os/ambassadors/*.bak-*", "../../**/*.tsx"]
}
