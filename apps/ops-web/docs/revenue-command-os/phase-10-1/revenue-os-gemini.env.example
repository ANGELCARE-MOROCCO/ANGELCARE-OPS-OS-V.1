REVENUE_OS_AI_ENABLED=true
REVENUE_OS_AI_PROVIDER=gemini
REVENUE_OS_AI_EXECUTION_MODE=shadow
REVENUE_OS_AI_ALLOW_EXTERNAL_ACTIONS=false
GEMINI_API_KEY=
GEMINI_PRIMARY_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
REVENUE_OS_AI_MIN_STRATEGIES=5
REVENUE_OS_AI_TIMEOUT_MS=120000
REVENUE_OS_AI_MAX_RETRIES=2
REVENUE_OS_AI_MAX_CONCURRENT_RUNS=2
REVENUE_OS_AI_MAX_REQUESTS_PER_MINUTE=5
REVENUE_OS_AI_MAX_REQUESTS_PER_DAY=100
REVENUE_OS_AI_MAX_INPUT_TOKENS_PER_RUN=50000
REVENUE_OS_AI_MAX_OUTPUT_TOKENS_PER_RUN=12000
REVENUE_OS_AI_DETERMINISTIC_FALLBACK=true
REVENUE_OS_AI_CACHE_ENABLED=true
REVENUE_OS_AI_CACHE_TTL_SECONDS=3600
REVENUE_OS_AI_REQUIRE_STRUCTURED_OUTPUT=true
REVENUE_OS_AI_REQUIRE_COMMAND_TRACE=true
REVENUE_OS_AI_REQUIRE_EVIDENCE_TRACE=true
REVENUE_OS_AI_MAX_REPAIR_ATTEMPTS=1
