    "lib/revenue-command-os/command-kernel/commands-3000/versions.ts",
    "lib/revenue-command-os/command-kernel/commands-3000/triggers.ts",
    "lib/revenue-command-os/command-kernel/commands-3000/schedules.ts",
    "lib/revenue-command-os/command-kernel/commands-3000/graphs.ts",
    "lib/revenue-command-os/command-kernel/commands-3000/index.ts",
    "lib/revenue-command-os/command-kernel/eligibility.ts",
    "lib/revenue-command-os/command-kernel/permissions.ts",
    "lib/revenue-command-os/command-kernel/graph.ts",
    "lib/revenue-command-os/command-kernel/scheduler.ts",
    "lib/revenue-command-os/command-kernel/schemas.ts",
    "lib/revenue-command-os/command-kernel/validation.ts"
