# Development override. Local HTTP is accepted only for localhost/127.0.0.1.
ANGELCARE_DESKTOP_APP_URL=http://localhost:3000

# Optional comma-separated navigation hosts in addition to the SaaS host.
ANGELCARE_DESKTOP_ALLOWED_HOSTS=opsmanagement.angelcarehub.com

# Optional release/build metadata surfaced to the SaaS runtime.
ANGELCARE_DESKTOP_RELEASE_CHANNEL=stable
ANGELCARE_DESKTOP_BUILD_ID=local

# Optional macOS signing/notarization values used only during packaging.
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
APPLE_SIGNING_IDENTITY=

# Optional Windows code-signing values used only during packaging.
WINDOWS_CERTIFICATE_FILE=
WINDOWS_CERTIFICATE_PASSWORD=

# Mega ZIP 2 WhatsApp Web runtime
# The linked-device session remains local in persist:angelcare-whatsapp-main.
ANGELCARE_DESKTOP_WHATSAPP_ENABLED=true
