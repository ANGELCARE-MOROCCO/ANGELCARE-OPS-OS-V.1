}

function StatusLine({ label, value }: { label: string; value: number }) {
  return (
    <div style={{ display: 'flex', justifyContent: 'space-between', gap: 12, borderBottom: '1px solid rgba(255,255,255,.14)', paddingBottom: 8 }}>
      <span style={{ color: '#bfdbfe', fontWeight: 850 }}>{label}</span>
      <strong>{value}</strong>
    </div>
  )
}

function TaskSection({ title, tasks }: { title: string; tasks: StaffPortalTask[] }) {
  return (
    <div>
      <h3 style={{ margin: '0 0 8px', color: '#0f172a', fontSize: 17 }}>{title}</h3>
      {tasks.length ? tasks.map((task) => <TaskRow key={`${task.source}-${task.id}`} task={task} />) : (
        <div style={{ border: '1px dashed #cbd5e1', borderRadius: 18, padding: 16, color: '#64748b', fontWeight: 780, background: '#f8fafc' }}>
          No open task in this period.
        </div>
      )}
    </div>
  )
}

const heroChip: React.CSSProperties = {
  display: 'inline-flex',
  alignItems: 'center',
  border: '1px solid rgba(255,255,255,.18)',
  background: 'rgba(255,255,255,.10)',
  color: '#e0f2fe',
  borderRadius: 999,
  padding: '8px 11px',
  fontWeight: 900,
}
