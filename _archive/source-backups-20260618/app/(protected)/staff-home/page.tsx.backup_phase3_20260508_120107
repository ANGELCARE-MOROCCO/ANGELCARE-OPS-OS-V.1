            padding: 30,
            color: 'white',
            background: 'linear-gradient(135deg,#020617 0%,#0f172a 34%,#1e3a8a 68%,#0f766e 100%)',
            boxShadow: '0 30px 90px rgba(2,6,23,.28)',
            marginBottom: 22,
            overflow: 'hidden',
          }}
        >
          <div style={{ display: 'grid', gridTemplateColumns: 'minmax(0,1.35fr) minmax(280px,.65fr)', gap: 24 }}>
            <div>
              <div style={{ color: '#93c5fd', fontSize: 12, fontWeight: 950, textTransform: 'uppercase', letterSpacing: 1.4 }}>
                Personalized Master Staff Page
              </div>
              <h1 style={{ margin: '10px 0', fontSize: 40, lineHeight: 1.04, letterSpacing: -1.1 }}>
                Welcome, {data.displayName}
              </h1>
              <p style={{ color: '#dbeafe', margin: 0, maxWidth: 920, fontWeight: 780, lineHeight: 1.6 }}>
                Your workspace is synchronized with your department, position and permissions. Use this page as your daily command desk for tasks, memos, access, roster, trainings and performance pulse.
              </p>
              <div style={{ display: 'flex', gap: 10, flexWrap: 'wrap', marginTop: 18 }}>
                <span style={heroChip}>Department: {data.department}</span>
                <span style={heroChip}>Position: {data.position}</span>
                <span style={heroChip}>Role: {data.roleLabel}</span>
                <span style={heroChip}>{data.accessRoutes.length} authorized routes</span>
              </div>
            </div>

            <div
              style={{
                background: 'rgba(255,255,255,.10)',
                border: '1px solid rgba(255,255,255,.18)',
                borderRadius: 24,
                padding: 16,
                backdropFilter: 'blur(12px)',
              }}
            >
