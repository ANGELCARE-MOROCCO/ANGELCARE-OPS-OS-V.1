      <div
        style={{
          background:
            'radial-gradient(circle at top left, rgba(37,99,235,.10), transparent 34%), radial-gradient(circle at top right, rgba(20,184,166,.11), transparent 30%), #f8fafc',
          borderRadius: 30,
          padding: 2,
        }}
      >
