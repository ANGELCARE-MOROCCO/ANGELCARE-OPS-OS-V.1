import Link from 'next/link'
import AppShell, { PageAction } from '@/app/components/erp/AppShell'
import { getCurrentUser } from '@/lib/getUser'
import { getStaffPortalPhase1Data, type StaffPortalTask } from '@/lib/staff-portal-os/phase1-data'
import StaffPortalMemoPanel from './_components/StaffPortalMemoPanel'

type Tone = 'blue' | 'green' | 'amber' | 'red' | 'purple' | 'cyan' | 'slate'

const tones: Record<Tone, { bg: string; text: string; border: string; shadow: string }> = {
  blue: { bg: '#eff6ff', text: '#1d4ed8', border: '#bfdbfe', shadow: 'rgba(37,99,235,.16)' },
  green: { bg: '#ecfdf5', text: '#047857', border: '#a7f3d0', shadow: 'rgba(5,150,105,.16)' },
  amber: { bg: '#fffbeb', text: '#b45309', border: '#fde68a', shadow: 'rgba(217,119,6,.16)' },
  red: { bg: '#fef2f2', text: '#b91c1c', border: '#fecaca', shadow: 'rgba(220,38,38,.18)' },
  purple: { bg: '#f5f3ff', text: '#6d28d9', border: '#ddd6fe', shadow: 'rgba(124,58,237,.16)' },
  cyan: { bg: '#ecfeff', text: '#0e7490', border: '#a5f3fc', shadow: 'rgba(8,145,178,.16)' },
  slate: { bg: '#f8fafc', text: '#334155', border: '#cbd5e1', shadow: 'rgba(15,23,42,.10)' },
}

function fmtDate(value: string | null) {
  if (!value) return 'Not scheduled'
  const date = new Date(value)
  if (Number.isNaN(date.getTime())) return value
  return date.toLocaleDateString('fr-MA', { weekday: 'short', day: '2-digit', month: 'short' })
}

function toneForTask(task: StaffPortalTask): Tone {
  if (task.priority === 'critical') return 'red'
  if (task.priority === 'high') return 'amber'
  if (task.priority === 'medium') return 'blue'
  return 'slate'
}

function KPI({ label, value, detail, tone }: { label: string; value: string | number; detail: string; tone: Tone }) {
  const t = tones[tone]
  return (
    <div
      style={{
        background: 'white',
        border: `1px solid ${t.border}`,
        borderRadius: 24,
        padding: 18,
        boxShadow: `0 18px 55px ${t.shadow}`,
      }}
    >
      <div style={{ display: 'flex', justifyContent: 'space-between', gap: 10 }}>
        <div style={{ color: '#64748b', fontSize: 12, fontWeight: 950, letterSpacing: .8, textTransform: 'uppercase' }}>{label}</div>
        <span style={{ width: 10, height: 10, borderRadius: 999, background: t.text, boxShadow: `0 0 0 5px ${t.bg}` }} />
      </div>
      <div style={{ color: t.text, fontSize: 34, fontWeight: 950, marginTop: 8 }}>{value}</div>
      <div style={{ color: '#475569', fontWeight: 750, marginTop: 5 }}>{detail}</div>
    </div>
  )
}

function PortalPanel({
  title,
  detail,
  children,
  tone = 'blue',
}: {
  title: string
  detail?: string
  children: React.ReactNode
  tone?: Tone
}) {
  const t = tones[tone]
  return (
    <section
      style={{
        background: 'rgba(255,255,255,.97)',
        border: `1px solid ${t.border}`,
        borderRadius: 26,
        padding: 18,
        boxShadow: `0 18px 55px ${t.shadow}`,
        position: 'relative',
        overflow: 'hidden',
      }}
    >
      <div style={{ position: 'absolute', inset: '0 auto 0 0', width: 5, background: t.text }} />
      <div style={{ paddingLeft: 4, marginBottom: 14 }}>
        <h2 style={{ color: '#0f172a', margin: 0, fontSize: 21, fontWeight: 950 }}>{title}</h2>
        {detail ? <p style={{ color: '#64748b', margin: '5px 0 0', fontWeight: 760, lineHeight: 1.45 }}>{detail}</p> : null}
      </div>
      {children}
    </section>
  )
}

function TaskRow({ task }: { task: StaffPortalTask }) {
  const t = tones[toneForTask(task)]
  return (
    <div
      style={{
        display: 'grid',
        gridTemplateColumns: '12px minmax(0,1fr) auto',
        gap: 12,
        alignItems: 'center',
        borderBottom: '1px solid #f1f5f9',
        padding: '12px 0',
      }}
    >
      <span style={{ width: 10, height: 10, borderRadius: 999, background: t.text, boxShadow: `0 0 0 5px ${t.bg}` }} />
      <div>
        <div style={{ color: '#0f172a', fontWeight: 950 }}>{task.title}</div>
        <div style={{ color: '#64748b', fontSize: 13, fontWeight: 720, marginTop: 4 }}>
          {task.source} · {fmtDate(task.date)} · {task.detail}
        </div>
      </div>
      <div style={{ display: 'flex', gap: 8, alignItems: 'center' }}>
        <span style={{ color: t.text, background: t.bg, border: `1px solid ${t.border}`, borderRadius: 999, padding: '5px 9px', fontSize: 12, fontWeight: 950 }}>
          {task.status}
        </span>
        <Link href={task.href} style={smallButton('#334155', '#f8fafc', '#cbd5e1')}>View</Link>
        <Link href={task.executeHref} style={smallButton('#ffffff', '#2563eb', '#1d4ed8')}>Execute</Link>
      </div>
    </div>
  )
}

function smallButton(color: string, background: string, border: string): React.CSSProperties {
  return {
    color,
    background,
    border: `1px solid ${border}`,
    borderRadius: 999,
    padding: '7px 10px',
    textDecoration: 'none',
    fontWeight: 950,
    fontSize: 12,
    whiteSpace: 'nowrap',
  }
}

