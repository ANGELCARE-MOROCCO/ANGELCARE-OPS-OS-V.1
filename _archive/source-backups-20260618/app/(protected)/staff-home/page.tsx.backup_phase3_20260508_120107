              <div style={{ marginTop: 14, display: 'grid', gap: 10 }}>
                <StatusLine label="Today tasks" value={data.tasksToday.length} />
                <StatusLine label="Week tasks" value={data.tasksWeek.length} />
                <StatusLine label="Memos" value={data.memos.length} />
                <StatusLine label="Modules" value={Object.keys(data.routeGroups).length} />
              </div>
            </div>
          </div>
        </section>

        <section id="access-menu" style={{ marginBottom: 22 }}>
          <div style={{ display: 'flex', gap: 9, overflowX: 'auto', paddingBottom: 4 }}>
            {accessModules.length ? accessModules.map(([module, routes]) => (
              <Link
                key={module}
                href={routes[0]?.href || '/staff-home'}
                style={{
                  whiteSpace: 'nowrap',
                  textDecoration: 'none',
                  color: '#0f172a',
                  background: 'white',
                  border: '1px solid #e2e8f0',
                  borderRadius: 999,
                  padding: '10px 13px',
                  fontWeight: 950,
                  boxShadow: '0 10px 24px rgba(15,23,42,.06)',
                }}
              >
                {routes[0]?.moduleLabel || module} · {routes.length}
