            <PortalPanel title="My Space" detail="Dedicated personal command card with real workspace buttons." tone="purple">
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fit,minmax(190px,1fr))', gap: 12 }}>
                {data.mySpaceLinks.map((link) => (
                  <Link
