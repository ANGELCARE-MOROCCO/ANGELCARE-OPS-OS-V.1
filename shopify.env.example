# Server Config
PORT=3000
HOST=127.0.0.1
NODE_ENV=development
APP_URL=http://localhost:3000
CORS_ORIGIN=*
DATA_DIR=./data/shopify-api
ALLOW_UNSIGNED_WEBHOOKS=

# Database Config (PostgreSQL recommended)
DATABASE_URL=postgres://user:password@localhost:5432/shopify_dashboard

# Shopify App Credentials
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Shopify Store Config
SHOPIFY_SHOP_DOMAIN=angelcare4all.myshopify.com
SHOPIFY_API_VERSION=2026-04
SHOPIFY_SCOPES=read_orders,read_products,read_customers,read_inventory,write_inventory,read_locations,read_reports
SHOPIFY_TOKEN_GRANT=authorization_code
SHOPIFY_OMIT_AUTH_SCOPES=true

# Final offline token, filled after OAuth install callback.
SHOPIFY_ACCESS_TOKEN=
