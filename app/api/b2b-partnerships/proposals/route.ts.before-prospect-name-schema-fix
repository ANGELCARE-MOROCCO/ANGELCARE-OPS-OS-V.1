import { NextRequest, NextResponse } from 'next/server'
import { getCurrentB2BAppUser, getServerB2BDatabaseClient } from '@/lib/b2b-partnerships/runtime'
import { requireB2BPermission } from '@/lib/b2b-partnerships/permissions'
import { logB2BActivity, logB2BAuditEvent } from '@/lib/b2b-partnerships/audit'
import { B2B_AUDIT_ACTIONS } from '@/lib/b2b-partnerships/constants'

function toNumber(value: unknown) {
  const n = Number(value || 0)
  return Number.isFinite(n) ? n : 0
}

function asArray(value: unknown): string[] {
  if (Array.isArray(value)) return value.map(String).filter(Boolean)
  if (typeof value === 'string' && value.trim()) {
    try {
      const parsed = JSON.parse(value)
      if (Array.isArray(parsed)) return parsed.map(String).filter(Boolean)
    } catch {}
    return value.split(',').map((x) => x.trim()).filter(Boolean)
  }
  return []
}


function normalizeProposalStatus(value: unknown) {
  const raw = typeof value === 'string' ? value.trim().toLowerCase() : ''

  const map: Record<string, string> = {
    draft: 'Draft',
    sent: 'Sent',
    pending: 'Pending',
    pending_review: 'Pending',
    review: 'Pending',
    under_review: 'Pending',
    negotiation: 'Negotiation',
    accepted: 'Accepted',
    signed: 'Accepted',
    won: 'Accepted',
    lost: 'Lost',
    rejected: 'Lost',
    expired: 'Lost',
  }

  return map[raw] || 'Draft'
}

function cleanText(value: unknown, fallback = '') {
  return typeof value === 'string' && value.trim() ? value.trim() : fallback
}

async function findProspectId(db: any, body: any, actorId?: string | null) {
  if (body.prospect_id) return body.prospect_id

  const partnerName = cleanText(body.partner_name || body.prospect_name || body.company_name || body.account_name)
  if (!partnerName) {
    throw new Error('A partner/prospect name is required before creating a proposal.')
  }

  const safeName = partnerName.replace(/[%_,]/g, ' ').trim()

  const { data: existing, error: lookupError } = await db
    .from('b2b_prospects')
    .select('id,name,prospect_name,company_name')
    .or(`name.ilike.%${safeName}%,prospect_name.ilike.%${safeName}%,company_name.ilike.%${safeName}%`)
    .limit(1)
    .maybeSingle()

  if (lookupError) {
    throw new Error(lookupError.message || 'Unable to look up prospect before proposal creation.')
  }

  if (existing?.id) return existing.id

  const sector = cleanText(body.sector || body.segment || body.partner_sector, 'hospitality')
  const city = cleanText(body.city || body.partner_city || body.location, 'Rabat')
  const status = 'New'
  const priority = 'B'

  const prospectPayload = {
    name: partnerName,
    prospect_name: partnerName,
    company_name: partnerName,
    sector,
    city,
    status,
    priority,
    source: 'proposal_builder',
    decision_maker_name: cleanText(body.decision_maker_name || body.contact_name, null as any),
    decision_maker_role: cleanText(body.decision_maker_role || body.contact_role, null as any),
    email: cleanText(body.email || body.partner_email || body.contact_email, null as any),
    phone: cleanText(body.phone || body.partner_phone || body.mobile, null as any),
    created_by: actorId || null,
  }

  const { data: created, error: createError } = await db
    .from('b2b_prospects')
    .insert(prospectPayload)
    .select('id')
    .single()

  if (createError) {
    throw new Error(createError.message || 'Unable to create linked prospect before proposal creation.')
  }

  return created.id
}

function buildProposalPayload(body: any, actorId?: string | null, prospectId?: string | null) {
  const title = cleanText(
    body.proposal_title ||
      body.title ||
      body.name ||
      body.proposal_name,
    'Proposition de partenariat ANGELCARE'
  )

  const sector = cleanText(body.sector || body.segment || body.partner_sector, 'hospitality')
  const services = asArray(body.services_included || body.services || body.service_scope)

  const estimatedMonthly = toNumber(
    body.estimated_monthly_value ||
      body.monthly_value ||
      body.estimated_monthly_revenue ||
      body.estimated_value
  )

  const estimatedAnnual = toNumber(
    body.estimated_annual_value ||
      body.annual_value ||
      body.estimated_annual_revenue ||
      estimatedMonthly * 12
  )

  return {
    prospect_id: prospectId,
    proposal_title: title,
    proposal_type: cleanText(body.proposal_type || body.type || sector, 'Partnership Proposal'),
    services_included: services,
    pricing_model: cleanText(body.pricing_model || body.commercial_terms || body.terms, null as any),
    estimated_monthly_value: estimatedMonthly,
    estimated_annual_value: estimatedAnnual,
    pilot_duration: cleanText(body.pilot_duration || body.duration, null as any),
    follow_up_at: body.follow_up_at || body.next_follow_up_at || null,
    status: normalizeProposalStatus(body.status || body.proposal_status),
    created_by: actorId || null,
  }
}

export async function GET(req: NextRequest) {
  try {
    const db = await getServerB2BDatabaseClient()
    const actor = await getCurrentB2BAppUser()

    if (!actor?.id) {
      return NextResponse.json({ ok: false, error: 'Authentication required.' }, { status: 401 })
    }

    const perm = requireB2BPermission('read', { actorId: actor.id, actorRole: actor.role || actor.role_key })
    if (!perm.ok) {
      return NextResponse.json({ ok: false, error: perm.error }, { status: perm.status })
    }

    const limit = Number(req.nextUrl.searchParams.get('limit') || 300)

    const { data, error } = await db
      .from('b2b_proposals')
      .select('*, prospect:b2b_prospects(*)')
      .order('created_at', { ascending: false })
      .limit(limit)

    if (error) {
      return NextResponse.json(
        { ok: false, error: error.message || 'Unable to load proposals.', details: error },
        { status: 500 }
      )
    }

    return NextResponse.json({ ok: true, data: data || [] })
  } catch (error) {
    console.error('[B2B_PROPOSALS_GET_FAILED]', error)
    return NextResponse.json({ ok: false, error: 'Unexpected server error.' }, { status: 500 })
  }
}

export async function POST(req: NextRequest) {
  try {
    const db = await getServerB2BDatabaseClient()
    const actor = await getCurrentB2BAppUser()

    if (!actor?.id) {
      return NextResponse.json({ ok: false, error: 'Authentication required.' }, { status: 401 })
    }

    const perm = requireB2BPermission('create', { actorId: actor.id, actorRole: actor.role || actor.role_key })
    if (!perm.ok) {
      return NextResponse.json({ ok: false, error: perm.error }, { status: perm.status })
    }

    const body = await req.json()
    const prospectId = await findProspectId(db, body, actor.id)
    const payload = buildProposalPayload(body, actor.id, prospectId)

    const { data, error } = await db
      .from('b2b_proposals')
      .insert(payload)
      .select('*')
      .single()

    if (error) {
      return NextResponse.json(
        {
          ok: false,
          error: error.message || 'Unable to create proposal.',
          details: error,
          attempted_payload: payload,
        },
        { status: 500 }
      )
    }

    await logB2BActivity({
      db: db as any,
      prospectId: data.prospect_id,
      actorId: actor.id,
      activityType: 'proposal.created',
      title: 'B2B proposal created',
      description: data.proposal_title,
      metadata: { status: data.status, proposal_type: data.proposal_type },
    })

    await logB2BAuditEvent({
      db: db as any,
      actorId: actor.id,
      entityType: 'b2b_proposal',
      entityId: data.id,
      action: B2B_AUDIT_ACTIONS.PROPOSAL_CREATED,
      afterData: data,
    })

    return NextResponse.json({ ok: true, data })
  } catch (error) {
    console.error('[B2B_PROPOSAL_POST_FAILED]', error)
    return NextResponse.json(
      { ok: false, error: error instanceof Error ? error.message : 'Unexpected server error.' },
      { status: 500 }
    )
  }
}
