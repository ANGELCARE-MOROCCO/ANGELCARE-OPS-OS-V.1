import { NextRequest, NextResponse } from 'next/server'
import { getCurrentB2BAppUser, getServerB2BDatabaseClient } from '@/lib/b2b-partnerships/runtime'
import { requireB2BPermission } from '@/lib/b2b-partnerships/permissions'
import { logB2BActivity, logB2BAuditEvent } from '@/lib/b2b-partnerships/audit'
import { B2B_AUDIT_ACTIONS } from '@/lib/b2b-partnerships/constants'

function toNumber(value: unknown) {
  const n = Number(value || 0)
  return Number.isFinite(n) ? n : 0
}

function asArray(value: unknown): string[] {
  if (Array.isArray(value)) return value.map(String).filter(Boolean)
  if (typeof value === 'string' && value.trim()) {
    try {
      const parsed = JSON.parse(value)
      if (Array.isArray(parsed)) return parsed.map(String).filter(Boolean)
    } catch {}
    return value.split(',').map((x) => x.trim()).filter(Boolean)
  }
  return []
}

function cleanText(value: unknown, fallback: any = '') {
  return typeof value === 'string' && value.trim() ? value.trim() : fallback
}

function buildUpdate(body: any) {
  const title = cleanText(body.proposal_title || body.title || body.name || body.proposal_name, undefined)
  const sector = cleanText(body.sector || body.segment || body.partner_sector, undefined)
  const services = asArray(body.services_included || body.services || body.service_scope)

  const update: any = {}

  if (title !== undefined) update.proposal_title = title
  if (sector !== undefined) update.proposal_type = cleanText(body.proposal_type || body.type || sector, 'Partnership Proposal')
  if (services.length) update.services_included = services
  if (body.pricing_model || body.commercial_terms || body.terms) update.pricing_model = cleanText(body.pricing_model || body.commercial_terms || body.terms)
  if (body.estimated_monthly_value || body.monthly_value || body.estimated_value) update.estimated_monthly_value = toNumber(body.estimated_monthly_value || body.monthly_value || body.estimated_value)
  if (body.estimated_annual_value || body.annual_value) update.estimated_annual_value = toNumber(body.estimated_annual_value || body.annual_value)
  if (body.pilot_duration || body.duration) update.pilot_duration = cleanText(body.pilot_duration || body.duration)
  if (body.follow_up_at || body.next_follow_up_at) update.follow_up_at = body.follow_up_at || body.next_follow_up_at
  if (body.status || body.proposal_status) update.status = cleanText(body.status || body.proposal_status)

  return update
}

export async function PATCH(req: NextRequest, { params }: { params: { id: string } }) {
  try {
    const db = await getServerB2BDatabaseClient()
    const actor = await getCurrentB2BAppUser()

    if (!actor?.id) {
      return NextResponse.json({ ok: false, error: 'Authentication required.' }, { status: 401 })
    }

    const perm = requireB2BPermission('update', { actorId: actor.id, actorRole: actor.role || actor.role_key })
    if (!perm.ok) {
      return NextResponse.json({ ok: false, error: perm.error }, { status: perm.status })
    }

    const body = await req.json()
    const { data: existing } = await db.from('b2b_proposals').select('*').eq('id', params.id).single()
    const update = buildUpdate(body)

    const { data, error } = await db
      .from('b2b_proposals')
      .update(update)
      .eq('id', params.id)
      .select('*')
      .single()

    if (error) {
      return NextResponse.json(
        { ok: false, error: error.message || 'Unable to update proposal.', details: error, attempted_update: update },
        { status: 500 }
      )
    }

    await logB2BActivity({
      db: db as any,
      prospectId: data.prospect_id,
      actorId: actor.id,
      activityType: 'proposal.updated',
      title: 'B2B proposal updated',
      description: data.proposal_title,
    })

    await logB2BAuditEvent({
      db: db as any,
      actorId: actor.id,
      entityType: 'b2b_proposal',
      entityId: data.id,
      action: B2B_AUDIT_ACTIONS.PROPOSAL_UPDATED,
      beforeData: existing,
      afterData: data,
    })

    return NextResponse.json({ ok: true, data })
  } catch (error) {
    console.error('[B2B_PROPOSAL_PATCH_FAILED]', error)
    return NextResponse.json(
      { ok: false, error: error instanceof Error ? error.message : 'Unexpected server error.' },
      { status: 500 }
    )
  }
}

export async function DELETE(_req: NextRequest, { params }: { params: { id: string } }) {
  try {
    const db = await getServerB2BDatabaseClient()
    const actor = await getCurrentB2BAppUser()

    if (!actor?.id) {
      return NextResponse.json({ ok: false, error: 'Authentication required.' }, { status: 401 })
    }

    const perm = requireB2BPermission('update', { actorId: actor.id, actorRole: actor.role || actor.role_key })
    if (!perm.ok) {
      return NextResponse.json({ ok: false, error: perm.error }, { status: perm.status })
    }

    const { data: existing } = await db.from('b2b_proposals').select('*').eq('id', params.id).single()
    const { error } = await db.from('b2b_proposals').delete().eq('id', params.id)

    if (error) {
      return NextResponse.json(
        { ok: false, error: error.message || 'Unable to delete proposal.', details: error },
        { status: 500 }
      )
    }

    await logB2BAuditEvent({
      db: db as any,
      actorId: actor.id,
      entityType: 'b2b_proposal',
      entityId: params.id,
      action: 'proposal.deleted',
      beforeData: existing,
    })

    return NextResponse.json({ ok: true, data: existing })
  } catch (error) {
    console.error('[B2B_PROPOSAL_DELETE_FAILED]', error)
    return NextResponse.json(
      { ok: false, error: error instanceof Error ? error.message : 'Unexpected server error.' },
      { status: 500 }
    )
  }
}
