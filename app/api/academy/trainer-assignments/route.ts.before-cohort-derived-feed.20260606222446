import { NextResponse } from 'next/server'
import { createTrainerAssignment } from '@/lib/academy-trainers/repository'

export const dynamic = 'force-dynamic'

export async function POST(request: Request) {
  try {
    const body = await request.json().catch(() => ({}))
    if (!body.trainer_id) return NextResponse.json({ ok: false, error: 'trainer_id is required' }, { status: 400 })
    const data = await createTrainerAssignment(body)
    return NextResponse.json({ ok: true, data })
  } catch (error: any) {
    return NextResponse.json({ ok: false, error: error?.message || 'Unable to assign trainer' }, { status: 500 })
  }
}
