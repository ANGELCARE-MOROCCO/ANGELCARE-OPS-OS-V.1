import { NextRequest, NextResponse } from 'next/server'
import { createClient } from '@/lib/supabase/server'

export const runtime = 'nodejs'
export const dynamic = 'force-dynamic'

type Context = {
  params: Promise<{ id: string }> | { id: string }
}

function numberOrNull(value: any) {
  if (value === undefined || value === null || value === '') return null
  const parsed = Number(value)
  return Number.isFinite(parsed) ? parsed : null
}

function cleanCohortPatch(body: any) {
  const patch: Record<string, any> = {}

  const textFields = [
    'reference_number',
    'title',
    'status',
    'notes',
    'program_title',
    'trainer_name',
    'training_start_time',
    'training_end_time',
  ]

  const numberFields = [
    'program_id',
    'capacity',
    'readiness_score',
    'progression_percent',
    'attendance_health',
    'hours_per_day',
  ]

  const dateFields = ['start_date', 'end_date']

  for (const key of textFields) {
    if (body[key] !== undefined) patch[key] = body[key] === '' ? null : String(body[key])
  }

  for (const key of numberFields) {
    if (body[key] !== undefined) patch[key] = numberOrNull(body[key])
  }

  for (const key of dateFields) {
    if (body[key] !== undefined) patch[key] = body[key] || null
  }

  if (body.training_start_time !== undefined) patch.training_start_time = body.training_start_time || null
  if (body.training_end_time !== undefined) patch.training_end_time = body.training_end_time || null
  if (body.hours_per_day !== undefined) {
    const parsedHours = Number(body.hours_per_day)
    patch.hours_per_day = Number.isFinite(parsedHours) ? parsedHours : null
  }

  if (body.trainer_id !== undefined) {
    patch.trainer_id = body.trainer_id || null
  }

  patch.updated_at = new Date().toISOString()

  return patch
}



async function syncCohortToTrainerAssignments(supabase: any, cohort: Record<string, any>) {
  const cohortId = cohort?.id
  const trainerId = cohort?.trainer_id

  if (!cohortId) return

  // If trainer was removed, clear any old assignment linked to this cohort.
  if (!trainerId) {
    await supabase
      .from('academy_trainer_assignments')
      .delete()
      .eq('cohort_id', cohortId)
    return
  }

  const title =
    cohort?.title ||
    cohort?.program_title ||
    cohort?.program_name ||
    cohort?.reference_number ||
    `Cohort ${cohortId}`

  const startDate = cohort?.start_date || new Date().toISOString().slice(0, 10)
  const endDate = cohort?.end_date || startDate

  const startTime = `${startDate}T09:00:00`
  const endTime = `${endDate}T17:00:00`

  // Remove stale linked assignment first so trainer reassignment is reflected everywhere.
  await supabase
    .from('academy_trainer_assignments')
    .delete()
    .eq('cohort_id', cohortId)

  const assignment = {
    trainer_id: trainerId,
    trainer_name: cohort?.trainer_name || null,
    cohort_id: cohortId,
    cohort_title: cohort?.title || null,
    cohort_reference: cohort?.reference_number || null,
    program_id: cohort?.program_id || null,
    program_title: cohort?.program_title || cohort?.program_name || null,
    title,
    status: cohort?.status || 'planned',
    start_time: startTime,
    end_time: endTime,
    location: cohort?.location || null,
    delivery_format: cohort?.delivery_format || null,
    updated_at: new Date().toISOString(),
  }

  // Some older assignment tables may not have all columns. Try full insert first,
  // then fall back to the minimal columns used by the trainers dispatch board.
  const { error } = await supabase
    .from('academy_trainer_assignments')
    .insert(assignment)

  if (error) {
    await supabase
      .from('academy_trainer_assignments')
      .insert({
        trainer_id: trainerId,
        trainer_name: cohort?.trainer_name || null,
        title,
        status: cohort?.status || 'planned',
        start_time: startTime,
        end_time: endTime,
        updated_at: new Date().toISOString(),
      })
  }
}

async function readCohort(id: number) {
  const supabase = await createClient()

  const { data: cohort, error } = await supabase
    .from('academy_cohorts')
    .select('*')
    .eq('id', id)
    .maybeSingle()

  if (error) return { error: error.message, status: 500 }
  if (!cohort) return { error: 'Cohort not found', status: 404 }

  const { data: participants } = await supabase
    .from('academy_cohort_participants')
    .select('*')
    .eq('cohort_id', id)
    .order('joined_at', { ascending: true })

  const { data: checklist } = await supabase
    .from('academy_cohort_checklist')
    .select('*')
    .eq('cohort_id', id)
    .order('sort_order', { ascending: true })

  return {
    data: {
      ...cohort,
      participants: participants || [],
      checklist: checklist || [],
    },
  }
}

async function updateCohort(id: number, body: any) {
  const patch = cleanCohortPatch(body)

  if (Object.keys(patch).length <= 1) {
    return NextResponse.json({ ok: false, error: 'No valid cohort fields provided' }, { status: 400 })
  }

  const supabase = await createClient()

  const { data, error } = await supabase
    .from('academy_cohorts')
    .update(patch)
    .eq('id', id)
    .select('*')
    .maybeSingle()

  if (error) {
    return NextResponse.json({ ok: false, error: error.message }, { status: 500 })
  }

  if (!data) {
    return NextResponse.json({ ok: false, error: 'Cohort not found' }, { status: 404 })
  }

  await syncCohortToTrainerAssignments(supabase, data)

  return NextResponse.json({ ok: true, data, cohort: data, synced: true })
}

export async function GET(_request: NextRequest, context: Context) {
  const params = await context.params
  const id = Number(params.id)

  if (!Number.isFinite(id)) {
    return NextResponse.json({ ok: false, error: 'Invalid cohort id' }, { status: 400 })
  }

  const result = await readCohort(id)

  if ('error' in result) {
    return NextResponse.json({ ok: false, error: result.error }, { status: result.status })
  }

  return NextResponse.json({ ok: true, data: result.data })
}

export async function PATCH(request: NextRequest, context: Context) {
  const params = await context.params
  const id = Number(params.id)

  if (!Number.isFinite(id)) {
    return NextResponse.json({ ok: false, error: 'Invalid cohort id' }, { status: 400 })
  }

  const body = await request.json().catch(() => ({}))
  return updateCohort(id, body)
}

export async function PUT(request: NextRequest, context: Context) {
  return PATCH(request, context)
}

export async function POST(request: NextRequest, context: Context) {
  return PATCH(request, context)
}
