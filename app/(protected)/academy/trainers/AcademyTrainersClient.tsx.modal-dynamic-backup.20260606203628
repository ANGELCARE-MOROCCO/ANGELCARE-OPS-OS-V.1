function DossierPanel({ number, title, children }: { number: string; title: string; children: any }) {
  return (
    <section className="rounded-[1.8rem] border border-slate-200 bg-white p-5 shadow-sm">
      <div className="mb-4 flex items-center gap-3">
        <span className="grid h-7 w-7 place-items-center rounded-xl bg-blue-600 text-xs font-black text-white">{number}</span>
        <h3 className="text-sm font-black text-slate-950">{title}</h3>
      </div>
      {children}
    </section>
  )
}

function SmartField({
  label,
  value,
  locked,
  required,
  onChange,
}: {
  label: string
  value: string
  locked?: boolean
  required?: boolean
  onChange?: (value: string) => void
}) {
  return (
    <label>
      <span className="text-xs font-black text-slate-600">{label}{required && <b className="text-red-500"> *</b>}</span>
      <input
        disabled={locked}
        value={value || ''}
        onChange={(event) => onChange?.(event.target.value)}
        className="mt-2 h-11 w-full rounded-2xl border border-slate-200 bg-white px-4 text-sm font-bold text-slate-800 outline-none focus:border-blue-400 disabled:bg-slate-50"
      />
    </label>
  )
}

function SmartSelect({
  label,
  value,
  options,
  locked,
  onChange,
}: {
  label: string
  value: string
  options: string[]
  locked?: boolean
  onChange?: (value: string) => void
}) {
  return (
    <label>
      <span className="text-xs font-black text-slate-600">{label}</span>
      <select
        disabled={locked}
        value={value || ''}
        onChange={(event) => onChange?.(event.target.value)}
        className="mt-2 h-11 w-full rounded-2xl border border-slate-200 bg-white px-4 text-sm font-bold text-slate-800 outline-none focus:border-blue-400 disabled:bg-slate-50"
      >
        {options.map((option) => <option key={option} value={option}>{option || 'Select'}</option>)}
      </select>
    </label>
  )
}

function SmartTagField({ label, tags }: { label: string; tags: string[] }) {
  return (
    <div>
      <span className="text-xs font-black text-slate-600">{label}</span>
      <div className="mt-2 flex h-11 items-center gap-2 rounded-2xl border border-slate-200 bg-white px-3">
        {tags.map((tag) => (
          <span key={tag} className="rounded-full bg-blue-50 px-2.5 py-1 text-[10px] font-black text-blue-700">{tag}</span>
        ))}
        <span className="rounded-full bg-violet-50 px-2.5 py-1 text-[10px] font-black text-violet-700">+ Add</span>
      </div>
    </div>
  )
}

function PremiumList({ title, action, rows }: { title: string; action: string; rows: string[][] }) {
  return (
    <div className="rounded-3xl bg-slate-50 p-4">
      <div className="mb-3 flex items-center justify-between">
        <h4 className="text-xs font-black text-slate-500">{title}</h4>
        <button type="button" className="text-xs font-black text-blue-600">{action}</button>
      </div>
      <div className="space-y-2">
        {rows.map((row, index) => (
          <div key={`${title}-${index}-${row[0]}`} className="grid grid-cols-[1fr_auto] gap-2 rounded-2xl bg-white px-3 py-2 text-xs font-black ring-1 ring-slate-100">
            <span>{row[0]}</span>
            <span className={row[row.length - 1].toLowerCase().includes('exp') ? 'text-orange-600' : 'text-emerald-600'}>{row[row.length - 1]}</span>
            <small className="col-span-2 text-[10px] font-bold text-slate-400">{row.slice(1, -1).join(' · ')}</small>
          </div>
        ))}
      </div>
    </div>
  )
}

function VerificationList() {
  return (
    <div className="rounded-3xl bg-slate-50 p-4">
      <h4 className="mb-3 text-xs font-black text-slate-500">Compliance & Verification</h4>
      {[
        ['Medical Fitness', 'Fit'],
        ['Background Check', 'Verified'],
        ['ID Verification', 'Verified'],
        ['Reference Check', 'Verified'],
        ['Contract Signed', 'Pending'],
      ].map(([label, status]) => (
        <div key={label} className="mb-2 flex items-center justify-between rounded-2xl bg-white px-3 py-2 text-xs font-black ring-1 ring-slate-100">
          <span>{label}</span>
          <span className={status === 'Pending' ? 'rounded-full bg-orange-50 px-2 py-1 text-orange-600' : 'rounded-full bg-emerald-50 px-2 py-1 text-emerald-600'}>{status}</span>
        </div>
      ))}
    </div>
  )
}

function ProgressLine({ label, value }: { label: string; value: number }) {
  return (
    <div>
      <div className="mb-1 flex justify-between text-xs font-black">
        <span className="text-slate-500">{label}</span>
        <span>{value}%</span>
      </div>
      <div className="h-2 rounded-full bg-slate-100">
        <div className="h-2 rounded-full bg-blue-600" style={{ width: `${Math.min(100, Math.max(0, value))}%` }} />
      </div>
    </div>
  )
}

function MetricBox({ label, value }: { label: string; value: string | number }) {
  return (
    <div className="rounded-2xl border border-slate-200 bg-white p-4">
      <span className="block text-xs font-black text-slate-500">{label}</span>
      <strong className="mt-1 block text-xl font-black">{value}</strong>
    </div>
  )
}

