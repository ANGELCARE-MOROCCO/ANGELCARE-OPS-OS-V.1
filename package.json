{
  "name": "angelcare-platform",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:web": "npm --prefix apps/ops-web run dev",
    "build:web": "npm --prefix apps/ops-web run build",
    "typecheck:web": "cd apps/ops-web && NODE_OPTIONS=\"--max-old-space-size=8192\" npx tsc --noEmit --pretty false",
    "carelink:deploy-gate": "npm --prefix apps/ops-web run carelink:deploy-gate",
    "android:start": "npm --prefix apps/carelink-android start",
    "android:run": "npm --prefix apps/carelink-android run android",
    "android:debug-apk": "cd apps/carelink-android/android && ./gradlew assembleDebug",
    "android:release-apk": "cd apps/carelink-android/android && ./gradlew assembleRelease",
    "verify:all": "npm run typecheck:web && npm run carelink:deploy-gate && npm run android:debug-apk",
    "dev:extension": "npm --prefix apps/revenue-browser-extension run build",
    "build:extension": "npm --prefix apps/revenue-browser-extension run build",
    "typecheck:extension": "npm --prefix apps/revenue-browser-extension run typecheck",
    "browser-extension:contracts:sync": "node scripts/sync-browser-extension-contracts.mjs",
    "browser-extension:contracts:verify": "node scripts/verify-browser-extension-contracts.mjs",
    "browser-extension:verify": "npm run browser-extension:contracts:verify && npm --prefix apps/ops-web run browser-extension:verify && npm run browser-extension:b2b-ai-sales-director:verify && npm run browser-extension:production-final:verify && npm run browser-extension:scanner-intelligence:verify && npm --prefix apps/revenue-browser-extension run verify && npm run browser-extension:ultra:verify",
    "browser-extension:b2b-intelligence:verify": "npm --prefix apps/ops-web run browser-extension:b2b-intelligence:verify",
    "browser-extension:b2b-execution:verify": "npm --prefix apps/ops-web run browser-extension:b2b-execution:verify",
    "browser-extension:b2b-deal-closing:verify": "npm --prefix apps/ops-web run browser-extension:b2b-deal-closing:verify",
    "browser-extension:b2b-enterprise-experience:verify": "npm --prefix apps/ops-web run browser-extension:b2b-enterprise-experience:verify",
    "browser-extension:b2b-partner-lifecycle:verify": "npm --prefix apps/ops-web run browser-extension:b2b-partner-lifecycle:verify",
    "browser-extension:b2b-ai-sales-director:verify": "npm --prefix apps/ops-web run browser-extension:b2b-ai-sales-director:verify",
    "browser-extension:production-final:verify": "npm --prefix apps/ops-web run browser-extension:production-final:verify",
    "browser-extension:security:verify": "npm --prefix apps/ops-web run browser-extension:security:verify",
    "browser-extension:production-gate": "npm run browser-extension:contracts:verify && npm run typecheck:extension && npm run browser-extension:production-final:verify && npm run browser-extension:security:verify && npm run browser-extension:scanner-intelligence:verify && npm --prefix apps/revenue-browser-extension run build && npm --prefix apps/revenue-browser-extension run verify && npm run browser-extension:ultra:verify",
    "browser-extension:scanner-intelligence:verify": "node scripts/verify-browser-extension-scanner-intelligence-2.mjs",
    "revenue-os:phase07:typecheck": "tsc -p apps/ops-web/tsconfig.revenue-os-phase7-kernel.json --noEmit",
    "revenue-os:phase07:typecheck:integration": "tsc -p apps/ops-web/tsconfig.revenue-os-phase7.json --noEmit",
    "revenue-os:phase07:verify": "node apps/ops-web/scripts/revenue-command-os/verify-phase7.mjs",
    "revenue-os:phase07:test": "node apps/ops-web/scripts/revenue-command-os/run-phase7-command-tests.mjs",
    "revenue-os:phase07:ui-syntax": "node apps/ops-web/scripts/revenue-command-os/transpile-phase7-ui.mjs",
    "revenue-os:phase07:manifest": "node apps/ops-web/scripts/revenue-command-os/print-phase7-manifest.mjs",
    "revenue-os:phase07:semantic-review": "node apps/ops-web/scripts/revenue-command-os/review-phase7-semantic-duplicates.mjs",
    "revenue-os:phase07:sql-review": "node apps/ops-web/scripts/revenue-command-os/review-phase7-sql.mjs",
    "revenue-os:phase07:verify:cumulative": "node apps/ops-web/scripts/revenue-command-os/verify-phase1.mjs && node apps/ops-web/scripts/revenue-command-os/verify-phase2.mjs && node apps/ops-web/scripts/revenue-command-os/verify-phase3.mjs && node apps/ops-web/scripts/revenue-command-os/verify-phase4.mjs && node apps/ops-web/scripts/revenue-command-os/verify-phase5.mjs && node apps/ops-web/scripts/revenue-command-os/verify-phase6.mjs && node apps/ops-web/scripts/revenue-command-os/verify-phase7.mjs",
    "revenue-os:phase08:typecheck": "tsc -p apps/ops-web/tsconfig.revenue-os-phase8-kernel.json --noEmit",
    "revenue-os:phase08:typecheck:integration": "tsc -p apps/ops-web/tsconfig.revenue-os-phase8.json --noEmit",
    "revenue-os:phase08:verify": "node apps/ops-web/scripts/revenue-command-os/verify-phase8.mjs",
    "revenue-os:phase08:test": "node apps/ops-web/scripts/revenue-command-os/run-phase8-command-tests.mjs",
    "revenue-os:phase08:ui-syntax": "node apps/ops-web/scripts/revenue-command-os/transpile-phase8-ui.mjs",
    "revenue-os:phase08:semantic-review": "node apps/ops-web/scripts/revenue-command-os/review-phase8-semantic-duplicates.mjs",
    "revenue-os:phase08:sql-review": "node apps/ops-web/scripts/revenue-command-os/review-phase8-sql.mjs",
    "revenue-os:phase09:typecheck": "tsc -p apps/ops-web/tsconfig.revenue-os-phase9-kernel.json --noEmit",
    "revenue-os:phase09:verify": "cd apps/ops-web && node scripts/revenue-command-os/verify-phase9.mjs",
    "revenue-os:phase09:test": "cd apps/ops-web && node scripts/revenue-command-os/run-phase9-command-tests.mjs",
    "revenue-os:phase09:semantic-review": "cd apps/ops-web && node scripts/revenue-command-os/review-phase9-semantic-duplicates.mjs",
    "revenue-os:phase09:sql-review": "cd apps/ops-web && node scripts/revenue-command-os/review-phase9-sql.mjs",
    "revenue-os:phase09:typecheck:integration": "tsc -p apps/ops-web/tsconfig.revenue-os-phase9.json --noEmit",
    "browser-extension:ultra:verify": "node scripts/verify-browser-extension-ultra-reality.mjs && npm --prefix apps/ops-web run browser-extension:ultra:regression"
  }
}
