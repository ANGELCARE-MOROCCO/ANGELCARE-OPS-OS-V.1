  id: string | number
  mission_id?: string | number
  code?: string
  mission_code?: string
  title?: string
  service_type?: string
  serviceType?: string
  status?: string
  lifecycle_stage?: string
  mission_date?: string
  date?: string
  start_time?: string
  end_time?: string
  startTime?: string
  endTime?: string
  hoursEstimate?: number | string
  city?: string
  zone?: string
  address?: string
  client_name?: string
  family_name?: string
  beneficiary_name?: string
  caregiver_id?: string | number | null
  parent_mission_id?: string | number | null
  mission_kind?: 'single' | 'dossier' | 'sub_mission' | string
  occurrence_index?: number | null
  total_occurrences?: number | null
  checklist?: unknown[]
  report_status?: string
  validation_status?: string
  risk_level?: string
  notes?: string | null
  sla_minutes_remaining?: number | null
  readiness_status?: string
  sla_status?: string
  priority?: string
  urgency?: string
  [key: string]: unknown
}

export type CareLinkDashboard = {
  ok?: boolean
  source?: string
  generatedAt?: string
  agent?: Record<string, unknown> | null
  profile?: Record<string, unknown> | null
  status?: CareLinkStatus
  missions?: CareLinkMission[]
  todayMissions?: CareLinkMission[]
  upcomingMissions?: CareLinkMission[]
